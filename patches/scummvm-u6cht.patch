+// v2.0 B.1 Phase 3: queue Big5 char as 16×16 native glyph.
+// game-space advance = 16 px (= 2 ASCII wide, matches PC-98 ratio).
+// Glyph paints onto _rawSurface at native (x*2, y*2) — 16-pixel real detail.
+uint16 ConvFont::drawBig5Char(Screen *screen, uint8 lead, uint8 trail,
+                              uint16 x, uint16 y, uint8 color) {
+	if (!big5_data || !isBig5Lead(lead) || !isBig5Trail(trail))
+		return 16;
+
+	uint32 toff;
+	if (trail >= 0x40 && trail <= 0x7E)
+		toff = trail - 0x40;
+	else
+		toff = trail - 0xA1 + 63;
+	uint32 idx = (lead - 0xA1) * CFB5_NUM_TRAIL + toff;
+	const unsigned char *g = &big5_data[idx * CFB5_GLYPH_BYTES];
+
+	screen->queueCJKGlyph(x, y, g, color);
+	return 16;
+}
+
+uint16 ConvFont::drawString(Screen *screen, const char *str, uint16 string_len,
+                            uint16 x, uint16 y, uint8 color, uint8 highlight_color) {
+	if (!big5_data)
+		return Font::drawString(screen, str, string_len, x, y, color, highlight_color);
+
+	uint16 font_len = 0;
+	bool highlight = false;
+	for (uint16 i = 0; i < string_len; i++) {
+		uint8 c = (uint8)str[i];
+		if (isBig5Lead(c) && i + 1 < string_len && isBig5Trail((uint8)str[i + 1])) {
+			// CHT: render at y (no lift). ConverseGump line stride is 10 px so
+			// 12 px Big5 has 2 px tail intruding into next line top — usually
+			// empty descender padding in WQY Sharp.
+			font_len += drawBig5Char(screen, c, (uint8)str[i + 1],
+			                         x + font_len, y,
+			                         highlight ? highlight_color : color);
+			i++;
+			highlight = false;
+			continue;
+		}
+		if (c == '@') {
+			highlight = true;
+			continue;
+		}
+		if (!Common::isAlpha(c))
+			highlight = false;
+		font_len += drawChar(screen, c, x + font_len, y,
+		                     highlight ? highlight_color : color);
+	}
+	return font_len;
+}
+
 } // End of namespace Nuvie
 } // End of namespace Ultima
