+bool ConvFont::initBig5(const Common::Path &path) {
+	Common::File f;
+	if (!f.open(path))
+		return false;
+	uint32 sz = f.size();
+	if (sz != CFB5_FILE_SIZE) {
+		f.close();
+		return false;
+	}
+	big5_data = (unsigned char *)malloc(sz);
+	if (!big5_data) {
+		f.close();
+		return false;
+	}
+	f.read(big5_data, sz);
+	big5_size = sz;
+	f.close();
+	return true;
