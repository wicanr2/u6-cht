+	// v2.0 B.1 Phase 3: paint a 16×16 CJK glyph DIRECTLY onto _overlaySurface
+	// (persistent across frames). Name kept as "queueCJKGlyph" so font path
+	// callers don't need rewiring — but it's no longer a queue.
+	if (!glyph32 || !_overlaySurface || !_renderSurface ||
+	    _renderSurface->bits_per_pixel != 16)
+		return;
+	uint16 *dst       = (uint16 *)_overlaySurface->getPixels();
+	uint32 dst_pitch  = _overlaySurface->pitch / 2;
+	uint16 native_x   = game_x * _displayScale;
+	uint16 native_y   = game_y * _displayScale;
+	uint16 ow         = (uint16)_overlaySurface->w;
+	uint16 oh         = (uint16)_overlaySurface->h;
+	uint16 color      = (uint16)_renderSurface->colour32[color_index];
+	// Transparent color key is 0x0000 (pure black). If a CJK glyph asks for
+	// black, nudge to 0x0001 so it survives compose; visually indistinguishable.
+	if (color == 0x0000) color = 0x0001;
+	for (int r = 0; r < 16; ++r) {
+		int row_y = native_y + r;
+		if (row_y < 0 || row_y >= (int)oh) continue;
+		uint16 bits = ((uint16)glyph32[r * 2] << 8) | glyph32[r * 2 + 1];
+		if (!bits) continue;
+		uint16 *rowPtr = dst + (uint32)row_y * dst_pitch;
+		for (int c = 0; c < 16; ++c) {
+			if (bits & (0x8000 >> c)) {
+				int col_x = native_x + c;
+				if (col_x >= 0 && col_x < (int)ow)
+					rowPtr[col_x] = color;
+			}
+		}
+	}
+}
+
+// (debug logging removed after Phase 3 verified 2026-06-27)
+
 void Screen::performUpdate() {
+	// v2.0 B.1 Phase 2: 2× nearest-neighbor scale _gameSurface (320×200) → _rawSurface (640×400).
+	if (_gameSurface && _rawSurface && _gameSurface->format.bytesPerPixel == 2) {
+		const uint16 *src = (const uint16 *)_gameSurface->getPixels();
+		uint16 *dst       = (uint16 *)_rawSurface->getPixels();
+		uint32 src_pitch  = _gameSurface->pitch / 2;
+		uint32 dst_pitch  = _rawSurface->pitch / 2;
+		uint16 gw         = (uint16)_gameSurface->w;
+		uint16 gh         = (uint16)_gameSurface->h;
+		for (uint16 y = 0; y < gh; ++y) {
+			const uint16 *sr = src + (uint32)y * src_pitch;
+			uint16 *dr0      = dst + ((uint32)y * 2) * dst_pitch;
+			uint16 *dr1      = dr0 + dst_pitch;
+			for (uint16 x = 0; x < gw; ++x) {
+				uint16 c = sr[x];
+				uint32 dx = (uint32)x * 2;
+				dr0[dx]     = c;
+				dr0[dx + 1] = c;
+				dr1[dx]     = c;
+				dr1[dx + 1] = c;
+			}
+		}
+
+		// v2.0 B.1 Phase 3: compose persistent _overlaySurface onto _rawSurface.
+		// Skip transparent key (0x0000) so only CJK glyph pixels overlay.
+		if (_overlaySurface && _overlaySurface->format.bytesPerPixel == 2) {
+			const uint16 *osrc = (const uint16 *)_overlaySurface->getPixels();
+			uint16 *dstPx     = (uint16 *)_rawSurface->getPixels();
+			uint32 src_pitch_o = _overlaySurface->pitch / 2;
+			uint32 dst_pitch_o = _rawSurface->pitch / 2;
+			uint16 ow         = (uint16)_overlaySurface->w;
+			uint16 oh         = (uint16)_overlaySurface->h;
+			for (uint16 y = 0; y < oh; ++y) {
+				const uint16 *sr = osrc + (uint32)y * src_pitch_o;
+				uint16 *dr       = dstPx + (uint32)y * dst_pitch_o;
+				for (uint16 x = 0; x < ow; ++x) {
+					uint16 px = sr[x];
+					if (px) dr[x] = px;  // 0x0000 = transparent
+				}
+			}
+		}
+
+		// Tell ScummVM the whole raw surface is dirty so it actually pushes the 2×-scaled frame
+		_rawSurface->addDirtyRect(Common::Rect(0, 0, _rawSurface->w, _rawSurface->h));
+	}
 	_rawSurface->update();
 }
 
 void Screen::set_screen_mode() {
 	const Graphics::PixelFormat SCREEN_FORMAT(2, 5, 6, 5, 0, 11, 5, 0, 0);
-	initGraphics(width, height, &SCREEN_FORMAT);
-	_rawSurface = new Graphics::Screen(width, height, SCREEN_FORMAT);
-
-	_renderSurface = CreateRenderSurface(_rawSurface);
+	// v2.0 B.1: native window = game × _displayScale (640×400).
+	// _gameSurface is the 320×200 framebuffer all existing Nuvie blit/fill paths
+	// write to (via _renderSurface wrapper). Screen.width/height stay 320×200
+	// for callers — they don't know the native surface is 2× bigger.
+	// _overlaySurface is 640×400 transparent (0x0000 key); CJK 16×16 painted
+	// directly here; performUpdate composes it onto _rawSurface after game scale.
+	uint16 native_w = width  * _displayScale;
+	uint16 native_h = height * _displayScale;
+	initGraphics(native_w, native_h, &SCREEN_FORMAT);
+	_rawSurface     = new Graphics::Screen(native_w, native_h, SCREEN_FORMAT);
+	_gameSurface    = new Graphics::ManagedSurface(width, height, SCREEN_FORMAT);
+	_overlaySurface = new Graphics::ManagedSurface(native_w, native_h, SCREEN_FORMAT);
+	_overlaySurface->fillRect(Common::Rect(0, 0, native_w, native_h), 0); // transparent
+
+	_renderSurface = CreateRenderSurface(_gameSurface);
 }
 
