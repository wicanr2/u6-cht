+static const uint32 CFB5_NUM_TRAIL = 157;
+static const uint32 CFB5_GLYPH_BYTES = 32;
+static const uint32 CFB5_FILE_SIZE = 94 * CFB5_NUM_TRAIL * CFB5_GLYPH_BYTES; // 472256
