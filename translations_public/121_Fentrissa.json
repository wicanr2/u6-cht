{
 "_meta": {},
 "translations": [
  {
   "hash": "7b65c93345e43d41",
   "zh": "身強體健的女子，眼神剛毅。",
   "note": "DESC"
  },
  {
   "hash": "9b5073e57d58033d",
   "zh": "「聞聞那鹹海風，朋友，讓我眼眶泛濕……」"
  },
  {
   "hash": "ac0cc2e5331e3a41",
   "zh": "「歡迎，歡迎！」她用力拍了拍你的背。"
  },
  {
   "hash": "6c637ad996efbfbe",
   "zh": "「@芬翠莎。」"
  },
  {
   "hash": "3ce080ae47fc6735",
   "zh": "「響亮的名字，如同@大海一般強勁。」她遠眺天際。"
  },
  {
   "hash": "48f66067b1af640c",
   "zh": "「美麗之物，卻是個@善妒的傢伙。」",
   "note": "她稱海為 he（男性），下文有人物回應"
  },
  {
   "hash": "734d0d81eded1162",
   "zh": "「很多人叫它女性。」"
  },
  {
   "hash": "39a5fbb6df0733f3",
   "zh": "「依我說，男人才更難捉摸呢。」"
  },
  {
   "hash": "09c1102cdb20b867",
   "zh": "「你把我最後一艘船買走了。」"
  },
  {
   "hash": "9b406c5664b2c690",
   "zh": "「我賣",
   "note": "句子開頭，與後面部分拼接"
  },
  {
   "hash": "0c862e0782ef96fc",
   "zh": " @帆船。」"
  },
  {
   "hash": "9b4868755b02bb37",
   "zh": " @小艇。」"
  },
  {
   "hash": "019b4e8b37814c27",
   "zh": " @帆船與@小艇。」"
  },
  {
   "hash": "d197a44af89840bc",
   "zh": "「抱歉，已賣給你最後一艘了。」"
  },
  {
   "hash": "a4cbfb2dedcf57e6",
   "zh": "「把船和小艇都賣給你後，我就沒活幹了。」"
  },
  {
   "hash": "e54ece2e2cbb3193",
   "zh": "「我有@帆船可賣，但最後一艘@小艇已賣給你了。」"
  },
  {
   "hash": "9bb967ed9473fb8a",
   "zh": "「最後一艘@帆船已賣給你了，但還有幾艘@小艇。」"
  },
  {
   "hash": "6b7f83c0969ef988",
   "zh": "「我賣@帆船和@小艇。」"
  },
  {
   "hash": "43a0540dfc1e7d3c",
   "zh": "「保重。」她叉著腰鞠了個躬。"
  },
  {
   "hash": "8d6393e625d5e067",
   "zh": "「去問問別人吧。」"
  },
  {
   "hash": "7c727576c584c866",
   "zh": "$N轉向$Y：「這份船契要#4枚金幣。有意嗎？」"
  },
  {
   "hash": "edc5c174c28c98fb",
   "zh": "$N看了看$Y：「你好像裝得滿滿的了。」"
  },
  {
   "hash": "09d94fa66a98a319",
   "zh": "「好極了！」$N收下金幣，將船契遞給$Y。"
  },
  {
   "hash": "5a108f0bdbd387a7",
   "zh": "「一帆風順。」"
  },
  {
   "hash": "663d72312f313f70",
   "zh": "「你再也找不到更好的船了。」"
  },
  {
   "hash": "9170399f08bcacb9",
   "zh": "「你們的錢不夠。」"
  },
  {
   "hash": "02d17966438147d7",
   "zh": "「你似乎還差#1枚金幣。」",
   "note": "保留 \\s"
  },
  {
   "hash": "c27fc4efce75462a",
   "zh": "「抱歉。」"
  },
  {
   "hash": "a4717e411db607ec",
   "zh": "你們一起湊錢買下了船契。"
  }
 ],
 "glossary_additions": {
  "people": {
   "Fentrissa": "芬翠莎"
  },
  "places": {}
 },
 "translator_notes": "Fentrissa 賣船女商人，豪邁海員氣息。ship → 帆船，skiff → 小艇，deed → 船契。"
}
