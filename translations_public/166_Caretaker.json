{
 "_meta": {},
 "translations": [
  {
   "hash": "cc668ab31bec9317",
   "zh": "守藏者",
   "note": "NPC name — 魔像守藏官"
  },
  {
   "hash": "9af03491ab54c9b5",
   "zh": "年邁之有翼魔像，臉上架著一具以玻璃與金屬製成的奇特裝置。",
   "note": "DESC — 即眼鏡"
  },
  {
   "hash": "dade2f7356cc4d7b",
   "zh": "魔像無視你，繼續書寫。",
   "note": "旁白"
  },
  {
   "hash": "1a508c89c1eb1e28",
   "zh": "「什麼事？欲問此番",
   "note": "前半段"
  },
  {
   "hash": "4ed131f7c9e7bf9a",
   "zh": "又一次"
  },
  {
   "hash": "0ede6b72726accd3",
   "zh": "此番"
  },
  {
   "hash": "529bc750d559b3de",
   "zh": "打擾之緣由？」",
   "note": "後半段"
  },
  {
   "hash": "2997598d3d5a33b2",
   "zh": "「以為汝在說笑。」"
  },
  {
   "hash": "0e4f4c6263b51f17",
   "zh": "「汝亦知之，汝等已將知識寶典帶往人類那一側的世界！」"
  },
  {
   "hash": "c61b5ab5544eaed3",
   "zh": "「吾非路牌！」",
   "note": "不耐煩的簡短回答"
  },
  {
   "hash": "5e40aa900043182b",
   "zh": "「獨身者神殿在北方山中——前提是汝能@fly飛翔！」"
  },
  {
   "hash": "f8c912ad268d0053",
   "zh": "「徒步無法抵達深鎖於山中的獨身者神殿。」"
  },
  {
   "hash": "cfb1ad4aefd8c072",
   "zh": "「唯有翼魔像方能抵達該聖地。」"
  },
  {
   "hash": "fe777dc417dc6b80",
   "zh": "「吾認為此乃最為適切之安排。」"
  },
  {
   "hash": "428b2bdd8bc7c1f0",
   "zh": "「吾不見任何理由讓人類烏合之眾進入神殿。」"
  },
  {
   "hash": "b05356d8d6cce666",
   "zh": "「汝所求之物在@Vortex渦旋之室。」"
  },
  {
   "hash": "77ddcbfeabc70d3b",
   "zh": "「汝所求之物在@Librum典籍之室。」"
  },
  {
   "hash": "730abda632565b02",
   "zh": "「可嘆此物已失，多年前遭人類竊賊盜走。」"
  },
  {
   "hash": "a1a2408bf0b06f54",
   "zh": "「曾聞逃走的人類提及@Stonegate石門之名。」"
  },
  {
   "hash": "f7d8a616b92fb08e",
   "zh": "「曾聞其言將乘船穿越絕望灣。」"
  },
  {
   "hash": "2464a48190e283b9",
   "zh": "「對其下落，吾一無所知。」"
  },
  {
   "hash": "77f38568d7deb7a3",
   "zh": "「對月光石之所在，吾坦承不知。」"
  },
  {
   "hash": "0ed3f5b3e4050daf",
   "zh": "「吾料其在充滿人類的幽冥界某處。」"
  },
  {
   "hash": "f723d57b8255022e",
   "zh": "「吾以守藏者之稱代替真名。」"
  },
  {
   "hash": "6655f33b245405e0",
   "zh": "「能在此@Hall殿中盡守藏@duties職責，深感榮幸。」"
  },
  {
   "hash": "3225675707e72dd5",
   "zh": "「守護吾族典藏於@Hall智識之殿的珍寶文物。」"
  },
  {
   "hash": "7265a356a68fed8f",
   "zh": "「將吾族珍貴文物置於此殿三@chambers廳室之中。」"
  },
  {
   "hash": "f24fb98c92443a68",
   "zh": "「此殿共有三室：」"
  },
  {
   "hash": "bf6a754992f1c059",
   "zh": "「東側人類之室存放來自@Underworld幽冥界的文物。」"
  },
  {
   "hash": "5f60c8f971259a25",
   "zh": "「西側典籍之室存放珍貴典籍。」"
  },
  {
   "hash": "297b4f9664424a99",
   "zh": "「南側渦旋之室存放@Cube渦旋立方體與@Lens渦旋透鏡。」"
  },
  {
   "hash": "b2fc704d1b017b59",
   "zh": "「是的，幽冥界。吾料汝等稱之為『不列顛尼亞』。」",
   "note": "gargoyle 視角：不列顛尼亞=幽冥界"
  },
  {
   "hash": "fd9867514d58e7be",
   "zh": "魔像一言不發，繼續低頭工作。",
   "note": "旁白"
  },
  {
   "hash": "3a6e598bd784834a",
   "zh": "「吾無暇閒聊。」"
  },
  {
   "hash": "0a39f4c3a43db678",
   "zh": "「請直說正事，然後離去。」"
  }
 ],
 "glossary_additions": {
  "people": {},
  "places": {
   "Lost Hope Bay": "絕望灣"
  }
 },
 "translator_notes": "守藏者為學究型老魔像，不耐煩人類打擾，語氣傲慢簡短。魔像To+動詞語法一律譯為文言。其視角中不列顛尼亞=幽冥界，此為魔像族世界觀重要設定。"
}
