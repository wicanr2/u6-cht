{
 "_meta": {},
 "translations": [
  {
   "hash": "c302897ab203945f",
   "zh": "造透鏡者",
   "note": "NPC name — glossary 已有"
  },
  {
   "hash": "d7054d5a19728d87",
   "zh": "極為年邁之魔像。",
   "note": "DESC"
  },
  {
   "hash": "6b8c323c94fcf81c",
   "zh": "魔像驚恐地喘息，氣喘吁吁地嘶喊：「An-bal-sil-fer！」",
   "note": "旁白，魔像語保留"
  },
  {
   "hash": "3d28bb1a9f4dcd43",
   "zh": "而後他徹底昏厥！",
   "note": "旁白"
  },
  {
   "hash": "bc5c6442628d12d0",
   "zh": "魔像驚恐地喘息，氣喘吁吁地嘶喊：「偽先知！」",
   "note": "旁白"
  },
  {
   "hash": "3d28bb1a9f4dcd43",
   "zh": "而後他徹底昏厥！",
   "note": "旁白（重複）"
  },
  {
   "hash": "c4be79c0742c6193",
   "zh": "這位德高望重的魔像仔細打量你。",
   "note": "旁白"
  },
  {
   "hash": "eaa84f20fc6a9f2c",
   "zh": "「問候，偽先知。」"
  },
  {
   "hash": "098ac1ff64ba262d",
   "zh": "「久前@Naxatilor曾告知吾，汝有朝一日將來見吾，頸間佩戴臣服護符。」"
  },
  {
   "hash": "59a102c6375817e2",
   "zh": "「吾從未信以為真，以為此事不可能發生。」"
  },
  {
   "hash": "5f90dd007ba4ed2b",
   "zh": "「問有何可效勞之處？」"
  },
  {
   "hash": "7b9cd1d7eb5b13da",
   "zh": "「再問有何可助汝之處？」"
  },
  {
   "hash": "64ca9d9726521ca3",
   "zh": "「納悶汝為何未將碎裂的透鏡帶回？！」"
  },
  {
   "hash": "ea83408b9c0021bb",
   "zh": "「早已告知汝，吾需要碎片方能製作新的透鏡！」"
  },
  {
   "hash": "0dd9328150e113bc",
   "zh": "「問汝以為吾沒有碎片能做什麼？」"
  },
  {
   "hash": "009a894ddff73c52",
   "zh": "「年代久遠，吾所記已甚少，」魔像喉音沙啞道。",
   "note": "旁白嵌入"
  },
  {
   "hash": "a013b68f53dc8b59",
   "zh": "「需要透鏡碎片，方能製作新的複製品。」"
  },
  {
   "hash": "43cff14a0a5c1989",
   "zh": "「當然，吾沒有名字。」"
  },
  {
   "hash": "b49fea8a13ca9687",
   "zh": "「然許多博學之魔像稱吾為洛爾-維斯-蘭，即光之學者。」"
  },
  {
   "hash": "17066e1d12379235",
   "zh": "說此話時，這位古老魔像面露自豪之色。",
   "note": "旁白"
  },
  {
   "hash": "10304ab3129cdb45",
   "zh": "「打造此地最精良之透鏡，」魔像自豪地說。",
   "note": "旁白嵌入"
  },
  {
   "hash": "6c0505cafeff4e03",
   "zh": "「亦教導年輕@apprentices學徒勿讓玻璃割傷自己！」"
  },
  {
   "hash": "0fd226b4ea2b3b09",
   "zh": "「吾之@time時日已近末途。」"
  },
  {
   "hash": "b39a8afd4e3c4092",
   "zh": "「吾有最後一項神聖職責：」"
  },
  {
   "hash": "61df567857ab7bac",
   "zh": "「將吾之技藝傳承予下一代。」"
  },
  {
   "hash": "37d36fc4d587747b",
   "zh": "「吾已逾千歲。」"
  },
  {
   "hash": "d508f6d23c3b86b1",
   "zh": "「然與@Naxatilor相比，吾不過是個少年。」"
  },
  {
   "hash": "d7cec5bb47bc6286",
   "zh": "「數百年前，曾協助納薩蒂製作渦旋透鏡。」"
  },
  {
   "hash": "ac9ca042ee7eb4b3",
   "zh": "「即便在當時，吾便已覺得他德高望重、飽經歲月！」"
  },
  {
   "hash": "3324eb57787b706b",
   "zh": "「能助偽先知一臂之力，深感榮幸。」"
  },
  {
   "hash": "87de208aadb852cc",
   "zh": "「吾年邁。此事建議汝去問旁人。」"
  },
  {
   "hash": "ab2f44d5be8e0cf8",
   "zh": "「見汝攜帶已碎裂之渦旋透鏡。」"
  },
  {
   "hash": "589b1cbf511c45a0",
   "zh": "「記得製作此物之時，已是極久以前的事了。」"
  },
  {
   "hash": "839367afcb680dd8",
   "zh": "取過玻璃碎片，造透鏡者轉向研磨台。",
   "note": "旁白"
  },
  {
   "hash": "2686d9191033f8f6",
   "zh": "不多時，他已打造出全新的渦旋透鏡！",
   "note": "旁白"
  },
  {
   "hash": "992851a578f53dcd",
   "zh": "「如今技藝遠勝初次製作此透鏡之時，」他自鳴得意道。",
   "note": "旁白嵌入"
  },
  {
   "hash": "163a7ffa02db976d",
   "zh": "「修復所需時間甚短。」"
  },
  {
   "hash": "90ecc0e6db3138d4",
   "zh": "他將修復後的渦旋透鏡交給你。",
   "note": "旁白"
  }
 ],
 "glossary_additions": {
  "people": {
   "Lor-wis-lem": "洛爾-維斯-蘭（光之學者）"
  },
  "places": {}
 },
 "translator_notes": "造透鏡者為千歲以上的老魔像工匠，曾與納薩蒂合作打造渦旋透鏡。語氣沉穩淡然，自豪於技藝。關鍵道具互動（收碎片→製新透鏡）旁白保持敘述清晰。"
}
