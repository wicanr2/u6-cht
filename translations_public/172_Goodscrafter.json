 "_meta": {},
 "translations": [
  {
   "hash": "9b5312b762f53aa6",
   "zh": "工匠",
   "note": "NPC name — glossary 已有"
  },
  {
   "hash": "3c8bc269759b79fb",
   "zh": "沉默而了無生氣的魔像。",
   "note": "DESC"
  },
  {
   "hash": "2e7eba712dea4cff",
   "zh": "「哦，偽先知，」魔像平靜地說。",
   "note": "旁白嵌入"
  },
  {
   "hash": "d2a485de47424a99",
   "zh": "「以為汝也是來殺吾的。罷了。」"
  },
  {
   "hash": "0973f3dc363f8f3e",
   "zh": "「An-bal-sil-fer，」魔像平靜地說。「Sum in-korp i. Vers.」",
   "note": "魔像語保留原文"
  },
  {
   "hash": "22ff7829469220fd",
   "zh": "魔像靜默地等待命運降臨。",
   "note": "旁白"
  },
  {
   "hash": "d0f32313f83461e4",
   "zh": "「問偽先知為何再度來擾吾。」"
  },
  {
   "hash": "1770954f798ec6d9",
   "zh": "「見汝頸間之臣服護符。」"
  },
  {
   "hash": "861a2e9126d6c47c",
   "zh": "「如此，便是吾之世界已得救。」"
  },
  {
   "hash": "4c0d6b1fcc6938ff",
   "zh": "「然感覺救贖來得太@late遲了。」"
  },
  {
   "hash": "b41895f697849b44",
   "zh": "「吾拒絕與造成吾@grief哀慟之人談論此事。」"
  },
  {
   "hash": "340ed7fad636958e",
   "zh": "「汝必知竊取知識寶典給吾族帶來何等痛苦？」"
  },
  {
   "hash": "0d792d5d762485a2",
   "zh": "「吾不信汝在乎。事實上，吾深信汝以造成@suffering苦難為樂。」"
  },
  {
   "hash": "79cc46828c8fa9b1",
   "zh": "「吾不信汝會做任何事來幫助吾族。」"
  },
  {
   "hash": "9916a5232a70902d",
   "zh": "「吾沒有名字。」"
  },
  {
   "hash": "d27e822f3821ea7f",
   "zh": "「吾如今已一無所有……」"
  },
  {
   "hash": "e09df0f00b46ba85",
   "zh": "「吾是工匠。」"
  },
  {
   "hash": "5c2b5a06d30086df",
   "zh": "「然而如今已無理由再製作@goods物品了。」"
  },
  {
   "hash": "52468b4bdf735527",
   "zh": "「隨汝取用所需。」"
  },
  {
   "hash": "45de7899648f828b",
   "zh": "「在那場@cataclysms大災變中，吾失去了所有家人。」"
  },
  {
   "hash": "70ee379bbf0bb7cb",
   "zh": "「吾不願提及此事。」"
  },
  {
   "hash": "9e8d3af715ce1aff",
   "zh": "「吾在此等候汝回來殺吾。」",
   "note": "工匠的絕望"
  },
  {
   "hash": "971b7b12e5fb111b",
   "zh": "「吾不在乎$Z。」"
  },
  {
   "hash": "e0ee425849cae3df",
   "zh": "「吾如今什麼都不在乎了。」"
  }
 ],
 "glossary_additions": {
  "people": {},
  "places": {}
 },
 "translator_notes": "工匠為失去全部家人的絕望魔像，對偽先知的到來完全冷漠甚至歡迎死亡。語氣虛無，截然不同於其他魔像的對抗姿態。大災變（cataclysms）造成知識寶典失竊後的地震海嘯等。"
}
