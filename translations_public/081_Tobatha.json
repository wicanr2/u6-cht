{
 "_meta": {},
 "translations": [
  {
   "hash": "028101db157ff17d",
   "zh": "一位步履蹣跚的老婦人。",
   "note": "DESC"
  },
  {
   "hash": "4739ac05f4ced2b1",
   "zh": "「汝是何人，所為何來？」"
  },
  {
   "hash": "74fab6eadfd5956b",
   "zh": "「嗯？大聲說！」"
  },
  {
   "hash": "409451615a3e243f",
   "zh": "「嗯？這是什麼胡鬧？」"
  },
  {
   "hash": "8cde3f0c3ed32323",
   "zh": "「這裡根本沒有死人！」"
  },
  {
   "hash": "6ca7c1bf29e7b217",
   "zh": "「老身名叫@Tobatha（托芭）莎。」"
  },
  {
   "hash": "e847d7be0da4d131",
   "zh": "「但汝可叫我@maam（老太），年輕人。」"
  },
  {
   "hash": "b057adbab986364b",
   "zh": "「對我得叫@maam（老太），年輕人，尊老愛幼！」"
  },
  {
   "hash": "6e5728e46fa05d3d",
   "zh": "「這才對。那汝要什麼？」"
  },
  {
   "hash": "e9e5f506dbded74b",
   "zh": "「職業？老身是治療@inflicted（患難）者之人！」"
  },
  {
   "hash": "e6386771ffe3f5cd",
   "zh": "「若非如此，汝來此何為？」"
  },
  {
   "hash": "ffff38e9e9e67d65",
   "zh": "「莫再胡鬧，年輕人，說吧，汝要什麼。」"
  },
  {
   "hash": "e6a9d74029f3c19f",
   "zh": "「老身能@heal（治傷）、@cure（解毒），甚至@raise（起死）回生！」"
  },
  {
   "hash": "cc98204ca6ef6e66",
   "zh": "「哦，是嘛！汝不過是想討老身歡心罷了。」"
  },
  {
   "hash": "4f6d3053d70ca04f",
   "zh": "「哼，沒用的！」"
  },
  {
   "hash": "839a095369b89a01",
   "zh": "「哼！連個@thank（謝字）都沒有。」"
  },
  {
   "hash": "dbd01b6818b41dac",
   "zh": "「這就是現在的年輕人！一個個都沒禮貌！」"
  },
  {
   "hash": "063172ec64cfeda3",
   "zh": "「那老身能為汝效勞何事？」"
  },
  {
   "hash": "2658d3a7e4897535",
   "zh": "「莫拿這種事來煩老身！」"
  },
  {
   "hash": "c9e78c20532f5134",
   "zh": "「說什麼治傷？汝又沒有受傷！」"
  },
  {
   "hash": "9d519e776952a3e4",
   "zh": "「說什麼治傷？汝等沒有一個受傷！」"
  },
  {
   "hash": "7bf2e7fe4fc43e63",
   "zh": "「你們哪位？」"
  },
  {
   "hash": "4db295c43f282369",
   "zh": "「嗯，老身看到汝的傷了，$Y。」"
  },
  {
   "hash": "87ef4fd0f61f6961",
   "zh": "「汝願意奉上30枚金幣否？」"
  },
  {
   "hash": "ea4fac2189288f9d",
   "zh": "托芭莎將手覆於$Y身上，為其療傷。"
  },
  {
   "hash": "3d738f83d1f3f0ba",
   "zh": "「哼，若汝不肯付錢，老身憑何替汝治傷？」"
  },
  {
   "hash": "93b1bcab817f4767",
   "zh": "「汝等年輕人以為什麼都是免費的！」"
  },
  {
   "hash": "77ecbe0eac72fddc",
   "zh": "「汝這年輕人還算不差。」"
  },
  {
   "hash": "61fc0ddc2357c5ba",
   "zh": "「好吧，老身替汝療傷。」"
  },
  {
   "hash": "ea4fac2189288f9d",
   "zh": "托芭莎將手覆於$Y身上，為其療傷。"
  },
  {
   "hash": "2ab6b74343f2b145",
   "zh": "「還要什麼？」"
  },
  {
   "hash": "d828d82d27d3421c",
   "zh": "「說什麼解毒？汝並未中毒！」"
  },
  {
   "hash": "18534e0afda22346",
   "zh": "「說什麼解毒？汝等沒有一個中毒！」"
  },
  {
   "hash": "7bf2e7fe4fc43e63",
   "zh": "「你們哪位？」"
  },
  {
   "hash": "5ad4d6b5ec01aa54",
   "zh": "「嗯，$Y，老身看得出汝已中毒。」"
  },
  {
   "hash": "c2e73e73444a5d5b",
   "zh": "「汝願意奉上10枚金幣否？」"
  },
  {
   "hash": "1bac5907f1fd0da5",
   "zh": "托芭莎將手覆於$Y身上，為其除去毒素。"
  },
  {
   "hash": "fa039a1fdede07b2",
   "zh": "「哼，若汝不肯付錢，就別想得到解毒！」"
  },
  {
   "hash": "93b1bcab817f4767",
   "zh": "「汝等年輕人以為什麼都是免費的！」"
  },
  {
   "hash": "77ecbe0eac72fddc",
   "zh": "「汝這年輕人還算不差。」"
  },
  {
   "hash": "5aedec79445dafcb",
   "zh": "「好吧，老身替汝解毒。」"
  },
  {
   "hash": "1bac5907f1fd0da5",
   "zh": "托芭莎將手覆於$Y身上，為其除去毒素。"
  },
  {
   "hash": "cba00113a63158f0",
   "zh": "「哼，年輕人就是這樣？」"
  },
  {
   "hash": "e9c4e6c83d9e46fb",
   "zh": "「犯了錯，還指望長輩替他們收拾爛攤子。」"
  },
  {
   "hash": "7a5a546ba70d0c99",
   "zh": "「好吧，今日汝走運了。」"
  },
  {
   "hash": "bee3fae276f0725c",
   "zh": "「汝願意奉上400枚金幣否？」",
   "note": "復活費"
  },
  {
   "hash": "a815483f301b1933",
   "zh": "「那便去找掘墓人吧，老身猜他的要價更低。」"
  },
  {
   "hash": "b924be6ab9afb455",
   "zh": "「錢不夠。」"
  },
  {
   "hash": "46a5f426ffa5bbcb",
   "zh": "「汝還差#1枚金幣。」"
  },
  {
   "hash": "4bad2430a4712596",
   "zh": "「去找掘墓人吧，老身猜他的要價更低。」"
  },
  {
   "hash": "442e99118a9e0726",
   "zh": "汝的隊伍為倒下的同伴湊齊了費用。"
  },
  {
   "hash": "185522449e2ad26e",
   "zh": "托芭莎將手覆於屍體之上……"
  },
  {
   "hash": "514009a24fcb86ac",
   "zh": "「多瑪恩……」",
   "note": "復活咒語音譯"
  },
  {
   "hash": "f969324013f7d968",
   "zh": "「提克蘇斯……」",
   "note": "復活咒語音譯"
  },
  {
   "hash": "f9ef335076824b7b",
   "zh": "「安瑞圖！」",
   "note": "復活咒語音譯"
  },
  {
   "hash": "5882524ad132e7e4",
   "zh": "死者就此重生！"
  },
  {
   "hash": "a140b79a925925c4",
   "zh": "「看來$Y又惹了一個。」"
  }
 ],
 "glossary_additions": {
  "people": {
   "Tobatha": "托芭莎"
  }
 },
 "translator_notes": "081 Tobatha: 崔西克老婦醫者，暴躁但心善。口頭禪「年輕人」「老身」統一。咒語以音譯處理。"
}
