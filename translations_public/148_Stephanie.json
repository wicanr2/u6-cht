{
 "_meta": {},
 "translations": [
  {
   "hash": "1b1188c0a69e9f88",
   "zh": "凝視遠方的年輕女子。",
   "note": "DESC（她是盲人）"
  },
  {
   "hash": "64dfeb4490f61c42",
   "zh": "「我認出你的聲音了。」她微笑。"
  },
  {
   "hash": "d0ed20d9a358e5af",
   "zh": "「你好？有人在嗎？」"
  },
  {
   "hash": "add80e13b9463a16",
   "zh": "「史黛芬妮，但你可以叫我『@Steph（小黛）』。」"
  },
  {
   "hash": "729c28f71a49a814",
   "zh": "「這樣好多了。」"
  },
  {
   "hash": "ae01d200fc153638",
   "zh": "「但我感知到你們中沒有人死亡。」"
  },
  {
   "hash": "c721483cdf48d67b",
   "zh": "「我們這裡沒有所謂的『職業』。」"
  },
  {
   "hash": "1bffe8db67aaed94",
   "zh": "「但我能@heal（療傷）、@cure（解毒）和@resurrect（起死）回生。」"
  },
  {
   "hash": "69bb6258eefcb476",
   "zh": "「$T好，朋友",
   "note": "下接句號"
  },
  {
   "hash": "9fc9835c1728e8af",
   "zh": "。保重。」她長睫毛輕顫片刻。"
  },
  {
   "hash": "783c8a562699cf6c",
   "zh": "「我覺得那種事不適合問我。」"
  },
  {
   "hash": "e8c1eb571ac0c7aa",
   "zh": "「開門的時候來我的店！」"
  },
  {
   "hash": "58245472099d89cb",
   "zh": "觸摸你的額頭後她說：「你的狀況感覺很好。」"
  },
  {
   "hash": "ce7b61e021d3d51f",
   "zh": "她逐一觸摸各人的額頭，將耳朵湊近你們的口邊。"
  },
  {
   "hash": "868f605898deca4a",
   "zh": "「你們沒有一個生病！」"
  },
  {
   "hash": "7bf2e7fe4fc43e63",
   "zh": "「你們哪位？」"
  },
  {
   "hash": "5d4878edc413970f",
   "zh": "「我感知到你的傷，$Y。」"
  },
  {
   "hash": "b2c2aade732c6ec4",
   "zh": "「你願意獻上25枚金幣嗎？」"
  },
  {
   "hash": "502658ee4607285f",
   "zh": "她闔上眼睛，將纖細的手放在你的額頭，輕聲吟誦。"
  },
  {
   "hash": "9b81adecfc269ed5",
   "zh": "你感覺好多了。"
  },
  {
   "hash": "bcf59774cf8914bd",
   "zh": "「若你不願奉獻，我便無法為你療傷。」"
  },
  {
   "hash": "c00f57884b40ba39",
   "zh": "「抱歉。沒有奉獻，我無法為你療傷。」"
  },
  {
   "hash": "b6ce19302116f2be",
   "zh": "「我感知到你的猶豫，源自空空的口袋。」"
  },
  {
   "hash": "f2b0a18fb49d7298",
   "zh": "「我也感知到你的事業是正義的。」"
  },
  {
   "hash": "502658ee4607285f",
   "zh": "她闔上眼睛，將纖細的手放在你的額頭，輕聲吟誦。"
  },
  {
   "hash": "9b81adecfc269ed5",
   "zh": "你感覺好多了。"
  },
  {
   "hash": "7c1665fbda22f5e1",
   "zh": "她湛藍的眼眸凝視著你。「還有什麼我能為你做的？」"
  },
  {
   "hash": "e8c1eb571ac0c7aa",
   "zh": "「開門的時候來我的店！」"
  },
  {
   "hash": "b07e6fc35b9c3d4c",
   "zh": "她舉起你的手抵在唇邊。「你沒有中毒。」"
  },
  {
   "hash": "4338c95520bfef63",
   "zh": "她逐一舉起各人的手抵在唇邊，說道：「你們沒有中毒。」"
  },
  {
   "hash": "7bf2e7fe4fc43e63",
   "zh": "「你們哪位？」"
  },
  {
   "hash": "709298e06ef78998",
   "zh": "「我感知到你中了毒，$Y。」"
  },
  {
   "hash": "44cf3e4e42ebfeea",
   "zh": "「你願意獻上5枚金幣嗎？」"
  },
  {
   "hash": "e103461f9917b2e8",
   "zh": "她將你的手放在她心口，闔上雙眼，低聲細語。"
  },
  {
   "hash": "56f778ec7b5340b9",
   "zh": "你額頭的燥熱消散了。"
  },
  {
   "hash": "523a55a503d306fa",
   "zh": "「沒有奉獻，我無法為你解毒。」"
  },
  {
   "hash": "56e1cbcac632f78a",
   "zh": "「抱歉。沒有奉獻，我無法為你解毒。」"
  },
  {
   "hash": "31c07221b38af431",
   "zh": "她眼眶泛淚。"
  },
  {
   "hash": "0cfaea3a35823668",
   "zh": "「我早該知道你不會開口，除非",
   "note": "下接句尾"
  },
  {
   "hash": "d22361cd10dbdc00",
   "zh": "你真的有迫切需要。」",
   "note": "原文有多餘的方括號"
  },
  {
   "hash": "fef99ca5c38568cf",
   "zh": "「來，把你的手放在我心口。」"
  },
  {
   "hash": "e103461f9917b2e8",
   "zh": "她將你的手放在她心口，闔上雙眼，低聲細語。"
  },
  {
   "hash": "56f778ec7b5340b9",
   "zh": "你額頭的燥熱消散了。"
  },
  {
   "hash": "b441ac0fb6cf6835",
   "zh": "「我感知到有人遭遇了可怕的命運。」"
  },
  {
   "hash": "e8c1eb571ac0c7aa",
   "zh": "「開門的時候來我的店！」"
  },
  {
   "hash": "c3d9c1684b40ad71",
   "zh": "「你願意獻上350枚金幣嗎？」"
  },
  {
   "hash": "9e5a6f5842ddd843",
   "zh": "「那我所能做的只有與你同悲。」"
  },
  {
   "hash": "4f0b6df707f944dd",
   "zh": "「你的金幣不夠。」"
  },
  {
   "hash": "b24063588a8232b7",
   "zh": "「抱歉，我所能做的只有與你同悲。」"
  },
  {
   "hash": "442e99118a9e0726",
   "zh": "你的隊伍為倒下的同伴湊齊了金幣。"
  },
  {
   "hash": "208d75e9138c298d",
   "zh": "$N將雙手覆於遺體之上……"
  },
  {
   "hash": "514009a24fcb86ac",
   "zh": "「多曼……」",
   "note": "復活咒語（音譯）"
  },
  {
   "hash": "f969324013f7d968",
   "zh": "「希克蘇斯……」",
   "note": "復活咒語（音譯）"
  },
  {
   "hash": "f9ef335076824b7b",
   "zh": "「安雷圖！」",
   "note": "復活咒語（音譯）"
  },
  {
   "hash": "5882524ad132e7e4",
   "zh": "死者重生！"
  },
  {
   "hash": "9fa9a58bc2170544",
   "zh": "「我感知到還有其他人也失去了……」"
  }
 ],
 "glossary_additions": {
  "people": {
   "Stephanie": "史黛芬妮"
  },
  "places": {}
 },
 "translator_notes": "史黛芬妮是盲人療癒師，法蘭的妹妹。她靠觸感和感知能力判斷傷患。復活咒語（Doman/thixus/anretu）以音譯保留。"
}
