  {
   "hash": "adea976f474ab972",
   "zh": "尤洛將眾人之金幣匯齊，交予閣下。",
   "note": "敘述句"
  },
  {
   "hash": "7f360c3cded0842c",
   "zh": "「咱們無人攜帶金幣，$G。」",
   "note": "保留 $G"
  },
  {
   "hash": "824a7843c6a2fad3",
   "zh": "尤洛湊了些金幣，交予閣下。",
   "note": "敘述句"
  },
  {
   "hash": "0d582d89ce86f3d6",
   "zh": "「來，此乃閣下當前所能攜帶之數。」"
  },
  {
   "hash": "85810d254e5e228e",
   "zh": "「在下看閣下已攜帶足矣。」"
  },
  {
   "hash": "ab18b48ae9786753",
   "zh": "「然吾等並無金幣，$G！」",
   "note": "保留 $G"
  },
  {
   "hash": "c51e2c25cf4ddfc7",
   "zh": "「咱們的金幣不足道哉，$G。」",
   "note": "保留 $G"
  },
  {
   "hash": "9b7017b34d1ccbb6",
   "zh": "尤洛將眾人之金幣匯齊，再均分予諸人。",
   "note": "敘述句"
  },
  {
   "hash": "7e6788fe88ae4ecf",
   "zh": "尤洛將金幣分予尚能攜帶之眾人。",
   "note": "敘述句"
  }
