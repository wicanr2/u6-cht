{
 "_meta": {},
 "translations": [
  {
   "hash": "71aaeb44380d44cb",
   "zh": "一位勤勞的年輕女子。",
   "note": "DESC"
  },
  {
   "hash": "00f85eb71710e565",
   "zh": "「哎，聖者，再次見到汝！」"
  },
  {
   "hash": "a03f812c43321748",
   "zh": "「這個美好的$T，吾能為汝做什麼？」"
  },
  {
   "hash": "fe502156cd3d12eb",
   "zh": "「吾是米雪兒。」"
  },
  {
   "hash": "022115ee5b4f01b2",
   "zh": "「汝無需告訴吾汝的名字，$P。聖者大名聞名天下！」"
  },
  {
   "hash": "cf8e10917ec89226",
   "zh": "「吾編織籃子和蜂箱，就像吾的@father（父親）和他父親一樣。」"
  },
  {
   "hash": "c5499fff253d950f",
   "zh": "「吾的@baskets（籃子）行銷整個不列顛尼亞！」她自豪地補充道。"
  },
  {
   "hash": "e8c1eb571ac0c7aa",
   "zh": "「吾開店時來光顧！」"
  },
  {
   "hash": "e8c1eb571ac0c7aa",
   "zh": "「吾開店時來光顧！」"
  },
  {
   "hash": "616bcfe3cf161ebd",
   "zh": "「吾所需的一切都已齊備，沒有理由再購買什麼了。」"
  },
  {
   "hash": "9f663273e6eb9a52",
   "zh": "「但吾感謝汝的提議。」"
  },
  {
   "hash": "e3b1c948a78485bb",
   "zh": "「父親曾告訴吾一個故事，說他曾編織過一個能容納八個人的大籃子！」",
   "note": "balloon basket hint"
  },
  {
   "hash": "db95b2f35bf8d584",
   "zh": "「但他從未讓吾看過@plans（設計）圖。」"
  },
  {
   "hash": "e740c941ed3f736d",
   "zh": "「吾開店時再問吾！」"
  },
  {
   "hash": "5773c126e5b4b838",
   "zh": "「是的，沒有精確的設計圖，製作一個籃子會耗費太多時間。」"
  },
  {
   "hash": "a1e7d9d644b85b1f",
   "zh": "「那是真的！父親確實編過那麼大的籃子！」"
  },
  {
   "hash": "cc42257e15582369",
   "zh": "「吾一定也能做到。」"
  },
  {
   "hash": "85188295b5d5bc15",
   "zh": "她仔細端詳設計圖片刻。",
   "note": "action"
  },
  {
   "hash": "fcd44bd48b3f51b9",
   "zh": "「珍重！吾希望吾幫到汝的任務了！」",
   "note": "bye"
  },
  {
   "hash": "57f6e4ebe2f3306a",
   "zh": "「請問汝說什麼？」"
  },
  {
   "hash": "63009f059f6a795f",
   "zh": "「汝想購買吾的一件編織品嗎？」"
  },
  {
   "hash": "e6bfbf391500cfd1",
   "zh": "「好吧，雖然吾已提供全境最優惠的價格了！」"
  },
  {
   "hash": "7bf2e7fe4fc43e63",
   "zh": "「汝等哪一位？」"
  },
  {
   "hash": "e323009185d6fbbb",
   "zh": "1) 籃子",
   "note": "menu item"
  },
  {
   "hash": "1d83bcf5d8536176",
   "zh": "2) 蜂箱",
   "note": "menu item"
  },
  {
   "hash": "635205d4f822a5e3",
   "zh": "3) 特製訂單",
   "note": "menu item; balloon basket"
  },
  {
   "hash": "62aaff84f5558c2c",
   "zh": "「哪件物品？」"
  },
  {
   "hash": "148b1abbab813805",
   "zh": "「吾恐怕行程已排滿。」",
   "note": "custom job without plans"
  },
  {
   "hash": "0346fe4398ce944c",
   "zh": "「吾沒有時間製作一個沒有@plans（設計）圖的籃子。」"
  },
  {
   "hash": "3367075cd3cb5000",
   "zh": "「$1 每個 #1 枚金幣。」"
  },
  {
   "hash": "52b8d8ca94a0670c",
   "zh": "「汝想要幾個？」"
  },
  {
   "hash": "bcaf35c487676fe1",
   "zh": "「汝拿不了那麼多！」"
  },
  {
   "hash": "c57a4a12d4d2a56a",
   "zh": "「吾只賣給汝 #5 個 $1。」"
  },
  {
   "hash": "734f28daae0cf716",
   "zh": "「但汝根本拿不了任何 $1！」"
  },
  {
   "hash": "c720114525a94908",
   "zh": "「汝的金幣不足以購買那麼多！」"
  },
  {
   "hash": "c57a4a12d4d2a56a",
   "zh": "「吾只賣給汝 #5 個 $1。」"
  },
  {
   "hash": "24e5f8c858cd4bcf",
   "zh": "「但汝連一個 $1 也買不起！」"
  },
  {
   "hash": "ad9accacf750ecd8",
   "zh": "米雪兒收下 $Y 的金幣，遞出 $1",
   "note": "partial"
  },
  {
   "hash": "1d511eff5ca8e4f3",
   "zh": "。「吾感謝汝的光顧。」",
   "note": "partial end"
  },
  {
   "hash": "28a96de771204974",
   "zh": "「還有其他汝想購買的嗎？」"
  },
  {
   "hash": "aca82add6e45274d",
   "zh": "「也許改天再說。」"
  },
  {
   "hash": "a7420041a90a3a62",
   "zh": "「好好使用汝的 $1",
   "note": "partial"
  },
  {
   "hash": "8172bb195c3735f2",
   "zh": "們。」",
   "note": "plural suffix"
  },
  {
   "hash": "07da0e07b4a02ac9",
   "zh": "。」",
   "note": "singular"
  },
  {
   "hash": "71ef5b6e26f7aed1",
   "zh": "「但那要重達六石！」",
   "note": "custom basket; too heavy"
  },
  {
   "hash": "05391995c986f91f",
   "zh": "「汝現在已負重累累，根本拿不動那樣的籃子。」"
  },
  {
   "hash": "3a93af4905a9f28c",
   "zh": "「先減輕行李，吾再為汝編織這個籃子。」"
  },
  {
   "hash": "5a715a6c653018ca",
   "zh": "「這樣的籃子需 300 枚金幣，須先付清。汝還有意購買嗎？」"
  },
  {
   "hash": "cfab3762ccf47f1d",
   "zh": "「吾不怪汝。這確實是個大工程！」"
  },
  {
   "hash": "506a265ae252c878",
   "zh": "「汝的金幣不夠購買這個籃子。」"
  },
  {
   "hash": "64ec39614259bbd4",
   "zh": "「吾恐怕無法僅憑 #2 枚金幣就開始這樣的工程。」"
  },
  {
   "hash": "1501b6f4ef68edcb",
   "zh": "汝的隊伍湊錢支付籃子的費用。",
   "note": "action"
  },
  {
   "hash": "19436fa8f38cc1b3",
   "zh": "她開始編織這個巨大的籃子，一邊工作一邊與汝閒聊。",
   "note": "action"
  },
  {
   "hash": "6e048dd237e4cd58",
   "zh": "「汝找到絲綢工匠了嗎？」",
   "note": "balloon bag hint"
  },
  {
   "hash": "603baac51f84ffe5",
   "zh": "「那汝真有遠見。這需要一個巨大的絲袋。」"
  },
  {
   "hash": "40fd538f82559ac0",
   "zh": "「嗯，吾看得出這需要一個巨大的絲袋。」"
  },
  {
   "hash": "69ffe0eb4978a650",
   "zh": "「吾不知道汝去哪裡找絲綢工匠來製作！」"
  },
  {
   "hash": "97e669907bbb221d",
   "zh": "她繼續編織籃子。",
   "note": "action"
  },
  {
   "hash": "d62d6880e866efaa",
   "zh": "「吾無意窺探，但汝究竟為何需要氣球？」"
  },
  {
   "hash": "3ad78cefd9684674",
   "zh": "「吾恐怕不明白。」"
  },
  {
   "hash": "b64a6609a61b82a2",
   "zh": "「哦，原來如此。」"
  },
  {
   "hash": "97e669907bbb221d",
   "zh": "她繼續編織籃子。",
   "note": "action"
  },
  {
   "hash": "fa8525f2126e6dcd",
   "zh": "時間流逝……",
   "note": "action"
  },
  {
   "hash": "5ee3750b44f311b4",
   "zh": "更多時間流逝……",
   "note": "action"
  },
  {
   "hash": "8ac866c246a0118c",
   "zh": "「完成了！」"
  },
  {
   "hash": "c0f3776cb857f378",
   "zh": "「比吾預想的花了更少時間！」"
  },
  {
   "hash": "3edb86e20a209c20",
   "zh": "她將籃子交給 $Y，$Y 在其重量下吃力不堪。",
   "note": "action"
  },
  {
   "hash": "d37c659ae0028e89",
   "zh": "「這些籃子既堅固又美觀。」*"
  },
  {
   "hash": "e33d50edfe9a7321",
   "zh": "「以這個價格，整個不列顛尼亞找不到更好的，僅需 #1 枚金幣。」"
  },
  {
   "hash": "f5a0918e74a4faef",
   "zh": "「若汝需要蜂箱，這些編織的是汝能找到的最好的！」*"
  },
  {
   "hash": "5b3525701d4a9253",
   "zh": "「而且價格低廉，每個僅 #1 枚金幣。」"
  }
 ],
