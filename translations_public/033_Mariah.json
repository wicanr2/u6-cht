{
 "_meta": {},
 "translations": [
  {
   "hash": "8b082fd94584c0d6",
   "zh": "!Mariah"
  },
  {
   "hash": "c18240763e106912",
   "zh": "雀斑佳人，笑靨迷人。"
  },
  {
   "hash": "fb5ba89f128cd2ec",
   "zh": "「$T安，$G，妾身有何可效勞？」"
  },
  {
   "hash": "c4bcadba8e631b86",
   "zh": "名字"
  },
  {
   "hash": "5732f72b02fb4701",
   "zh": "「人喚我瑪萊雅。」"
  },
  {
   "hash": "45627c193a5b605c",
   "zh": "業"
  },
  {
   "hash": "2d8ec8658895fa78",
   "zh": "「妾身乃@Council（法師）議會新進之員。總得有人讓事情運轉得順。」",
   "note": "[r2]"
  },
  {
   "hash": "248c02759ce66656",
   "zh": "「閒暇時，妾身於@library（藏書）閣鑽研己學。」",
   "note": "[r2]"
  },
  {
   "hash": "3159043e4fccee85",
   "zh": "議會,法師"
  },
  {
   "hash": "d5ec70b1f61fcab8",
   "zh": "「他們有時太過投入，連@sleep（眠食）皆忘！」"
  },
  {
   "hash": "6cd6b58f02e4242a",
   "zh": "食,眠"
  },
  {
   "hash": "466a60524ed0187e",
   "zh": "「此等小事於彼輩無足輕重。彼常超脫於@senses（感官）之外。」"
  },
  {
   "hash": "ba216691e5bcd6c6",
   "zh": "投入,超脫,境,感官"
  },
  {
   "hash": "7e99264595d47937",
   "zh": "「然也。」"
  },
  {
   "hash": "becf224a8102bc4c",
   "zh": "藏書,鑽研"
  },
  {
   "hash": "bf46c03a4194994f",
   "zh": "「此乃不列顛尼亞最佳之藏書閣。」"
  },
  {
   "hash": "1c38603e9ac2e22d",
   "zh": "「妾身涉獵諸學，唯覺研習古語最為趣味。」",
   "note": "[r2]"
  },
  {
   "hash": "c3b556329afc8376",
   "zh": "「由此可窺我等語言之源流！」"
  },
  {
   "hash": "cd2fcd9bc6b008d8",
   "zh": "書"
  },
  {
   "hash": "f43199dfd23b1435",
   "zh": "半,版,古,銀,譯"
  },
  {
   "hash": "68afcae43c10c46f",
   "zh": "「妾身這塊銀版乃在酒館中向幾名吉普賽人所得。」",
   "note": "[r2]"
  },
  {
   "hash": "48de58832dc98f25",
   "zh": "「或可問彼等另一塊在何處。」"
  },
  {
   "hash": "af8f7509cfda0b0b",
   "zh": "「將兩塊銀版皆帶來，妾身自當盡言相告。」",
   "note": "[r2]"
  },
  {
   "hash": "008a2f19137d94c3",
   "zh": "別"
  },
  {
   "hash": "f02572718eb6401f",
   "zh": "「珍重別矣。」"
  },
  {
   "hash": "1fa9890fbf035491",
   "zh": "「此事妾身無能為力。」",
   "note": "[r2]"
  },
  {
   "hash": "afd3a2678974fb04",
   "zh": "「妾身須兩塊銀版皆備，方能再告汝詳情。」",
   "note": "[r2]"
  },
  {
   "hash": "54efdd81a1f36f11",
   "zh": "「此塊銀版妾身已持有多時，能習者皆已盡學。」",
   "note": "[r2]"
  },
  {
   "hash": "6263917d4442a39f",
   "zh": "「啊，汝已尋得銀版餘塊！且自妾書房取另一塊一同攜來。」",
   "note": "[r2]"
  },
  {
   "hash": "78f0ef4f4a29b7b6",
   "zh": "「兩塊合一，妾身當能告汝更多。」",
   "note": "[r2]"
  },
  {
   "hash": "d83c714617241d55",
   "zh": "「尼斯托傳信於妾身，言汝持有一冊異語之書。」",
   "note": "[r2]"
  },
  {
   "hash": "b0e39394c0c47d58",
   "zh": "「妾身不介意為汝一看……」",
   "note": "[r2]"
  },
  {
   "hash": "751646f64fa40cc2",
   "zh": "「然若汝願將其攜來此處，事必更易！」"
  },
  {
   "hash": "ae261db0eb630b55",
   "zh": "「妾樂為汝一觀。」她端詳此書。"
  },
  {
   "hash": "ff1357b7093b45e2",
   "zh": "「噢！此種字體妾曾見過！」"
  },
  {
   "hash": "1f66f7584da1d823",
   "zh": "「妾身書房中藏有一塊古銀版之半，其上以我等之語與此字並書。」",
   "note": "[r2]"
  },
  {
   "hash": "2addfba3d787ec3e",
   "zh": "「妾身研之所得僅微，唯能辨少數字句。」",
   "note": "[r2]"
  },
  {
   "hash": "b6b72ef88b94d577",
   "zh": "「題曰『預言之書』，內中提及『吾界之終末』。」"
  },
  {
   "hash": "66e80c4f61e1f6b5",
   "zh": "「若妾身得另半塊@tablet（銀版），或可破譯此書其餘之文。」",
   "note": "[r2]"
  },
  {
   "hash": "aaf06435db40602a",
   "zh": "「兩塊銀版俱在，妾身當能譯出全文。」",
   "note": "[r2]"
  },
  {
   "hash": "7fcc59180b397613",
   "zh": "她細觀銀版良久，便自書中遲疑誦讀。"
  },
  {
   "hash": "7166ddace69ef1ce",
   "zh": "古之預言述及末日，言吾界終亡之時。"
  },
  {
   "hash": "53f37e42856d3b0b",
   "zh": "三兆將先於末日而現。"
  },
  {
   "hash": "27e891d5145d802b",
   "zh": "*大惡之徒將三度降臨吾境，由此可知末日已近。",
   "note": "[r2]"
  },
  {
   "hash": "845feb4427f48cf4",
   "zh": "此惡乃他族之徒，彼族奉此惡為大先知。"
  },
  {
   "hash": "cca217443f3b93f9",
   "zh": "然此偽先知未循克制、熱情與勤勉三原則。"
  },
  {
   "hash": "afb61276ad7ad552",
   "zh": "某日偽先知將至，污瀆吾族至聖之聖壇。"
  },
  {
   "hash": "c4f0c8001fd033db",
   "zh": "偽先知並將盜走吾族至聖之物，終極智慧守則之書。"
  },
  {
   "hash": "e965b9c28907bf89",
   "zh": "是為末日之首兆。",
   "note": "[r2]"
  },
  {
   "hash": "54aeb46143e7d663",
   "zh": "經文又載，偽先知將下入大地深淵。"
  },
  {
   "hash": "8787f87be9ed5a54",
   "zh": "偽先知將使幽冥界傾頹。",
   "note": "[r2]"
  },
  {
   "hash": "ac56a78955e9cee0",
   "zh": "由此巨震將裂吾界於兩半，瘟疫與飢荒亦將降臨。*"
  },
  {
   "hash": "15ae764d291f7d1d",
   "zh": "是為末日之第二兆。",
   "note": "[r2]"
  },
  {
   "hash": "1d6b11ef58e82148",
   "zh": "偽先知將再度降臨，此為最末一次。"
  },
  {
   "hash": "5e682d3f91ddf364",
   "zh": "此次偽先知將率一隊戰士同來。"
  },
  {
   "hash": "d2fc7622581c6d38",
   "zh": "彼等將盡滅魔像族之遺民。"
  },
  {
   "hash": "989b9b414adc3f18",
   "zh": "唯有一法可避此預言之應驗："
  },
  {
   "hash": "b8c28de3f5327fbc",
   "zh": "唯以偽先知為犧牲耳。",
   "note": "[r2]"
  },
  {
   "hash": "8089af1dc6e6b6b9",
   "zh": "瑪萊雅頓首良久，深陷沉思。"
  },
  {
   "hash": "4742469d5efc4c13",
   "zh": "「彼言『偽先知』，所指必為汝。」她說。"
  },
  {
   "hash": "b42bb4e8afba3cac",
   "zh": "「依彼族之見，似有理由視汝為惡。」"
  },
  {
   "hash": "7598b790b3917f4e",
   "zh": "「此事甚難了結。妾身以為汝宜再尋些訊息。」",
   "note": "[r2]"
  },
  {
   "hash": "d773cd82d8420eb6",
   "zh": "「沙漠之中有一魔像名喚辛弗拉，通曉我等之語。」"
  },
  {
   "hash": "f72b01b985b2a724",
   "zh": "「或可問他關於此書，及魔像族如何看待我等之事。」"
  },
  {
   "hash": "3c2879ca803992b7",
   "zh": "「歉令汝奔波，唯妾身僅得助通曉法術之人。」",
   "note": "[r2]"
  },
  {
   "hash": "2e55ee1b4429b2f2",
   "zh": "「故妾身須問汝一題以試之……」",
   "note": "[r2]"
  },
  {
   "hash": "d25f2e4e838044bf",
   "zh": "「魔法音節『Zu』為何意？」"
  },
  {
   "hash": "6a992118f71b2ae8",
   "zh": "眠"
  },
  {
   "hash": "008a2f19137d94c3",
   "zh": "別"
  },
  {
   "hash": "96a8befa091bb20b",
   "zh": "「非也，並非如此。汝可有典籍以資查照？」*"
  },
  {
   "hash": "11a12d1813a11a90",
   "zh": "「魔法音節『Quas』為何意？」"
  },
  {
   "hash": "e3b06cc5703555ab",
   "zh": "幻"
  },
  {
   "hash": "008a2f19137d94c3",
   "zh": "別"
  },
  {
   "hash": "96a8befa091bb20b",
   "zh": "「非也，並非如此。汝可有典籍以資查照？」*"
  },
  {
   "hash": "c78fada8bd5543fb",
   "zh": "「魔法音節『Hur』為何意？」"
  },
  {
   "hash": "a6200ef65560e507",
   "zh": "風"
  },
  {
   "hash": "008a2f19137d94c3",
   "zh": "別"
  },
  {
   "hash": "96a8befa091bb20b",
   "zh": "「非也，並非如此。汝可有典籍以資查照？」*"
  },
  {
   "hash": "12a9c29b8d725447",
   "zh": "「魔法音節『Jux』為何意？」"
  },
  {
   "hash": "5a0141dba81f7664",
   "zh": "危,陷阱,傷"
  },
  {
   "hash": "008a2f19137d94c3",
   "zh": "別"
  },
  {
   "hash": "96a8befa091bb20b",
   "zh": "「非也，並非如此。汝可有典籍以資查照？」*"
  },
  {
   "hash": "2e7a843f34c40087",
   "zh": "「魔法音節『Ort』為何意？」"
  },
  {
   "hash": "1f7b65a2ceb4ef47",
   "zh": "法力"
  },
  {
   "hash": "008a2f19137d94c3",
   "zh": "別"
  },
  {
   "hash": "96a8befa091bb20b",
   "zh": "「非也，並非如此。汝可有典籍以資查照？」*"
  },
  {
   "hash": "ee26d02bb853b3a4",
   "zh": "「所言不差！且問汝有何見教？」",
   "note": "[r2]"
  },
  {
   "hash": "e0550efc70e3848d",
   "zh": "「妾身建議汝先尋典籍研讀，再來相談。」",
   "note": "[r2]"
  }
 ],
 "glossary_additions": {
