 "_meta": {},
 "translations": [
  {
   "hash": "43305ae14d62526f",
   "zh": "榮耀祭壇",
   "note": "NPC name — 神殿祭壇"
  },
  {
   "hash": "cc054101ebb629dd",
   "zh": "榮耀之祭壇。",
   "note": "DESC"
  },
  {
   "hash": "4dea77d1e904b054",
   "zh": "當你跪在祭壇前，一個神秘的聲音在你腦中迴響。",
   "note": "旁白"
  },
  {
   "hash": "9ca405424074886e",
   "zh": "「汝對榮耀仍有許多須學習之處。」",
   "note": "低階評語"
  },
  {
   "hash": "e9f91fd6dbf62ba9",
   "zh": "「汝之行為展現了令人欽佩的榮耀。」",
   "note": "中階評語"
  },
  {
   "hash": "52b84eff61efe845",
   "zh": "「汝之行為可為眾人表率。」",
   "note": "高階評語"
  },
  {
   "hash": "bf3b28dcc608d94c",
   "zh": "你希望在此祭壇冥想嗎？",
   "note": "旁白提示，尾隨空格保留"
  },
  {
   "hash": "50e77701c0136675",
   "zh": "#2。$Y",
   "note": "控制符保留"
  },
  {
   "hash": "4f97e949580d4b79",
   "zh": "「誰來冥想？」",
   "note": "尾隨空格保留"
  },
  {
   "hash": "5a46f4b80d7f7d98",
   "zh": "「覆誦榮耀真言。」"
  },
  {
   "hash": "ffe5b426e8468f7f",
   "zh": "「$Z…… $Z……」",
   "note": "真言提示第一次"
  },
  {
   "hash": "ffe5b426e8468f7f",
   "zh": "「$Z…… $Z……」",
   "note": "真言提示第二次"
  },
  {
   "hash": "ffe5b426e8468f7f",
   "zh": "「$Z…… $Z……」",
   "note": "真言提示第三次"
  },
  {
   "hash": "af229a41a3803fba",
   "zh": "「榮耀可受攻擊，但永不受傷。」",
   "note": "聖言（約翰·彌爾頓《失樂園》典故）"
  },
  {
   "hash": "9949eaad9b545c9e",
   "zh": "「為不義之力所突襲，卻不受其奴役。」",
   "note": "聖言（同上）"
  },
  {
   "hash": "9d3c825b4abf0064",
   "zh": "你未能獲得啟示。",
   "note": "旁白"
  },
  {
   "hash": "64268b11d0648045",
   "zh": "$Y提升了一個等級……",
   "note": "升級旁白"
  },
  {
   "hash": "c615cd151c9cf910",
   "zh": "智力……",
   "note": "能力提升（榮耀→智力+力量，第一項）"
  },
  {
   "hash": "0c701c5c793f8816",
   "zh": "以及力量！",
   "note": "能力提升第二項"
  },
  {
   "hash": "cb93cedb92f1135f",
   "zh": "「此刻此地，汝已無更多可學。」"
  },
  {
   "hash": "36b180a0ddf1311a",
   "zh": "「待汝的旅程更進一步，再行回返。」"
  }
 ],
 "glossary_additions": {
  "people": {},
  "places": {}
 },
 "translator_notes": "榮耀神殿，真言 summ（不翻譯）。冥想獲得智力+力量提升。聖言引自約翰·彌爾頓《失樂園》，榮耀不可被奴役的主題。"
}
