 "_meta": {},
 "translations": [
  {
   "hash": "e6e3fb58f0b51724",
   "zh": "身穿白袍、蓄著鬍鬚的黝黑男子。",
   "note": "DESC"
  },
  {
   "hash": "be0fadd06ada385a",
   "zh": "「問候，偉大的聖者。汝前來敝處，所為何事？」"
  },
  {
   "hash": "25cdf10b20b62468",
   "zh": "「吾乃魯迪奧姆。」"
  },
  {
   "hash": "8c57878f7342e4e0",
   "zh": "「吾販售魔法@books（書卷）及@reagents（施法）材料，並傳授@spells（法術）。」"
  },
  {
   "hash": "1ddaa125cf07275c",
   "zh": "「願平安伴隨汝，聖者。」"
  },
  {
   "hash": "343196a97b04a844",
   "zh": "「此事吾無可奉告。」"
  },
  {
   "hash": "65f0b66c719161f3",
   "zh": "「店鋪目前關閉。」"
  },
  {
   "hash": "31e8c720e45ef68a",
   "zh": "「但汝尚無法術@book（書卷）！」"
  },
  {
   "hash": "5c7edb8ee62e1f01",
   "zh": "「但你們沒有一人持有法術@book（書卷）！」"
  },
  {
   "hash": "7bf2e7fe4fc43e63",
   "zh": "「你們哪位？」"
  },
  {
   "hash": "5d46e73c04015d0f",
   "zh": "「$Y希望習學第幾階法術？」"
  },
  {
   "hash": "7fb5194af92d0a52",
   "zh": "「眾所周知，法術共有八階。」"
  },
  {
   "hash": "221ceb71ef20b21e",
   "zh": "「吾感知到$Y目前只宜修習第#1$1階。」"
  },
  {
   "hash": "39441f98e0f898fc",
   "zh": "「但此類事吾不置喙……」"
  },
  {
   "hash": "09c3489e7eba1c4e",
   "zh": "「吾無此階法術。」"
  },
  {
   "hash": "ad382ddf6d73ea3f",
   "zh": "「要哪一項？」"
  },
  {
   "hash": "c2a585f7f938b436",
   "zh": "「或許$Y尚未準備好修習此階。」"
  },
  {
   "hash": "38e28c553924d7fa",
   "zh": "「$Y金幣不足，需#5枚。」"
  },
  {
   "hash": "681bf837d48f48da",
   "zh": "「此法術需#5枚金幣。有意嗎？」"
  },
  {
   "hash": "a22a19da93a5eead",
   "zh": "$N遞給$Y一張佈滿符文的羊皮紙。"
  },
  {
   "hash": "1a5c50992da77078",
   "zh": "「$1每份#1枚金幣。」"
  },
  {
   "hash": "f8d92c716eb3e363",
   "zh": "「汝要幾份？」"
  },
  {
   "hash": "835d6182d3504dca",
   "zh": "「汝帶不了那麼多！」"
  },
  {
   "hash": "728518924ad41fa1",
   "zh": "「吾給汝#5份；其餘的汝不需要。」"
  },
  {
   "hash": "e851a65453925a3f",
   "zh": "「汝帶不了任何$1！」"
  },
  {
   "hash": "341685f0f18f3b53",
   "zh": "「汝負擔不起那麼多！」"
  },
  {
   "hash": "d3312e8b052e147b",
   "zh": "「吾給汝#5份；其餘的汝買不起。」"
  },
  {
   "hash": "1478913253368c2c",
   "zh": "「汝買不起任何$1！」"
  },
  {
   "hash": "69e5b03b303e477b",
   "zh": "「但汝帶不了法術書卷！」"
  },
  {
   "hash": "8a1ddb63dfc8ec48",
   "zh": "「但汝買不起法術書卷！」"
  },
  {
   "hash": "9237571e621cc401",
   "zh": "「法術書卷需50枚金幣。有意嗎？」"
  },
  {
   "hash": "cad0cd6e28573484",
   "zh": "「也許汝的同伴中有人感興趣。」"
  }
 ],
 "glossary_additions": {
  "people": {
   "Rudyom": "魯迪奧姆"
  },
  "places": {}
 },
 "translator_notes": "Rudyom 魔法商人，說話用 thou/thee 古體。商品名（Blood Moss、Garlic 等施法材料；Create Food 等法術名）為系統字串不在對話流程，略。"
}
