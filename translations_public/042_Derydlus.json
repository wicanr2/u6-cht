 "_meta": {},
 "translations": [
  {
   "hash": "13ac02c44042675b",
   "zh": "一位看起來自得其樂之男子——究竟是對周遭感到有趣，還是對自己感到有趣，實難分辨。",
   "note": "DESC"
  },
  {
   "hash": "36b158913c525950",
   "zh": "「啊，歡迎，$G！來和吾@drink（喝一）杯！」"
  },
  {
   "hash": "a634923db43ee581",
   "zh": "「汝可曾算過命？」"
  },
  {
   "hash": "13dce783b3d34b06",
   "zh": "「有些人以為@Penumbra（潘布）拉是個騙子。但她確有真本事。汝應耐心配合她——她確實能給汝莫大的幫助。」"
  },
  {
   "hash": "80d0413e6c482a64",
   "zh": "「德里德拉斯。汝的名字又是什麼來著？」"
  },
  {
   "hash": "954452056ce0f527",
   "zh": "「哦，是的，當然。來，請坐。」"
  },
  {
   "hash": "d66b63f4e2a2cdc5",
   "zh": "「鑽研弗雷澤之@Folly（愚醇）的所有微妙之處，幾乎本身就是一份職業！」"
  },
  {
   "hash": "a806a6f1e2ee8cbb",
   "zh": "他微笑道。",
   "note": "action"
  },
  {
   "hash": "b31a3302522a6838",
   "zh": "「是的，此乃弗雷澤之@Folly（愚醇）的發源地！」"
  },
  {
   "hash": "b7971bb15c02abb2",
   "zh": "「縱觀不列顛尼亞諸城，無處能找到更佳的釀造。」"
  },
  {
   "hash": "7f8936fd57536ca0",
   "zh": "「敬曼陀羅根！」",
   "note": "Mandrake is reagent/ingredient toast"
  },
  {
   "hash": "f9ea2bd241c0d66f",
   "zh": "「吾的飲酒伙伴！無論他身在何處，讓吾等舉杯致敬。」",
   "note": "Manrel reference"
  },
  {
   "hash": "f0c7f5d421f663da",
   "zh": "「為此乾杯！」"
  },
  {
   "hash": "b69b9f5bbfd43dbc",
   "zh": "「她確是怪人，但她有天賦。」",
   "note": "Penumbra"
  },
  {
   "hash": "612bd3b191fcd857",
   "zh": "「這就要走？汝連走路都還沒搖搖晃晃呢……」",
   "note": "bye"
  },
  {
   "hash": "63a24f15fcae9c9b",
   "zh": "「為此乾杯，」他說道，言出必行地舉杯飲下。",
   "note": "action"
  },
  {
   "hash": "87b0613b966c4f8b",
   "zh": "「`$Z？哈，確實！敬 $Z！」",
   "note": "backtick and $Z preserved"
  }
 ],
 "glossary_additions": {
  "people": {
   "Derydlus": "德里德拉斯"
  },
  "places": {},
  "concepts": {}
 },
 "translator_notes": "德里德拉斯是個終日在酒館喝酒的快活人，語氣隨性、詼諧。萬事皆可舉杯相慶。$Z 是玩家輸入的詞，保留不譯。"
}
