{
 "_meta": {},
 "translations": [
  {
   "hash": "a5e987c017c43920",
   "zh": "科蘭納達"
  },
  {
   "hash": "025cca90d9a94286",
   "zh": "一位舉止莊重之男子，身著繡有蛇紋之寬袍。"
  },
  {
   "hash": "6604d36832c5f6d5",
   "zh": "「$P，再見汝甚悅。」"
  },
  {
   "hash": "424a452e27687525",
   "zh": "「汝好，冒險者"
  },
  {
   "hash": "07c28407b48c616a",
   "zh": "！」"
  },
  {
   "hash": "8326825c6cdb6f96",
   "zh": "「在下為公會首座，謹以銀蛇騎士團之名歡迎汝。」"
  },
  {
   "hash": "d79f184bb044b728",
   "zh": "「汝何名？」"
  },
  {
   "hash": "e5ff8ed121e62258",
   "zh": "「幸會，$G 聖者！」"
  },
  {
   "hash": "18fbbe90bc6fa470",
   "zh": "「在下科蘭納達，庫雷布拉之子。」"
  },
  {
   "hash": "38b3f2706c917ee7",
   "zh": "「家父乃勇敢之@燈塔守。」"
  },
  {
   "hash": "e7b0e0cda992cc51",
   "zh": "「地震毀了燈塔，否則我本可承繼灰港之守塔之職。」"
  },
  {
   "hash": "e2a4669e854911da",
   "zh": "「故改往蛇要塞，加入@騎士團。」"
  },
  {
   "hash": "10c4d1c3536c62f6",
   "zh": "「我等以@勇氣為宗。」"
  },
  {
   "hash": "ad9ed691b54f7dcf",
   "zh": "「聖者大駕加盟，乃我等之榮幸！」"
  },
  {
   "hash": "85abf3ad859e1ae2",
   "zh": "「取得銀蛇@盾，便可入團，$G $P。」"
  },
  {
   "hash": "af999a5ed709db57",
   "zh": "「汝可願加入銀蛇騎士團？」"
  },
  {
   "hash": "dc70af94882d32f6",
   "zh": "「可往訪德修，聽其論勇之要義。」"
  },
  {
   "hash": "0e4e4cf7a55eb94f",
   "zh": "「他雖戰技卓越，然尚未證明自己堪入我@團。」"
  },
  {
   "hash": "085f889bc4448901",
   "zh": "「我團之蛇盾，乃勇者兄弟會之神聖象徵。」"
  },
  {
   "hash": "de19a63e542c127a",
   "zh": "「持之以榮！」"
  },
  {
   "hash": "726a5bf18c1d8b0c",
   "zh": "「鑄之乃一道魔法@工序。」"
  },
  {
   "hash": "0282124f2e3d4504",
   "zh": "「鐵匠@格里克可助汝鑄一面。」"
  },
  {
   "hash": "04379d288cf7f426",
   "zh": "「此事亦為秘傳。」"
  },
  {
   "hash": "2242585f9eacfc16",
   "zh": "「汝多半可在『攻城匠坊』尋得其人。」"
  },
  {
   "hash": "9977ea88ab3a2116",
   "zh": "「我在此身負職責"
  },
  {
   "hash": "ae4a9b3b71c7d199",
   "zh": "，$G。然蒙汝相邀，深感榮幸。」"
  },
  {
   "hash": "8d528993918bbb83",
   "zh": "。然而……」"
  },
  {
   "hash": "af999a5ed709db57",
   "zh": "「汝可願加入銀蛇騎士團？」"
  },
  {
   "hash": "d5f07e25b66e2660",
   "zh": "「若不明其意，此符號不過無謂之刻痕。」"
  },
  {
   "hash": "91b37925c6f778da",
   "zh": "「我等於此@冥思勇之德。」"
  },
  {
   "hash": "fa1d7f20c3b53f9b",
   "zh": "「真言乃一概念，一特殊之語，於心中反覆推敲。」"
  },
  {
   "hash": "5a1e697dd07a337c",
   "zh": "「冥思真言之目的，乃為尋彼德之@真意。」"
  },
  {
   "hash": "e19f587fbc889723",
   "zh": "「知真言、執符文，未為足也。」"
  },
  {
   "hash": "b012eec8cc7c566a",
   "zh": "「欲@有德，必當踐德。」"
  },
  {
   "hash": "f85480a1d583dafc",
   "zh": "「諸德之中，二德有時亦相衝，雖皆列於聖者八德之中。」"
  },
  {
   "hash": "dbdd4e34e466f241",
   "zh": "「英雄行事，當有此衝突之自覺，而非僅憑本能。」"
  },
  {
   "hash": "f3e3054f9af0194f",
   "zh": "「此乃吾師@康諾爾所教。」"
  },
  {
   "hash": "44238852cc132bd2",
   "zh": "「至交也。我修業之時，他正為此處之首座。」"
  },
  {
   "hash": "55d168e3591169d4",
   "zh": "「他如今隱居於新馬精西亞。」"
  },
  {
   "hash": "f02572718eb6401f",
   "zh": "「祝汝一路順遂。」"
  },
  {
   "hash": "f0e4fb1bc08a48cf",
   "zh": "「此事我幫不上汝。」"
  },
  {
   "hash": "c8fb32258a3b05d5",
   "zh": "「此處永為汝預留一席，$G。」"
  },
  {
   "hash": "0c659686048393fc",
   "zh": "「聖者若願加盟，乃我等莫大之榮。」"
  },
  {
   "hash": "7003566ddda3c282",
   "zh": "「$P，汝之行止已為汝立言。」"
  },
  {
   "hash": "cf43d4c2e90620f1",
   "zh": "「鑒於汝歷險之績已足證汝之勇，例行條件得免。」"
  },
  {
   "hash": "15e12722784a0ed7",
   "zh": "「然汝仍須親手鑄就自己之盾。」"
  }
 ],
