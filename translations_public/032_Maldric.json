{
 "_meta": {
  "npc": "Maldric (cook)",
  "role": "不列顛城堡廚師；前野豬獵人，因獻烤豬肉得 Lord British 賞識而為宮廷掌廚。光膀肌肉男、汗濕生光。對聖者一見傾心（依玩家性別 $G 顯示不同台詞），含浪漫求愛意味、提及『火爐邊共度良夜』等。"
 },
 "translations": [
  {
   "hash": "8def426a3d0fd97d",
   "zh": " 馬德力",
   "note": "人名音譯；前置空格保留"
  },
  {
   "hash": "c71187e22d7eada6",
   "zh": "一個赤膊肌肉男，汗水使其身軀閃閃發光。*",
   "note": "末尾 * 保留"
  },
  {
   "hash": "a253473e790cbf58",
   "zh": "「失陪片刻。」他自腰帶抽出一條布巾擦汗。「來，方才汝說什麼？」"
  },
  {
   "hash": "d9e4769b2f94ee72",
   "zh": "「且慢，」他打斷道，「我認得汝…汝乃聖者！我一直渴望相見。」"
  },
  {
   "hash": "6efaa3543d6779fc",
   "zh": "自初見汝之畫像，我便知汝必為不列顛尼亞最美之女子。」",
   "note": "對女性聖者；Britannia → 不列顛尼亞"
  },
  {
   "hash": "e23a0cee48290d16",
   "zh": "汝乃全境最偉大之英雄。」",
   "note": "對男性聖者"
  },
  {
   "hash": "e3286089ec37effa",
   "zh": "「噢，$G聖者，再見汝實乃意外之喜！」",
   "note": "保留 $G 性別變數"
  },
  {
   "hash": "2906d50b792835bb",
   "zh": "「嘿，老友 $P！再見汝甚悅。」",
   "note": "保留 $P"
  },
  {
   "hash": "c4bcadba8e631b86",
   "zh": "名字",
   "note": "@name keyword"
  },
  {
   "hash": "779b453fb3d734ef",
   "zh": "「在下馬德力。@昔為野豬獵人，今為廚子也。」"
  },
  {
   "hash": "7342d211ca2b3b5d",
   "zh": "昔,豬,獵",
   "note": "keyword 群組"
  },
  {
   "hash": "74d913250fd15313",
   "zh": "「啊，吾曾居於@林中，獵殺野豬。」"
  },
  {
   "hash": "6bed7f924cd59138",
   "zh": "「某日獻@烤豬於@陛下，他甚喜，遂聘吾為其@御廚。」"
  },
  {
   "hash": "1f563da2ce958f12",
   "zh": "陛下",
   "note": "@majesty keyword"
  },
  {
   "hash": "00165281291986da",
   "zh": "「是的，便是@不列顛王本人。」"
  },
  {
   "hash": "dd1d07790c2f0e4f",
   "zh": "林",
   "note": "@forest keyword"
  },
  {
   "hash": "2543d48178136c80",
   "zh": "「彼時美好。然此處亦堪稱樂土。」"
  },
  {
   "hash": "22e8b58fc3f29339",
   "zh": "獻,贈,烤,喜",
   "note": "keyword 群組"
  },
  {
   "hash": "8ff4fa26b930fbea",
   "zh": "「秘訣在於香料。乃我家傳老@祕方也。」"
  },
  {
   "hash": "87e5fda7ba85de28",
   "zh": "祕,家,方",
   "note": "keyword 群組"
  },
  {
   "hash": "15d3ed26cc76de5c",
   "zh": "「絕不外傳。",
   "note": "句首待接續"
  },
  {
   "hash": "20eadc3a8e740342",
   "zh": " 然對如此甜美之人，吾不免心動。"
  },
  {
   "hash": "45627c193a5b605c",
   "zh": "業",
   "note": "@job keyword"
  },
  {
   "hash": "4bda87dc4774a182",
   "zh": "「吾為@城堡中所有居者掌@廚，亦為與不列顛王共@膳之@賓客做菜。」",
   "note": "避『餐』改『膳』"
  },
  {
   "hash": "302f6a5903773b9e",
   "zh": "「此業甚足吾意，然偶望能與汝這般之人共@遊…」"
  },
  {
   "hash": "58c1f62530861039",
   "zh": "賓,膳",
   "note": "keyword 群組；避『餐』改『膳』"
  },
  {
   "hash": "9c9f92bea415d719",
   "zh": "「不列顛王朋友眾多。」"
  },
  {
   "hash": "b55e7090e879494e",
   "zh": "城堡",
   "note": "@castle keyword"
  },
  {
   "hash": "854c2f07f90c9167",
   "zh": "「比吾家祖輩所居皆豪奢之屋。然吾仍懷念林中那簡樸小屋。」"
  },
  {
   "hash": "016ae2ea475205b4",
   "zh": "「願它尚存，吾便可邀汝來@爐火邊共度一宵…",
   "note": "fireplace → 爐火；無結尾引號保留"
  },
  {
   "hash": "18d311b62d434179",
   "zh": "度,宵,爐,邀",
   "note": "keyword 群組"
  },
  {
   "hash": "845b63583e314d38",
   "zh": "「廚中之火足矣，惟非適浪漫之所。」"
  },
  {
   "hash": "d0614aff9e5fbf31",
   "zh": "廚,所,浪,遊,願,從,武",
   "note": "7 keyword 群組"
  },
  {
   "hash": "4b12f483c8a85fc7",
   "zh": "「此等事吾本不該妄言。」"
  },
  {
   "hash": "1b163d37076525b0",
   "zh": "「畢竟汝乃聖者，吾不過卑微廚子。望汝寬恕。」"
  },
  {
   "hash": "7d560e159b945c3b",
   "zh": "不列顛王",
   "note": "keyword 群組"
  },
  {
   "hash": "ba460eb9ae73ace5",
   "zh": "「他是個好人。喜在@燉湯中多放@胡椒。」"
  },
  {
   "hash": "3a5c0548290cf461",
   "zh": "椒,燉",
   "note": "keyword 群組"
  },
  {
   "hash": "b769d5117afa6241",
   "zh": "「香料為生活添點變化，此乃吾常言。」"
  },
  {
   "hash": "8b99ab19095527ea",
   "zh": "香料",
   "note": "@spice keyword"
  },
  {
   "hash": "7236dd8bbdb31c3c",
   "zh": "「汝自個兒也是個夠味之小尤物呢！」"
  },
  {
   "hash": "3982564b9728d7e1",
   "zh": "料,變,生,友,聞,險,人,樂",
   "note": "8 keyword 群組"
  },
  {
   "hash": "fc58ac2c9d2a0401",
   "zh": "「確乎。」",
   "note": "縮譯以符 len=13"
  },
  {
   "hash": "64e9978429a57cab",
   "zh": "聖者",
   "note": "@avatar keyword"
  },
  {
   "hash": "8b8ad6dbbca1fb26",
   "zh": "「汝之冒險吾皆有所聞。多願吾亦能為武士，而非僅一廚子！」"
  },
  {
   "hash": "0bc60d911959a649",
   "zh": "廚子",
   "note": "@cook keyword"
  },
  {
   "hash": "0dae468c5d1f3059",
   "zh": "「吾喜此業：能令人歡喜。」"
  },
  {
   "hash": "008a2f19137d94c3",
   "zh": "別",
   "note": "@bye keyword"
  },
  {
   "hash": "16b600c5059ccfcc",
   "zh": "「後會。下回汝與陛下同膳時，吾必為汝烹一道特別之菜。」"
  },
  {
   "hash": "748f8302938dcf9f",
   "zh": "他似欲再言，眼中懷著期盼之色。"
  },
  {
   "hash": "56d683cd99e8522c",
   "zh": "但隨即默然轉身而去。"
  },
  {
   "hash": "0fb4380ded018c84",
   "zh": "「妙哉汝提起此事…令吾憶起@烤豬之祕方。」"
  }
 ],
