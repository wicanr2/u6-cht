 "translations": [
  {
   "hash": "8c4edc7cd1ae285a",
   "zh": "靈性祭壇",
   "note": "NPC name — 神殿祭壇"
  },
  {
   "hash": "52175e8135e265f2",
   "zh": "靈性之祭壇。",
   "note": "DESC"
  },
  {
   "hash": "4dea77d1e904b054",
   "zh": "當你跪在祭壇前，一個神秘的聲音在你腦中迴響。",
   "note": "旁白"
  },
  {
   "hash": "891f5cccc6c4743d",
   "zh": "「汝對靈性仍有許多須學習之處。」",
   "note": "低階評語"
  },
  {
   "hash": "7d954af690d9337c",
   "zh": "「汝之行為展現了令人欽佩的靈性。」",
   "note": "中階評語"
  },
  {
   "hash": "52b84eff61efe845",
   "zh": "「汝之行為可為眾人表率。」",
   "note": "高階評語"
  },
  {
   "hash": "bf3b28dcc608d94c",
   "zh": "你希望在此祭壇冥想嗎？",
   "note": "旁白提示，尾隨空格保留"
  },
  {
   "hash": "50e77701c0136675",
   "zh": "#2。$Y",
   "note": "控制符保留"
  },
  {
   "hash": "4f97e949580d4b79",
   "zh": "「誰來冥想？」",
   "note": "尾隨空格保留"
  },
  {
   "hash": "1fdac90080f404b3",
   "zh": "「覆誦靈性真言。」"
  },
  {
   "hash": "ffe5b426e8468f7f",
   "zh": "「$Z…… $Z……」",
   "note": "真言提示第一次"
  },
  {
   "hash": "ffe5b426e8468f7f",
   "zh": "「$Z…… $Z……」",
   "note": "真言提示第二次"
  },
  {
   "hash": "ffe5b426e8468f7f",
   "zh": "「$Z…… $Z……」",
   "note": "真言提示第三次"
  },
  {
   "hash": "bf4b3bf7a567e46f",
   "zh": "「縱貫這多變而永恆的世界，靈魂是唯一的元素。」",
   "note": "聖言"
  },
  {
   "hash": "26b8cd59a0b56a28",
   "zh": "「靈魂的財富，是唯一真實的財富。」",
   "note": "聖言"
  },
  {
   "hash": "9d3c825b4abf0064",
   "zh": "你未能獲得啟示。",
   "note": "旁白"
  },
  {
   "hash": "64268b11d0648045",
   "zh": "$Y提升了一個等級……",
   "note": "升級旁白"
  },
  {
   "hash": "c615cd151c9cf910",
   "zh": "智力……",
   "note": "能力提升（靈性→智力+力量+敏捷，第一項）"
  },
  {
   "hash": "6939191c0a6360b6",
   "zh": "力量……",
   "note": "能力提升第二項"
  },
  {
   "hash": "ab95c009eca1d469",
   "zh": "以及敏捷！",
   "note": "能力提升第三項"
  },
  {
   "hash": "cb93cedb92f1135f",
   "zh": "「此刻此地，汝已無更多可學。」"
  },
  {
   "hash": "36b180a0ddf1311a",
   "zh": "「待汝的旅程更進一步，再行回返。」"
  }
 ],
 "glossary_additions": {
