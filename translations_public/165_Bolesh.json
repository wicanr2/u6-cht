 "_meta": {},
 "translations": [
  {
   "hash": "329db19bcb773f12",
   "zh": "波列許",
   "note": "NPC name — 魔像隊長"
  },
  {
   "hash": "29b9b5c97f1f5ef4",
   "zh": "強健之有翼魔像武士，身負重傷。",
   "note": "DESC"
  },
  {
   "hash": "175992e4bff231ec",
   "zh": "魔像費力地想坐起身。",
   "note": "旁白"
  },
  {
   "hash": "3e0162084c638081",
   "zh": "他嘶喊：「An-bal-sil-fer！Agra-lem！Agra-lem！」",
   "note": "魔像語原文保留，此為純粹魔像語叫喊"
  },
  {
   "hash": "f4aad88ef8cdd1d3",
   "zh": "魔像精疲力竭，再度倒下。",
   "note": "旁白"
  },
  {
   "hash": "175992e4bff231ec",
   "zh": "魔像費力地想坐起身。",
   "note": "旁白（重複）"
  },
  {
   "hash": "1d1ed0ef0762babf",
   "zh": "他嘶喊：「偽先知！護衛！護衛！」"
  },
  {
   "hash": "f2b5fa5dfc2b285b",
   "zh": "魔像雖憤怒不已，仍精疲力竭倒下。",
   "note": "旁白"
  },
  {
   "hash": "175992e4bff231ec",
   "zh": "魔像費力地想坐起身。",
   "note": "旁白（重複）"
  },
  {
   "hash": "45c1dad0d2064ee6",
   "zh": "「偽先知！」"
  },
  {
   "hash": "ff8356d5a966b091",
   "zh": "「然已佩戴臣服護符？」",
   "note": "魔像文言語法"
  },
  {
   "hash": "10278c77361287f5",
   "zh": "「則對汝之榮譽與勇氣，深感敬畏。」"
  },
  {
   "hash": "ae25c2aa35cf5b9c",
   "zh": "「再度問候，尊者。」"
  },
  {
   "hash": "6f5d253b2948da5a",
   "zh": "「吾名波列許·烏斯-阿格拉-蘭，即隊伍@Leader統帥波列許。」"
  },
  {
   "hash": "385738eb9c3c8248",
   "zh": "「率吾族殘部繼續征戰。」"
  },
  {
   "hash": "1ce91d5bd290edd1",
   "zh": "「近日已自汝等人類一方之世界完成任務歸返。」"
  },
  {
   "hash": "5e28f2d26632bcde",
   "zh": "「曾試圖抵達@Codex守則之書。」"
  },
  {
   "hash": "e25281e2edebe626",
   "zh": "「勝利已在爪間，卻在成功邊緣遭人阻攔！」"
  },
  {
   "hash": "1aad79430a3f9092",
   "zh": "「遭遇守則之書四周難以穿透之@force能量場。」"
  },
  {
   "hash": "de7476ef938de3aa",
   "zh": "「知曉吾族持有守則之書時，此類能量場亦曾環繞其外。」"
  },
  {
   "hash": "f5a6008a9dce5993",
   "zh": "「記得唯有進行神聖@quests智慧試煉者方能通過。」"
  },
  {
   "hash": "7fb1e3cd4341ad77",
   "zh": "「須於@Temple獨一神殿接受神聖試煉。」"
  },
  {
   "hash": "1a789a48d3605d1a",
   "zh": "「然不確定神殿是否接納人類之請求。」"
  },
  {
   "hash": "5bbfe6d3a4dfca88",
   "zh": "「神殿位於北方山中。」"
  },
  {
   "hash": "0aaa2d882fc2dd53",
   "zh": "「然須展翅飛翔方可抵達！」"
  },
  {
   "hash": "57f43f39d1dec292",
   "zh": "「是，唯有高等有翼魔像方可進入。」"
  },
  {
   "hash": "98587be9d56e0963",
   "zh": "「地行的工匠魔像根本無法到達！」"
  },
  {
   "hash": "21168ef04e65f7e1",
   "zh": "「吾料陸行之人類亦同樣無法抵達。」"
  },
  {
   "hash": "8121a86de9d79a9e",
   "zh": "「告別，偽先知。」"
  },
  {
   "hash": "05a130d01b66e76f",
   "zh": "「以汝之犧牲，榮耀吾族。」"
  },
  {
   "hash": "63310422c10e7622",
   "zh": "魔像有氣無力地說：「什麼？」",
   "note": "旁白"
  }
 ],
 "glossary_additions": {
  "people": {
   "Bolesh": "波列許"
  },
  "places": {}
 },
 "translator_notes": "波列許為受傷的魔像隊長，語氣先憤後敬。魔像語原文（An-bal-sil-fer 等）照原樣保留。魔像說話語法（To+動詞）譯為古典文言。"
}
