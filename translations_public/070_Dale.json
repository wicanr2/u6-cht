 "translations": [
  {
   "hash": "36daa3c44e5ae743",
   "zh": "一位身材矮小、胸廓寬闊的男子。",
   "note": "DESC"
  },
  {
   "hash": "a604b68c4479e60b",
   "zh": "「聖者，$T好。」"
  },
  {
   "hash": "caf6312d010af9d4",
   "zh": "「還有什麼吾能為汝效勞的嗎？」"
  },
  {
   "hash": "7d1dec71c496d4b4",
   "zh": "「吾是@Glassblower（玻璃）工匠戴爾。」"
  },
  {
   "hash": "b84d665a60ded287",
   "zh": "「吾製作@glassware（玻璃）器皿，全境最精良的！」"
  },
  {
   "hash": "b678d639dba0ba4f",
   "zh": "「若汝想@buy（買）吾的玻璃器皿，開口就是了！」"
  },
  {
   "hash": "fe29e396f0582007",
   "zh": "「是的，吾知道如何製作玻璃劍。」"
  },
  {
   "hash": "82a26eee5a9961b8",
   "zh": "「但@demand（需求）量不大。」"
  },
  {
   "hash": "0790776810555ce2",
   "zh": "「製作需要五顆寶石。對大多數人來說太貴了。」"
  },
  {
   "hash": "52161d617ec67175",
   "zh": "「是的，但它們確實是@beauty（美麗）的東西……」"
  },
  {
   "hash": "eedc4f1047dbdeed",
   "zh": "「汝看起來是個懂得欣賞藝術的人。」"
  },
  {
   "hash": "6da7beb091d44f95",
   "zh": "「若汝有@gems（寶石），吾可以為汝打造一把。」"
  },
  {
   "hash": "5f12741b34ba8821",
   "zh": "「嗯……汝得去找鏡片師詢問那件事。」",
   "note": "about crystals/lens/telescope"
  },
  {
   "hash": "44dd5f9ee11f66f9",
   "zh": "「吾聽說學苑附近有一位。」"
  },
  {
   "hash": "c096cd199dfbe8c6",
   "zh": "「吾開店時來光顧！」"
  },
  {
   "hash": "c096cd199dfbe8c6",
   "zh": "「吾開店時來光顧！」"
  },
  {
   "hash": "33b0a8d902a0084a",
   "zh": "「是的，玻璃劍需要上等寶石來成就其美感！」"
  },
  {
   "hash": "3927dfc6f22a1af2",
   "zh": "「祝汝$T愉快！」",
   "note": "bye"
  },
  {
   "hash": "c2b946efcea5e857",
   "zh": "「請問？」"
  },
  {
   "hash": "71868021d97fc22b",
   "zh": "「抱歉，$Y，汝的寶石不夠。」"
  },
  {
   "hash": "4c4ebdb1975e4bdc",
   "zh": "「嗯，$Y，吾看到汝攜帶的寶石了。」"
  },
  {
   "hash": "ec63020f0763746e",
   "zh": "「汝是否希望吾為汝打造一把玻璃劍？」"
  },
  {
   "hash": "942b58b9e7c515c9",
   "zh": "「需要 5 顆寶石！汝確定嗎？」"
  },
  {
   "hash": "0af1930934440cc5",
   "zh": "「嗯，」他皺眉道，「或許吾看錯汝了……」",
   "note": "action; refused"
  },
  {
   "hash": "ff019e0537fb361a",
   "zh": "「但汝拿不了那樣的劍！」"
  },
  {
   "hash": "b1e4085f5b32ab1e",
   "zh": "$N 轉向熔爐，開始鍛造這把劍。",
   "note": "action"
  },
  {
   "hash": "d4c2bdc4e6e8c198",
   "zh": "不久後大功告成，汝對其美感嘆不已！",
   "note": "action"
  },
  {
   "hash": "76702b2a6e87994f",
   "zh": "「大功告成，汝永遠見不到比這更精美的作品了！」"
  },
  {
   "hash": "0af1930934440cc5",
   "zh": "「嗯，」他皺眉道，「或許吾看錯汝了……」",
   "note": "action"
  },
  {
   "hash": "7bf2e7fe4fc43e63",
   "zh": "「汝等哪一位？」"
  },
  {
   "hash": "62aaff84f5558c2c",
   "zh": "「哪件物品？」"
  },
  {
   "hash": "3978435bc2b6d4bf",
   "zh": "「$1 售價 #1 枚金幣。」"
  },
  {
   "hash": "09e61d3bae68d9cc",
   "zh": "「有意嗎，$Y？」"
  },
  {
   "hash": "17b442a747cda944",
   "zh": "「但那會讓汝行李過重，$Y！」"
  },
  {
   "hash": "3d5e71454a4edb9e",
   "zh": "「甚好！」"
  },
  {
   "hash": "b3984455c20f3402",
   "zh": "收下 $Y 的金幣後，$N 遞出 $1。"
  },
  {
   "hash": "b308280d0a2bd0e3",
   "zh": "「但汝的金幣不足，$Y！」"
  },
