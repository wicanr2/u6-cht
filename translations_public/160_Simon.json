{
 "_meta": {},
 "translations": [
  {
   "hash": "cecce0b5bf4d817d",
   "zh": "賽門",
   "note": "NPC name"
  },
  {
   "hash": "6fe44d7fbc009382",
   "zh": "體魄雄健之武士，聲音沙啞。",
   "note": "DESC"
  },
  {
   "hash": "4e9135aed8fd2fb1",
   "zh": "「$T好，$G。」"
  },
  {
   "hash": "cc9d014cc525cbc4",
   "zh": "「聖者$G，你好！」"
  },
  {
   "hash": "13015deb9b8728d6",
   "zh": "「聖者，歡迎蒞臨吾城。」他深深一揖。"
  },
  {
   "hash": "ebbef8d52f7d531e",
   "zh": "「叫我賽門即可，$G。」"
  },
  {
   "hash": "96529b6c6dc33765",
   "zh": "「吾乃巨蛇堡之堡主。」"
  },
  {
   "hash": "10676c262447ad95",
   "zh": "「吾個人最推崇勇氣之真言。」"
  },
  {
   "hash": "2cf0b0754308730e",
   "zh": "「吾已將此真言譜入歌中，傳授給吟遊詩人@Culham。」"
  },
  {
   "hash": "86d03ef2ca0821a8",
   "zh": "「他雖是@walking吟遊詩人，卻常在傑隆盤桓。」",
   "note": "traveling bard"
  },
  {
   "hash": "95355fe70779cb4f",
   "zh": "「確實，他行蹤難以捉摸。」"
  },
  {
   "hash": "fb6176d66a23fa3a",
   "zh": "「但如我所說，傑隆是個不錯的猜測。」"
  },
  {
   "hash": "7a2e211245ddf9b6",
   "zh": "「若吾手持符文，必當引以為傲。」"
  },
  {
   "hash": "c990f43415f95678",
   "zh": "「然他人憂慮此等重要護符之安危，將其藏於奇特之處。」"
  },
  {
   "hash": "d18ff4431ee4b000",
   "zh": "「吾不禁納悶——拾取擺在眾目睽睽之下的符文，算是盜竊嗎……」"
  },
  {
   "hash": "72e25090bb471675",
   "zh": "「再見。盼汝有暇再來，吾友。」"
  },
  {
   "hash": "05c8eb1ca11f7c56",
   "zh": "「吾真希望能助汝此事，聖者。」"
  }
 ],
 "glossary_additions": {
  "people": {
   "Simon": "賽門",
   "Culham": "庫漢"
  },
  "places": {}
 },
 "translator_notes": "Simon 為巨蛇堡堡主、武士，口吻莊重但親切。@traveling bard 用 @walking 保留 keyword 觸發；Culham 為吟遊詩人，常駐傑隆。避 5C trail 字無問題。"
}
