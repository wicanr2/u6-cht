{
 "_meta": {},
 "translations": [
  {
   "hash": "2fbf9a6fbb867912",
   "zh": "里歐娜"
  },
  {
   "hash": "5bf610e5a45b6f62",
   "zh": "一名衣著入時之女子，笑容含蓄而宜人。"
  },
  {
   "hash": "2f3f254bc3c44df5",
   "zh": "「何事，$P？」"
  },
  {
   "hash": "8d44bd49494be539",
   "zh": "鬧鬨之中，汝終究未能引起她注意。"
  },
  {
   "hash": "da429de123d5ae80",
   "zh": "她認出汝，面露喜色：「又見面了，$P！」"
  },
  {
   "hash": "23d292d7e90c432f",
   "zh": "「噢，汝定是$P，那位赫赫有名之聖者！與汝相見乃我之榮。」"
  },
  {
   "hash": "25492f8b3dedf0b1",
   "zh": "「我名里歐娜。」"
  },
  {
   "hash": "ca8c72318c8a3dbe",
   "zh": "「我曾自己@captain（船長）一艘船。」"
  },
  {
   "hash": "04930e78ff12380f",
   "zh": "「後來時運不濟，目下與@Leodon（黎奧）頓共航於@Hind（號）之上。」"
  },
  {
   "hash": "1a4547f324557f26",
   "zh": "「金鹿乃艘上好的老船。」"
  },
  {
   "hash": "82b77cee0e48b381",
   "zh": "「惜哉，船@repaired（修繕）期間我也閒著無事。」"
  },
  {
   "hash": "ba707dacf4a1f881",
   "zh": "「再無更願與之同航之人。」"
  },
  {
   "hash": "394151c0ae547264",
   "zh": "「哪位船長？我認識的船長可多哉……」"
  },
  {
   "hash": "394151c0ae547264",
   "zh": "「哪位船長？我認識的船長可多哉……」"
  },
  {
   "hash": "e69dbcc21f1f4add",
   "zh": "汝一說「船長」，桌邊海盜眾人皆殷殷望汝。"
  },
  {
   "hash": "42419d8aeb369608",
   "zh": "見汝並非與彼等交談，眾人重又各做各事。"
  },
  {
   "hash": "d9e333354a9298c4",
   "zh": "「約翰船長乃一狂人！」"
  },
  {
   "hash": "a6bfb129930ed9a6",
   "zh": "「他下了希斯洛斯地穴，欲尋通往世界另一端之路。」"
  },
  {
   "hash": "f158e4a64f750dd8",
   "zh": "「他言道：『在彼等取我性命前，盡可能屠戮@gargoyles（魔像族）族。』」"
  },
  {
   "hash": "bb44ee6ffa26cb90",
   "zh": "「非也！」狐狸船長道，「實情如何，我可告知汝。」"
  },
  {
   "hash": "4cafc1e428448f10",
   "zh": "「拜託，莫提及彼輩。」"
  },
  {
   "hash": "a3c7c8d99e6e5575",
   "zh": "「下回再敘。」"
  },
  {
   "hash": "90b28b3722ed6c32",
   "zh": "「此事我幫不上忙。」"
  },
  {
   "hash": "4e29491957231391",
   "zh": "「我自當樂意入伙——但我已在汝隊中啦！」"
  },
  {
   "hash": "f85cbefae215934e",
   "zh": "「或可讓我入汝之伙？」"
  },
  {
   "hash": "b9eca35539b16c1b",
   "zh": "「好。那我便暫且留此。」"
  },
  {
   "hash": "93597ddbd33dae43",
   "zh": "「汝乘那玩意兒可不行！」"
  },
  {
   "hash": "ae1d7fbf0db17e81",
   "zh": "「汝隨行之人已夠多了。」"
  },
  {
   "hash": "b08225a74ebfc54d",
   "zh": "「但汝若先請其中一人@leave（離隊），我便樂意入伙。」"
  },
  {
   "hash": "c5a0e1ee66811501",
   "zh": "「太好了！我想我等定能遇上不少有趣的男子……」"
  },
  {
   "hash": "f5f504e3c07c71e9",
   "zh": "「我得先@join（入伙）才能離隊，傻孩子！」"
  },
  {
   "hash": "30179362e7308693",
   "zh": "「先讓我等腳踏實地再說，可好？」"
  },
  {
   "hash": "7d7a5059b61ae0c0",
   "zh": "「好。我便回墜貞酒館等候。」"
  },
  {
   "hash": "f00f93f5236eb0c2",
   "zh": "「這些裝備留在汝身上更有用處。」"
  },
  {
   "hash": "e3b5df433e85f7fc",
   "zh": "她放下身上所有物事，方才轉身離去。"
  }
 ],
 "glossary_additions": {
  "people": {
   "Captain Fox": "狐狸船長"
  },
  "places": {
   "Hythloth": "希斯洛斯地穴"
  }
 },
 "translator_notes": "Leonna = Leodon 的大副，可加入隊伍。Buc's Den 海盜酒館的常客之一。Hythloth = U4-5 八大地穴之一。"
}
