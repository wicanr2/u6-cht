{
 "_meta": {},
 "translations": [
  {
   "hash": "83db4fd51550886d",
   "zh": "納薩蒂",
   "note": "NPC name — glossary 已有"
  },
  {
   "hash": "f1280ed3b3d84dea",
   "zh": "膚色幽暗、皮膚粗糙之魔像。",
   "note": "DESC"
  },
  {
   "hash": "4ebddb143f791c58",
   "zh": "這位德高望重的魔像對你的到來置若罔聞。",
   "note": "旁白"
  },
  {
   "hash": "be35b0fd2100cf97",
   "zh": "「對偽先知，吾無話可說！」"
  },
  {
   "hash": "b6e1768e7924938a",
   "zh": "「再次問候，$P。」"
  },
  {
   "hash": "f59e5861de21b267",
   "zh": "「問候汝，$P，幽冥界之聖者。」",
   "note": "gargoyle 視角稱呼"
  },
  {
   "hash": "a649da2352b0d1c4",
   "zh": "「見汝頸間佩有臣服護符。」"
  },
  {
   "hash": "5bcb4e8d69648c9c",
   "zh": "「汝之接受，吾視之為高貴且明智之舉。」"
  },
  {
   "hash": "05e302d030d94ce2",
   "zh": "「觀汝靈光，此等榮譽之舉於汝甚是罕見。」"
  },
  {
   "hash": "f6ea7fc93ee6a342",
   "zh": "「如此，汝@fated命中注定毀滅一個世界，亦不足為奇。」"
  },
  {
   "hash": "436c2e15a51d8759",
   "zh": "「觀汝靈光，汝並非邪惡之輩。」"
  },
  {
   "hash": "75db3a1c2bb7e036",
   "zh": "「如此，汝@fated命中注定毀滅一個世界，吾為汝深感惋惜。」"
  },
  {
   "hash": "46ef9edf63352ce8",
   "zh": "「觀汝靈光，汝確為榮譽之人。」"
  },
  {
   "hash": "e98b124f9d3a6425",
   "zh": "「如此，汝@fated命中注定毀滅一個世界，令吾大感訝異。」"
  },
  {
   "hash": "33e049c51347c37d",
   "zh": "「已與學者瓦卡德許一談否？」"
  },
  {
   "hash": "8a358390eebe7bb9",
   "zh": "「則汝必知已對吾之世界造成何等傷害！」"
  },
  {
   "hash": "edf9b01709f67727",
   "zh": "「別無@choice選擇，唯有歸還知識寶典！」"
  },
  {
   "hash": "3a83c0a365b47bd4",
   "zh": "「汝竊取知識寶典，已在此地造成巨大禍害！」"
  },
  {
   "hash": "9a4e11c8a7bb038e",
   "zh": "「別無@choice選擇，唯有歸還！」"
  },
  {
   "hash": "c643bfd6e78fa26f",
   "zh": "「唯見兩途：歸還@Codex知識寶典，或獻出汝之性命。」"
  },
  {
   "hash": "e3a3bee8905d355c",
   "zh": "「嘶……是，此詞有三重含義，吾知之。」"
  },
  {
   "hash": "e47e86ddd7fc9d5d",
   "zh": "「問汝所指何種犧牲：@self自我、@others他人，抑或@value貴重之物？」"
  },
  {
   "hash": "21870bdc3fe401ea",
   "zh": "「汝願以性命換取吾族福祉，吾甚為敬佩。」"
  },
  {
   "hash": "f56c1d01936ce063",
   "zh": "「然吾懷疑此並非預言之真意。」"
  },
  {
   "hash": "a402d6d416e25c73",
   "zh": "「什麼？！」"
  },
  {
   "hash": "43618deef98fb7cc",
   "zh": "「汝竟暗示可以沐浴他人之血來洗清罪行？！」"
  },
  {
   "hash": "bdb9c9aa293d61e5",
   "zh": "「此等念頭與汝陰暗之靈光可謂相稱！」"
  },
  {
   "hash": "d83b04ffdfbed968",
   "zh": "「此等念頭有辱汝榮譽之靈光！」"
  },
  {
   "hash": "455503d516779176",
   "zh": "「吾所知唯一真正有價值之物——正是知識寶典本身。」"
  },
  {
   "hash": "a1ad3bebfffa43a3",
   "zh": "「難道要毀掉知識寶典？！」"
  },
  {
   "hash": "bebbbb310dd9eff5",
   "zh": "「指引汝前往此處南方之智識之殿。」"
  },
  {
   "hash": "c822754ea856eb86",
   "zh": "「在彼處研讀儀典之書。」"
  },
  {
   "hash": "6156c5ecf7fd0859",
   "zh": "「亦在彼處取得渦旋透鏡！」"
  },
  {
   "hash": "951c41ea220a731a",
   "zh": "「而後返回此處，吾將告知汝必須做之事！」"
  },
  {
   "hash": "c6e74ebefabc984c",
   "zh": "「從世界兩側皆能看見@Vortex渦旋！」"
  },
  {
   "hash": "f097a633bc14d460",
   "zh": "「若知識寶典@returned歸還彼處，兩族皆可平等受益！」"
  },
  {
   "hash": "49d60527ff8f661c",
   "zh": "「吾名納薩蒂。」"
  },
  {
   "hash": "2614623e7c0bed3c",
   "zh": "「吾乃預言者，吾族之神秘顧問。」"
  },
  {
   "hash": "27eb708eaee10277",
   "zh": "「然吾無力阻止預言之書中所載之事。」"
  },
  {
   "hash": "31b748a450dea251",
   "zh": "「務必將渦旋透鏡展示給人類造透鏡者看。」"
  },
  {
   "hash": "7aab449b9308a330",
   "zh": "「亦務必告知人類造透鏡者，其所製之透鏡必須是凹面！」"
  },
  {
   "hash": "7430d7e77daa8306",
   "zh": "「此乃重中之重——凹面！」"
  },
  {
   "hash": "787234b25d070abb",
   "zh": "「吾不知知識寶典在何處。」"
  },
  {
   "hash": "50e8fa615d49e028",
   "zh": "「然記得隊長波列許方才剛從知識寶典處歸來！」"
  },
  {
   "hash": "858fbdbc3663372c",
   "zh": "「建議汝去尋他。到北方醫者之居所試試。」"
  },
  {
   "hash": "e766e1361f7e12f8",
   "zh": "「渦旋透鏡在此處南方之智識之殿。」"
  },
  {
   "hash": "794169669bd8f6d0",
   "zh": "「告別！待汝拜訪智識之殿後再來！」"
  },
  {
   "hash": "48763558bb673491",
   "zh": "「告別，$P。待有更多可談之事時再來。」"
  },
  {
   "hash": "567dcbd302e34c9a",
   "zh": "「吾無暇討論此事。」"
  },
  {
   "hash": "aaac41b3ef8b11b3",
   "zh": "「是，見渦旋透鏡已不再完整。」"
  },
  {
   "hash": "2e14af73faee9f53",
   "zh": "「前往造透鏡者處，其居所在此處東北方。」"
  },
  {
   "hash": "30817c7830a6934e",
   "zh": "「在彼處將透鏡修復！」"
  },
  {
   "hash": "af7699789e3d56e0",
   "zh": "「而後攜完整之透鏡返回此處！」"
  },
  {
   "hash": "bec7f9245452e986",
   "zh": "「需要渦旋透鏡，愚蠢的人類！」"
  },
  {
   "hash": "42bb24ffcbb7173c",
   "zh": "「莫再虛耗時光！」"
  },
  {
   "hash": "8f8d6654d8883e11",
   "zh": "「前往@Hall智識之殿取得透鏡！」"
  },
  {
   "hash": "af52e192f74631bd",
   "zh": "「親自帶回給吾，聖者！」"
  },
  {
   "hash": "d423b69e01122de9",
   "zh": "「甚好，見汝已持有渦旋透鏡。」"
  },
  {
   "hash": "3128bb6563524a49",
   "zh": "「亦已研讀儀典之書否？」"
  },
  {
   "hash": "6a75091b77080818",
   "zh": "「那便前往智識之殿去讀！」"
  },
  {
   "hash": "a6991a5ed072deb0",
   "zh": "「甚好。吾本身無法逆轉此儀式。」"
  },
  {
   "hash": "cf968a49622889b3",
   "zh": "「然知識寶典本身將說明如何歸還至渦旋。」"
  },
  {
   "hash": "488183cf18280293",
   "zh": "「亦知汝將需要第二枚透鏡。」"
  },
  {
   "hash": "463d6ae36bd792f7",
   "zh": "「需要人類製作之@lens透鏡，使汝之族人亦能看見@Codex知識寶典。」"
  },
  {
   "hash": "6b75833bf28086c5",
   "zh": "「面對如此無知，吾已絕望至極。」"
  },
  {
   "hash": "2e75382b8bddee77",
   "zh": "「吾拒絕與惡魔交談。」"
  },
  {
   "hash": "606abfc87a873dc3",
   "zh": "「或有另一途徑……」"
  },
  {
   "hash": "1d074a0d732b9923",
   "zh": "「是！將知識寶典歸還@Vortex渦旋！」"
  },
  {
   "hash": "8f6427465728c77a",
   "zh": "「如此可讓@both兩族共享！」"
  }
 ],
 "glossary_additions": {
  "people": {
   "Naxatilor": "納薩蒂"
  },
  "places": {}
 },
 "translator_notes": "納薩蒂為魔像族神秘預言者，語氣莊嚴睿智，對 Avatar 靈光的解讀因玩家選擇而異。核心使命：返還渦旋透鏡、歸還知識寶典。凹面透鏡（concave）為重要 quest 資訊，特別保留。"
}
