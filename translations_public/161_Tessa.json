 "_meta": {},
 "translations": [
  {
   "hash": "df2d8baebffe3773",
   "zh": "泰莎",
   "note": "NPC name"
  },
  {
   "hash": "cbc04afd1ed1c4fe",
   "zh": "衣著考究之婦人。",
   "note": "DESC"
  },
  {
   "hash": "e5841b33086d288c",
   "zh": "「聖者，再度歡迎光臨巨蛇堡！」"
  },
  {
   "hash": "1d6a1ef212a33607",
   "zh": "「啊，$G $P！一名來自不列顛城的水手說汝已回到此地！」"
  },
  {
   "hash": "aab6a06517414d9b",
   "zh": "「見此果真，實乃喜出望外！」"
  },
  {
   "hash": "56f248ce96f6cc8a",
   "zh": "「吾乃泰莎。汝上次試煉時，我們曾相逢，聖者！」"
  },
  {
   "hash": "9c1d085a83f64b1f",
   "zh": "「奇怪，汝竟認不出我了。」"
  },
  {
   "hash": "b72e0bfd3c54ef95",
   "zh": "「吾本以為這些歲月並未在我臉上留下太深的痕跡！」"
  },
  {
   "hash": "981dc5d3c9e9c833",
   "zh": "「吾乃@Courage之火的守護者。」",
   "note": "Courage 保留 keyword"
  },
  {
   "hash": "53555666beaaaad2",
   "zh": "「吾也協助夫君@Simon治理此鎮。」"
  },
  {
   "hash": "488e8b367f6bcd06",
   "zh": "「那場@earthquake之後，我們得以來到此地，真是萬幸！」"
  },
  {
   "hash": "92a0e10f737d61f4",
   "zh": "「他是此堡之堡主。」"
  },
  {
   "hash": "6b39b92b38ad0693",
   "zh": "汝將在此遇見許多英勇的戰士！」",
   "note": "注意：原文缺開引號，照原樣"
  },
  {
   "hash": "ea9d4e9840b4fd31",
   "zh": "「汝上次試煉之後，發生了多場大地震。」"
  },
  {
   "hash": "32b506271eed7441",
   "zh": "「邊境島沉入海底，連同我們的堡壘一同消失！」"
  },
  {
   "hash": "f9332c9752e3b49d",
   "zh": "「全憑上天庇佑，賽門與我才能活著離開那座島！」"
  },
  {
   "hash": "9149672d95e1122f",
   "zh": "「再見，聖者！試煉之途，鼓勇前行！」"
  },
  {
   "hash": "18adc020cfde29fc",
   "zh": "「請問？」"
  }
 ],
 "glossary_additions": {
