{
 "_meta": {},
 "translations": [
  {
   "hash": "b39bb236e26bd2ab",
   "zh": "一位睿智博學之女子。",
   "note": "DESC"
  },
  {
   "hash": "09ef63078cc8e2b7",
   "zh": "「$T 吉祥，@Avatar（聖者）。汝此來有何目的？」",
   "note": "$T time placeholder preserved"
  },
  {
   "hash": "e34a79be5cc8fb3d",
   "zh": "「吾乃蕭。」",
   "note": "Xiao is a Chinese name, keep as 蕭"
  },
  {
   "hash": "e09e31b4fedb4efb",
   "zh": "「吾乃@Wizards（法師）議會成員。」"
  },
  {
   "hash": "e5a6c266a05e4dcd",
   "zh": "「吾亦傳授@spells（法術）並販售魔法@reagents（材料）。」"
  },
  {
   "hash": "2a94793a9b0b1431",
   "zh": "「其秘密遠比吾所能傳授之術更為@powerful（強大）。」",
   "note": "wisp secret"
  },
  {
   "hash": "67baef515a8fcb28",
   "zh": "「若此秘密落入不該知曉之人手中，後果不堪設想。」"
  },
  {
   "hash": "047673e1c75d16e3",
   "zh": "「唯有吾等法師議會成員知曉此秘密。」"
  },
  {
   "hash": "075c8c08bace1fac",
   "zh": "「然而，既然汝乃聖者，將此秘密告知汝應當無礙。」"
  },
  {
   "hash": "2623eca6e3d9aefe",
   "zh": "「汝之榜樣激勵吾等眾人。」",
   "note": "avatar keyword response"
  },
  {
   "hash": "a2db3acd42ffcc02",
   "zh": "「維持全境魔法力量的@balance（均衡），乃吾等之責任。」"
  },
  {
   "hash": "45881ea766304b8c",
   "zh": "「吾等亦盡力弘揚八大@virtues（美德）。」"
  },
  {
   "hash": "206962ea770c7b7a",
   "zh": "「吾等於多年前創立了諸@shrines（聖壇）。」"
  },
  {
   "hash": "4099760b7cca0dde",
   "zh": "「@Thariand（薩里）安能告知汝更多。」"
  },
  {
   "hash": "9c2fdc2cd2f65827",
   "zh": "「彼乃@Lycaeum（學苑）的圖書館員。」"
  },
  {
   "hash": "2e1df21abd576345",
   "zh": "「汝必然知曉學苑所在吧。」"
  },
  {
   "hash": "3684e105980fea26",
   "zh": "「此乃不易之事。」",
   "note": "balance response"
  },
  {
   "hash": "0dd095f93ebec4d0",
   "zh": "「汝隨時歡迎來此，聖者。」",
   "note": "bye response"
  },
  {
   "hash": "f9f305bdc38d74fa",
   "zh": "「此事汝或許應找他人商議。」"
  },
  {
   "hash": "31e8c720e45ef68a",
   "zh": "「然汝尚無法術@book（書）！」"
  },
  {
   "hash": "5c7edb8ee62e1f01",
   "zh": "「然汝等之中無人持有法術@book（書）！」"
  },
  {
   "hash": "7bf2e7fe4fc43e63",
   "zh": "「汝等哪一位？」",
   "note": "party prompt"
  },
  {
   "hash": "5d46e73c04015d0f",
   "zh": "「$Y 欲習第幾階法術圈？」"
  },
  {
   "hash": "7fb5194af92d0a52",
   "zh": "「眾所皆知，法術圈共有八階。」"
  },
  {
   "hash": "221ceb71ef20b21e",
   "zh": "「吾感覺 $Y 目前僅能習得第 #1$1 階法術。」",
   "note": "$1 ordinal suffix placeholder preserved"
  },
  {
   "hash": "39441f98e0f898fc",
   "zh": "「然此等事非吾所能置喙……」"
  },
  {
   "hash": "09c3489e7eba1c4e",
   "zh": "「吾無此階之法術可授。」"
  },
  {
   "hash": "37de12a826dbce09",
   "zh": "「哪一種？」"
  },
  {
   "hash": "c2a585f7f938b436",
   "zh": "「$Y 或許尚未準備好習得此階法術。」"
  },
  {
   "hash": "38e28c553924d7fa",
   "zh": "「$Y 所持黃金不足 #5 枚。」"
  },
  {
   "hash": "681bf837d48f48da",
   "zh": "「此法術需 #5 枚金幣。汝有意購買嗎？」"
  },
  {
   "hash": "a22a19da93a5eead",
   "zh": "$N 遞給 $Y 一張佈滿符文的羊皮紙。"
  },
  {
   "hash": "27f94121e943a77e",
   "zh": "「汝尚未做好接受此等知識的準備。」"
  },
  {
   "hash": "e531967684d9e617",
   "zh": "「去尋訪@wisps（幽影），與之交談，習得其秘密。」"
  },
  {
   "hash": "a64dd7f4babe8ddf",
   "zh": "「如此汝方能準備進入第八階法術圈。」"
  },
  {
   "hash": "7bf2e7fe4fc43e63",
   "zh": "「汝等哪一位？」"
  },
  {
   "hash": "37de12a826dbce09",
   "zh": "「哪一種？」"
  },
  {
   "hash": "1a5c50992da77078",
   "zh": "「$1 每份 #1 枚金幣。」"
  },
  {
   "hash": "f8d92c716eb3e363",
   "zh": "「汝需要幾份？」"
  },
  {
   "hash": "9e20188c5876a688",
   "zh": "$N 將 $1 遞給 $Y。"
  },
  {
   "hash": "835d6182d3504dca",
   "zh": "「汝無法攜帶那麼多！」"
  },
  {
   "hash": "728518924ad41fa1",
   "zh": "「吾給汝 #5 份；汝不需要其餘的。」"
  },
  {
   "hash": "e851a65453925a3f",
   "zh": "「汝無法攜帶任何 $1！」"
  },
  {
   "hash": "341685f0f18f3b53",
   "zh": "「汝負擔不起那麼多！」"
  },
  {
   "hash": "d3312e8b052e147b",
   "zh": "「吾給汝 #5 份；汝無法負擔其餘的。」"
  },
  {
   "hash": "1478913253368c2c",
   "zh": "「汝負擔不起任何 $1！」"
  },
  {
   "hash": "7bf2e7fe4fc43e63",
   "zh": "「汝等哪一位？」"
  },
  {
   "hash": "69e5b03b303e477b",
   "zh": "「然汝無法攜帶法術書冊！」"
  },
  {
   "hash": "8a1ddb63dfc8ec48",
   "zh": "「然汝負擔不起一本法術書冊！」"
  },
  {
   "hash": "100b2a76f31eb1ac",
   "zh": "「一本法術書冊需 60 枚金幣。汝有意購買嗎？」"
  },
  {
   "hash": "df04c171b66f6452",
   "zh": "「請收下。」"
  },
  {
   "hash": "cad0cd6e28573484",
   "zh": "「或許汝的同伴之中有人適合。」"
  }
 ],
