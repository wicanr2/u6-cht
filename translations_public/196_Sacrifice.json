 "_meta": {},
 "translations": [
  {
   "hash": "d587d6e36d89a136",
   "zh": "犧牲祭壇",
   "note": "NPC name — 神殿祭壇"
  },
  {
   "hash": "41270f1fea86d6f6",
   "zh": "犧牲之祭壇。",
   "note": "DESC"
  },
  {
   "hash": "4dea77d1e904b054",
   "zh": "當你跪在祭壇前，一個神秘的聲音在你腦中迴響。",
   "note": "旁白"
  },
  {
   "hash": "74c8ed7d5b297caf",
   "zh": "「汝對犧牲仍有許多須學習之處。」",
   "note": "低階評語"
  },
  {
   "hash": "1592e60400c67190",
   "zh": "「汝之行為展現了令人欽佩的犧牲精神。」",
   "note": "中階評語"
  },
  {
   "hash": "52b84eff61efe845",
   "zh": "「汝之行為可為眾人表率。」",
   "note": "高階評語"
  },
  {
   "hash": "bf3b28dcc608d94c",
   "zh": "你希望在此祭壇冥想嗎？",
   "note": "旁白提示，尾隨空格保留"
  },
  {
   "hash": "50e77701c0136675",
   "zh": "#2。$Y",
   "note": "控制符保留"
  },
  {
   "hash": "4f97e949580d4b79",
   "zh": "「誰來冥想？」",
   "note": "尾隨空格保留"
  },
  {
   "hash": "7f9396ae3d94c85d",
   "zh": "「覆誦犧牲真言。」"
  },
  {
   "hash": "ffe5b426e8468f7f",
   "zh": "「$Z…… $Z……」",
   "note": "真言提示第一次"
  },
  {
   "hash": "ffe5b426e8468f7f",
   "zh": "「$Z…… $Z……」",
   "note": "真言提示第二次"
  },
  {
   "hash": "ffe5b426e8468f7f",
   "zh": "「$Z…… $Z……」",
   "note": "真言提示第三次"
  },
  {
   "hash": "8f50d95aa507e29c",
   "zh": "「宇宙如此廣闊，如此古遠，",
   "note": "聖言第一段（未閉合）"
  },
  {
   "hash": "264693df4c2107a4",
   "zh": "一個人的生命之所以有意義，",
   "note": "聖言第二段"
  },
  {
   "hash": "d05ab4a9db3e51ed",
   "zh": "唯在於他犧牲的尺度。」",
   "note": "聖言第三段（閉合）"
  },
  {
   "hash": "9d3c825b4abf0064",
   "zh": "你未能獲得啟示。",
   "note": "旁白"
  },
  {
   "hash": "64268b11d0648045",
   "zh": "$Y提升了一個等級……",
   "note": "升級旁白"
  },
  {
   "hash": "6939191c0a6360b6",
   "zh": "力量……",
   "note": "能力提升（犧牲→力量+敏捷，第一項）"
  },
  {
   "hash": "ab95c009eca1d469",
   "zh": "以及敏捷！",
   "note": "能力提升第二項"
  },
  {
   "hash": "cb93cedb92f1135f",
   "zh": "「此刻此地，汝已無更多可學。」"
  },
  {
   "hash": "36b180a0ddf1311a",
   "zh": "「待汝的旅程更進一步，再行回返。」"
  }
 ],
 "glossary_additions": {
  "people": {},
  "places": {}
 },
 "translator_notes": "犧牲神殿，真言 cah（不翻譯）。冥想獲得力量+敏捷提升。聖言三段合一引自科幻作家 Robert A. Heinlein 之句（有說法為 U6 開發者引用），宇宙廣袤與個人犧牲的對比。"
}
