 "translations": [
  {
   "hash": "27eb205603e9964a",
   "zh": "一位身形圓潤、金色捲髮、面帶笑容的男子。",
   "note": "DESC"
  },
  {
   "hash": "23db9122c75bdf7d",
   "zh": "「聖者，又見面了！」"
  },
  {
   "hash": "502d28b5d01f8ce8",
   "zh": "「哈囉哈囉！」"
  },
  {
   "hash": "4033d7c837044682",
   "zh": "「這個$T吾能為汝做什麼？」"
  },
  {
   "hash": "d2c5144df1c62ec7",
   "zh": "「真有趣。吾記得汝的名字！」"
  },
  {
   "hash": "e0d2846c7e1fcbf5",
   "zh": "「吾叫亞倫。」"
  },
  {
   "hash": "50487d7cc0972c74",
   "zh": "「吾經營鋸木廠！有什麼吾能為汝效勞的嗎？」"
  },
  {
   "hash": "0304c14e5ad928f8",
   "zh": "「是的，吾把原木鋸成@boards（木板）。」"
  },
  {
   "hash": "e8c1eb571ac0c7aa",
   "zh": "「吾開店時來光顧！」"
  },
  {
   "hash": "ec55f88fbcb32847",
   "zh": "「吾的鋸木廠把粗切的原木鋸成光滑的木板和厚板。」"
  },
  {
   "hash": "c49e24273b58fc04",
   "zh": "「嗯，吾看到 $Y 有根紫杉原木。」他以行家的眼光審視木材。",
   "note": "action"
  },
  {
   "hash": "a17c9b1cb58883ef",
   "zh": "「紋路不錯。是的，吾可以用這根原木做出一塊好木板。」"
  },
  {
   "hash": "156ac6de8e926725",
   "zh": "「但這需要 5 枚金幣，$Y！」"
  },
  {
   "hash": "12576311f6b8ac0b",
   "zh": "「還有意嗎？」"
  },
  {
   "hash": "401f618e3a238f5a",
   "zh": "「珍重！」",
   "note": "bye"
  },
  {
   "hash": "57f6e4ebe2f3306a",
   "zh": "「請問汝說什麼？」"
  },
  {
   "hash": "ba46892f8c736e0c",
   "zh": "「抱歉，吾不能免費工作！」"
  },
  {
   "hash": "8af69c80aa4e672c",
   "zh": "「等汝湊到 5 枚金幣再來！」"
  },
  {
   "hash": "c71d6bba71935bab",
   "zh": "亞倫走向鋸子，把原木切成一塊平整磨光的木板。",
   "note": "action"
  },
  {
   "hash": "cb8c6dc61db29b40",
   "zh": "「完成了！」他將成品遞給 $Y。",
   "note": "action"
  },
  {
   "hash": "9577d38ca85d6d05",
   "zh": "「哦。那也許改天再說吧。」"
  }
 ],
 "glossary_additions": {
