 "translations": [
  {
   "hash": "86f39c7dbb29ec94",
   "zh": "一位和藹可親的老婦人。",
   "note": "DESC"
  },
  {
   "hash": "444b6ba4f5679e75",
   "zh": "「歡迎來到吾的治療所，聖者。」",
   "note": "first greeting"
  },
  {
   "hash": "b797d601d2485a82",
   "zh": "「吾希望汝不需要吾的服務！」"
  },
  {
   "hash": "5d0e19ee56eea546",
   "zh": "「再次歡迎，尊貴的聖者。」"
  },
  {
   "hash": "9d2fa3d733d0dd89",
   "zh": "「吾希望這次來訪是為了閒聊，而非看病！」"
  },
  {
   "hash": "0b67bc8b3bd4f12b",
   "zh": "「但吾很高興地說汝的隊伍無人陣亡！」",
   "note": "resurrection check; no one dead"
  },
  {
   "hash": "267b75360034e714",
   "zh": "「吾的名字是塔拉。」"
  },
  {
   "hash": "eabf93427cf77da3",
   "zh": "「吾是這座城鎮的治療師。」"
  },
  {
   "hash": "37e2dff64c89fcd3",
   "zh": "「吾在這裡照料@unfit（體弱）者已有六十年了！」"
  },
  {
   "hash": "0a29131a348b58f9",
   "zh": "「那些需要@healing（療傷）、@curing（解毒），或需要被@resurrected（復活）的人。」"
  },
  {
   "hash": "3ef5979ad506e907",
   "zh": "「『cah』，那是奉獻的咒語。」",
   "note": "mantra kept as-is"
  },
  {
   "hash": "401f618e3a238f5a",
   "zh": "「珍重！」",
   "note": "bye"
  },
  {
   "hash": "8f14487cf8cce24b",
   "zh": "「吾能為汝做什麼？」"
  },
  {
   "hash": "933197594b850982",
   "zh": "「吾不理解『$Z』。」"
  },
  {
   "hash": "8ded6a1041341d62",
   "zh": "「請問汝說什麼？」"
  },
  {
   "hash": "715a86bc79bafa60",
   "zh": "「但汝身體無恙！」",
   "note": "heal; no injury"
  },
  {
   "hash": "f13782857ba64cfc",
   "zh": "「但汝等全都身體無恙！」"
  },
  {
   "hash": "7bf2e7fe4fc43e63",
   "zh": "「汝等哪一位？」"
  },
  {
   "hash": "0096c89bdb1ea6cc",
   "zh": "「吾看到汝的傷勢了，$Y。」",
   "note": "heal 30g"
  },
  {
   "hash": "87ef4fd0f61f6961",
   "zh": "「汝願意獻上 30 枚金幣嗎？」"
  },
  {
   "hash": "5d89cc7119087070",
   "zh": "塔拉走近 $Y，為其包紮傷口。",
   "note": "action"
  },
  {
   "hash": "eb56ee104dc7ff07",
   "zh": "「若汝不願付費，吾便無法為汝治療。」"
  },
  {
   "hash": "e5f8119409f78da4",
   "zh": "「抱歉。沒有獻金，吾無法為汝治療。」",
   "note": "no gold"
  },
  {
   "hash": "432e96e99d4ce8fd",
   "zh": "「汝雖貧窮，但汝的事業是正義的。」",
   "note": "free heal for Avatar"
  },
  {
