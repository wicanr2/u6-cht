{
 "_meta": {},
 "translations": [
  {
   "hash": "b804bed7fb9ef60b",
   "zh": "慈悲祭壇",
   "note": "NPC name — 神殿祭壇"
  },
  {
   "hash": "32afabed78c65de5",
   "zh": "慈悲之祭壇。",
   "note": "DESC"
  },
  {
   "hash": "4dea77d1e904b054",
   "zh": "當你跪在祭壇前，一個神秘的聲音在你腦中迴響。",
   "note": "旁白"
  },
  {
   "hash": "98e3ec77df2e5480",
   "zh": "「汝對慈悲仍有許多須學習之處。」",
   "note": "低階評語"
  },
  {
   "hash": "1e4caec93a7f99e1",
   "zh": "「汝之行為展現了令人欽佩的慈悲。」",
   "note": "中階評語"
  },
  {
   "hash": "52b84eff61efe845",
   "zh": "「汝之行為可為眾人表率。」",
   "note": "高階評語"
  },
  {
   "hash": "bf3b28dcc608d94c",
   "zh": "你希望在此祭壇冥想嗎？",
   "note": "旁白提示，尾隨空格保留"
  },
  {
   "hash": "50e77701c0136675",
   "zh": "#2。$Y",
   "note": "控制符保留"
  },
  {
   "hash": "4f97e949580d4b79",
   "zh": "「誰來冥想？」",
   "note": "尾隨空格保留"
  },
  {
   "hash": "c393f590a1746886",
   "zh": "「覆誦慈悲真言。」"
  },
  {
   "hash": "ffe5b426e8468f7f",
   "zh": "「$Z…… $Z……」",
   "note": "真言提示第一次"
  },
  {
   "hash": "ffe5b426e8468f7f",
   "zh": "「$Z…… $Z……」",
   "note": "真言提示第二次"
  },
  {
   "hash": "ffe5b426e8468f7f",
   "zh": "「$Z…… $Z……」",
   "note": "真言提示第三次"
  },
  {
   "hash": "bf4317d82294f964",
   "zh": "「即便最兇猛的野獸，亦不乏些許憐憫之心。」",
   "note": "聖言（莎士比亞《理查三世》典故）"
  },
  {
   "hash": "8f8e4dc55c4ac2f2",
   "zh": "「仁慈寬恕，乃高貴之真正徽印。」",
   "note": "聖言（莎士比亞《泰特斯·安德洛尼克斯》典故）"
  },
  {
   "hash": "9d3c825b4abf0064",
   "zh": "你未能獲得啟示。",
   "note": "旁白"
  },
  {
   "hash": "64268b11d0648045",
   "zh": "$Y提升了一個等級……",
   "note": "升級旁白"
  },
  {
   "hash": "ab95c009eca1d469",
   "zh": "以及敏捷！",
   "note": "能力提升（慈悲→敏捷）"
  },
  {
   "hash": "cb93cedb92f1135f",
   "zh": "「此刻此地，汝已無更多可學。」"
  },
  {
   "hash": "36b180a0ddf1311a",
   "zh": "「待汝的旅程更進一步，再行回返。」"
  }
 ],
 "glossary_additions": {
  "people": {},
  "places": {}
 },
 "translator_notes": "慈悲神殿，真言 mu（不翻譯）。冥想獲得敏捷提升。聖言引自莎士比亞作品。"
}
