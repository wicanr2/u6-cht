 "_meta": {},
 "translations": [
  {
   "hash": "2fe8a0f8a981bf0e",
   "zh": "一頭巨大的雌性獨眼巨人。",
   "note": "DESC"
  },
  {
   "hash": "4cdf5a49a875d92d",
   "zh": "「你回來了！和@tiny（小不）點玩嗎？」"
  },
  {
   "hash": "0a39b8c2a4ee8d03",
   "zh": "「好，他需要小小的朋友！」"
  },
  {
   "hash": "e5bd7d32c11be26a",
   "zh": "「但他需要小小的朋友！他會孤單！」"
  },
  {
   "hash": "350030ba9e882bee",
   "zh": "「哦，你可愛！你長得奇怪像@tiny（小不）點！」"
  },
  {
   "hash": "dec61a65a8edecb6",
   "zh": "「我獨眼巨人。」"
  },
  {
   "hash": "e9b6aeb46778128c",
   "zh": "「@Tiny（小不）點叫我『媽媽』。」"
  },
  {
   "hash": "5ae13fe2a1421e53",
   "zh": "「男的在岸邊找到他。」"
  },
  {
   "hash": "50b20d5a63cbbe22",
   "zh": "「一眼的小不點很久以前死了。」"
  },
  {
   "hash": "aea5fb719ff1381d",
   "zh": "「兩眼的小不點一樣好！」"
  },
  {
   "hash": "a33298b3263abce4",
   "zh": "「住這！煮飯，打獵！」"
  },
  {
   "hash": "1011006071580f53",
   "zh": "「地下室不能去。很深很深。@Locked（鎖著）。」"
  },
  {
   "hash": "7222d67f7f9465a8",
   "zh": "「長什麼樣子？」"
  },
  {
   "hash": "7be0cd972508d84d",
   "zh": "「什麼顏色？」"
  },
  {
   "hash": "80aa8c81e2e6512c",
   "zh": "「哦，我見過！大大黑色@block方塊！」",
   "note": "關於黑色方形石頭"
  },
  {
   "hash": "313a879436257362",
   "zh": "「去找男的說。他有鑰匙。」"
  },
  {
   "hash": "85b7708f3aaae7f6",
   "zh": "「男的把那個放在@cellar（地）下室。」"
  },
  {
   "hash": "bda6718a12a42c53",
   "zh": "「快快回來，多和小不點玩！」"
  },
  {
   "hash": "b6422d8c3fb4fa73",
   "zh": "「$Z是什麼意思？」"
  }
 ],
 "glossary_additions": {
  "people": {
   "Mama": "媽媽"
  },
  "places": {}
 },
 "translator_notes": "媽媽是雌性獨眼巨人，和爸爸一樣說話簡短。兩眼的小不點（Myles）是她收養的人類孩子。black block（黑色方塊）是劇情道具Vortex Cube。"
}
