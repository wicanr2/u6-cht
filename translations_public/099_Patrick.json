{
 "_meta": {},
 "translations": [
  {
   "hash": "73bf811d3798409d",
   "zh": "一位衣著色彩斑斕的吟遊詩人。",
   "note": "DESC"
  },
  {
   "hash": "75c6d08c06c33c1c",
   "zh": "「$T好，",
   "note": "fragment — 與後續拼接"
  },
  {
   "hash": "4ce8205e43426f4e",
   "zh": "女士。」",
   "note": "fragment — 女性稱謂"
  },
  {
   "hash": "5d79acbd2150d7f0",
   "zh": "先生。」",
   "note": "fragment — 男性稱謂"
  },
  {
   "hash": "db8eeb36df5995c8",
   "zh": "「在下叫派崔克，汝尊名？」"
  },
  {
   "hash": "5b4c3788ac7d44bb",
   "zh": "「幸會。」"
  },
  {
   "hash": "ec47e21cf8ee420a",
   "zh": "「與一般@吟遊詩人無異——說@故事、唱@歌，諸如此類。」"
  },
  {
   "hash": "0bcaca1598fd3226",
   "zh": "「在下在@音樂學院受過訓練，大多數人都是如此。」"
  },
  {
   "hash": "72debc9b204fcd31",
   "zh": "「約翰、拉澤娜、西歐娜——他們都在那裡求學過。」"
  },
  {
   "hash": "4fdee25a5f5a595d",
   "zh": "「當然，也有像@曼德雷克這樣的奇人。」"
  },
  {
   "hash": "0ea33125363b82b0",
   "zh": "「確是位出色的吟遊詩人。」"
  },
  {
   "hash": "12ba58f78f4efd31",
   "zh": "「他完全是自學成才，對八大@美德也有些奇特的見解。」"
  },
  {
   "hash": "de9a3ff3a556e040",
   "zh": "「不過在下也得承認……」"
  },
  {
   "hash": "9a07fc93e4716e5c",
   "zh": "「上次我等齊聚一堂舉辦作曲比賽，他輕鬆奪得首獎。」"
  },
  {
   "hash": "c7c05d38c7fd753d",
   "zh": "「汝自己去問他吧。」"
  },
  {
   "hash": "be369cf9a1d09763",
   "zh": "「好吧，說一個……」"
  },
  {
   "hash": "b939d226fb4cd8c2",
   "zh": "「貓頭鷹與小花貓揚帆出海",
   "note": "混搭童謠fragment"
  },
  {
   "hash": "c7a36acaedc72ff3",
   "zh": "乘著一艘漂亮的豌豆綠小舟。",
   "note": "混搭童謠fragment"
  },
  {
   "hash": "de2eeec07126ab41",
   "zh": "蜘蛛爬來坐在他們身旁，",
   "note": "混搭童謠fragment"
  },
  {
   "hash": "47baaaeeba7b3c12",
   "zh": "貓兒說：『誰睡了我的床！』",
   "note": "混搭童謠fragment"
  },
  {
   "hash": "b34c01c97eac2d04",
   "zh": "時鐘報一時，貓頭鷹倒下，",
   "note": "混搭童謠fragment"
  },
  {
   "hash": "3c9500440da9cc95",
   "zh": "三隻小豬『唧唧唧唧唧』一路跑回家。」",
   "note": "混搭童謠，刻意胡亂拼接"
  },
  {
   "hash": "2c9ecf1119dc067c",
   "zh": "「在下完全不明白，但@貓博士說那是他最喜歡的故事。」"
  },
  {
   "hash": "fd8ba170dee97ed2",
   "zh": "「他是個好人，而且他的@飲品也不摻水。」"
  },
  {
   "hash": "a988fbf8ea7556a8",
   "zh": "「不過他說在下應該學一個有@鴨子的故事。」"
  },
  {
   "hash": "4e614a491ca357f5",
   "zh": "「吟遊詩人的工作容易讓人@口渴。」"
  },
  {
   "hash": "90cb2d2b548bb3c8",
   "zh": "「武士不能讓刀鋒鈍去，對吧？」"
  },
  {
   "hash": "11d721ba8c8b498a",
   "zh": "「同理，吟遊詩人也得讓喉嚨保持濕潤！」"
  },
  {
   "hash": "495b5576aaa0205f",
   "zh": "「別問在下。他喜歡鴨子是他的事。」"
  },
  {
   "hash": "033e7c6736b91f60",
   "zh": "他清了清嗓子……"
  },
  {
   "hash": "ab32c5f44a6ce5e2",
   "zh": "「一位年輕力壯的鐵匠站在爐旁鍛鐵，",
   "note": "民謠fragment，帶雙關意味"
  },
  {
   "hash": "889c7f75b2db5ffe",
   "zh": "錘子擱置一旁但爐火仍燃，",
   "note": "民謠fragment"
  },
  {
   "hash": "db162ec4686539d1",
   "zh": "豐腴的少女含笑前來，",
   "note": "民謠fragment"
  },
  {
   "hash": "d6149579424b3398",
   "zh": "問他可否去她的爐邊效力。」",
   "note": "民謠fragment，爐=雙關"
  },
  {
   "hash": "088769a7dd6bbbd4",
   "zh": "「叮鈴鏘當叮鈴鏘當叮鈴鏘當叮鈴，",
   "note": "副歌擬聲fragment"
  },
  {
   "hash": "761f5c42af5b4ecb",
   "zh": "叮鈴鏘當叮鈴鏘當叮鈴嗨喲。」",
   "note": "副歌擬聲fragment"
  },
  {
   "hash": "93990f2bbae48427",
   "zh": "「『願意』鐵匠答道，二人便一同而去，",
   "note": "民謠fragment"
  },
  {
   "hash": "b636bdddf058b5ce",
   "zh": "「前往那少女的爐邊，",
   "note": "民謠fragment"
  },
  {
   "hash": "55ce0691ff0c7027",
   "zh": "二人褪衣勞作——天氣炎熱，活計也熱，",
   "note": "民謠fragment，雙關"
  },
  {
   "hash": "52ad42a31eecc9df",
   "zh": "她點燃爐火，令他頓時發熱。」",
   "note": "民謠fragment，雙關"
  },
  {
   "hash": "088769a7dd6bbbd4",
   "zh": "「叮鈴鏘當叮鈴鏘當叮鈴鏘當叮鈴，",
   "note": "副歌擬聲fragment"
  },
  {
   "hash": "76156a42af531210",
   "zh": "叮鈴鏘當叮鈴鏘當叮鈴嗨喲！」",
   "note": "副歌擬聲fragment"
  },
  {
   "hash": "99f4466cc6303766",
   "zh": "「希望汝喜歡這首歌！」"
  },
  {
   "hash": "f02572718eb6401f",
   "zh": "「珍重再見。」"
  },
  {
   "hash": "9b064b3741585426",
   "zh": "「這是個絕妙的問題，再問在下一個！」"
  }
 ],
 "glossary_additions": {
  "people": {
   "Patrick": "派崔克",
   "Lazeena": "拉澤娜",
   "Sionnach": "西歐娜",
   "Mandrake": "曼德雷克"
  }
 },
 "translator_notes": "099 Patrick: 吟遊詩人，說混搭童謠與帶雙關的鐵匠民謠。Dr. Cat的好友。副歌擬聲詞以漢語諧音意譯。"
}
