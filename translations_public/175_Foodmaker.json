 "_meta": {},
 "translations": [
  {
   "hash": "70574ba13ea6ffc3",
   "zh": "膳師",
   "note": "NPC name — glossary 已有"
  },
  {
   "hash": "25328cb2ddf76caf",
   "zh": "體形龐大、性情豪放之魔像。*",
   "note": "DESC，* 控制符保留"
  },
  {
   "hash": "aa3336095f1f8be9",
   "zh": "他手持一把大到可以當劍用的「菜刀」！",
   "note": "旁白"
  },
  {
   "hash": "96a63bc6dc7ea8ca",
   "zh": "「偽先知！」魔像大喊。「滾！滾！」",
   "note": "旁白嵌入"
  },
  {
   "hash": "cede7879b01dfb63",
   "zh": "「An-bal-sil-fer！」魔像大喊。「Gres por！Gres por！」",
   "note": "魔像語保留"
  },
  {
   "hash": "6f82a02050456cc8",
   "zh": "尤洛半開玩笑地說：「我們最好照他說的做。」",
   "note": "旁白嵌入"
  },
  {
   "hash": "386f52138bcd2abb",
   "zh": "「況且，我們也不知道那是什麼肉！",
   "note": "旁白（未閉合）"
  },
  {
   "hash": "5e4fb0ce9e83362c",
   "zh": "「歡迎偽先知再次光臨！」"
  },
  {
   "hash": "45c1dad0d2064ee6",
   "zh": "「偽先知！」"
  },
  {
   "hash": "352a494d36cbb73a",
   "zh": "「歡迎光臨吾之廚所。」"
  },
  {
   "hash": "3a4307fc5a8b4ab0",
   "zh": "「奉上天下最美味之@food食物！」"
  },
  {
   "hash": "943953f22dbcd577",
   "zh": "「吾身上並未帶有食物。請至吾的店鋪。」"
  },
  {
   "hash": "794a9e936d706862",
   "zh": "「吾之馬肉品質聞名於所有魔像之中！」"
  },
  {
   "hash": "9a47201f0894a5b0",
   "zh": "「吾被稱為膳師，尚未獲得真名。」"
  },
  {
   "hash": "fd761ae47f2ad8de",
   "zh": "「然吾乃此地最傑出之廚師！」"
  },
  {
   "hash": "f8325b17246e8cd3",
   "zh": "「憑藉吾之技藝，不久後必可獲賜真名！」"
  },
  {
   "hash": "9ff11086762a4fbc",
   "zh": "「工匠？實在可悲！」這位龐大的魔像皺眉道。",
   "note": "旁白嵌入"
  },
  {
   "hash": "0ea4241eea9ec843",
   "zh": "「自怨自艾？力量與長久的努力才能帶來成功！」"
  },
  {
   "hash": "4e28b77387e7de77",
   "zh": "「吾不願再聽到關於那個傢伙的任何事。」"
  },
  {
   "hash": "01d7c764fd16faaf",
   "zh": "「為居住在這一帶的所有魔像烹調膳食！」"
  },
  {
   "hash": "4ec2814cdd8e0b75",
   "zh": "「亦指導@wingless無翼者承擔廚房雜務。」"
  },
  {
   "hash": "cd5dc5dcb3747ac3",
   "zh": "「須盯著他們的一舉一動！」"
  },
  {
   "hash": "08618927109cdba1",
   "zh": "「然吾承認，他們對吾族社會不可或缺。」"
  },
  {
   "hash": "00af43a4b0ba749c",
   "zh": "「呃，是的，當然也有那個。」"
  },
  {
   "hash": "db1f1280b7474bff",
   "zh": "「然吾以烤馬肉聞名！」"
  },
  {
   "hash": "f7a164dc24487613",
   "zh": "「奉上些許這等美味之@food！」"
  },
  {
   "hash": "0ce8095e4afe24e8",
   "zh": "「不知$Z是何物。」"
  },
  {
   "hash": "487144dcac59d6fe",
   "zh": "「然若汝告知食譜，吾便欣然為汝烹調！」"
  },
  {
   "hash": "120e1986d48b449d",
   "zh": "「是是！奉上此精心烤製之@meat肉食！」"
  },
  {
   "hash": "9b5675d384bf32fc",
   "zh": "魔像揮動巨刀幾下，為你切下一片@meat肉。",
   "note": "旁白"
  },
  {
   "hash": "04464855ce5dfebf",
   "zh": "你接受這塊肉嗎？",
   "note": "旁白提示"
  },
  {
   "hash": "cb6a9c1a1757adbc",
   "zh": "你",
   "note": "旁白前半"
  },
  {
   "hash": "1b0f2af32170bab8",
   "zh": "的隊伍吃下了奉上的食物。",
   "note": "旁白後半（隊伍版）"
  },
  {
   "hash": "b2b8bbcdf86d50a5",
   "zh": "吃下了奉上的食物。",
   "note": "旁白（單人版）"
  },
  {
   "hash": "1c8daf9f424551e1",
   "zh": "那滋味前所未有，難以形容。",
   "note": "旁白"
  },
  {
   "hash": "0576244c9382acd1",
   "zh": "尤洛開口：「不知這是什麼@meat肉，$P。」",
   "note": "旁白嵌入"
  },
  {
   "hash": "c5f1381e2fc902be",
   "zh": "魔像滿臉驕傲。「問汝：這不是汝所吃過最好的@meat肉嗎？」",
   "note": "旁白嵌入"
  },
  {
   "hash": "9c44f2c37c692f6f",
   "zh": "「汝不喜歡令吾深感難過！」"
  },
  {
   "hash": "a531f3e070667aaa",
   "zh": "「天下烤@horseflesh馬肉無人勝過吾！」"
  },
  {
   "hash": "77419c5022f00683",
   "zh": "「且慢！」"
  },
  {
   "hash": "5015d6543c9e89de",
   "zh": "「贈汝些許精良馬肉，帶上路途！」"
  },
  {
   "hash": "071e667d548d11e2",
   "zh": "你接受他的禮物嗎？",
   "note": "旁白提示"
  },
  {
   "hash": "fee2be560c9cc38a",
   "zh": "廚師給了",
   "note": "旁白前半"
  },
  {
   "hash": "b5617c19799ea15c",
   "zh": "你",
   "note": "旁白（單人版）"
  },
  {
   "hash": "07b86707b483db9e",
   "zh": "$Y",
   "note": "旁白（隊伍成員版）"
  },
  {
   "hash": "2170730cff61e84a",
   "zh": " #2塊馬排。",
   "note": "#N 控制符保留"
  },
  {
   "hash": "7c1bfd2e38f60ddc",
   "zh": "「那好，為汝保留在此！」"
  },
  {
   "hash": "a3dcbd6eb3e7db22",
   "zh": "「歡迎汝下次肚子餓了再來！」"
  }
 ],
 "glossary_additions": {
