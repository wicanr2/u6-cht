{
 "_meta": {
  "npc": "Gwenneth",
  "role": "弓店店主，Iolo 昔日學徒"
 },
 "translations": [
  {
   "hash": "76c74647747f9115",
   "zh": "葛雯妮絲"
  },
  {
   "hash": "8bf6dd0e331c07b1",
   "zh": "一位嬌小女子，棕髮飄逸。"
  },
  {
   "hash": "321708be0627785b",
   "zh": "尤洛！"
  },
  {
   "hash": "44fb09d7671e14b1",
   "zh": "還有汝的同伴們！」"
  },
  {
   "hash": "5706d704da592747",
   "zh": "「聞汝至此城之傳言！」"
  },
  {
   "hash": "b7b0ee5d554ad936",
   "zh": "尤洛親切地向昔日學徒問好。"
  },
  {
   "hash": "2b89c20e05fae570",
   "zh": "「生意如何，葛雯妮絲？」"
  },
  {
   "hash": "b4708eef0ef6c177",
   "zh": "「甚好，甚好。傑佛瑞爵士剛親下一筆大訂單！」"
  },
  {
   "hash": "fcb20c948d7ee7b4",
   "zh": "「如今@魔像族肆虐，弓的需求大增！」"
  },
  {
   "hash": "6222df7d49377ae5",
   "zh": "葛雯妮絲轉向你，說：「尤洛之友啊，於"
  },
  {
   "hash": "4f9af85d255edc86",
   "zh": "此$T可效勞？」"
  },
  {
   "hash": "68d1b5ba2ccb5dbe",
   "zh": "「我認得汝！汝便是尤洛之友，$P！」"
  },
  {
   "hash": "124863f871715477",
   "zh": "「此美好之$T，可效何勞？」"
  },
  {
   "hash": "db82a57bb8c44c77",
   "zh": "「又見面了。此$T可效何勞？」"
  },
  {
   "hash": "7a00cded738a03be",
   "zh": "「接下來要什麼？」"
  },
  {
   "hash": "00612319135a7b4b",
   "zh": "買"
  },
  {
   "hash": "2d19df18d4078885",
   "zh": "賣"
  },
  {
   "hash": "c4bcadba8e631b86",
   "zh": "名字"
  },
  {
   "hash": "804b5476fb1884bb",
   "zh": "「何等怪問。我自然是葛雯妮絲。」"
  },
  {
   "hash": "041ea0f66039a044",
   "zh": "「問尤洛便知！」"
  },
  {
   "hash": "beffbc7031122452",
   "zh": "「汝豈不識尤洛？」"
  },
  {
   "hash": "11b195b2e00da104",
   "zh": "「在下乃他昔日學徒葛雯妮絲。」"
  },
  {
   "hash": "45627c193a5b605c",
   "zh": "業"
  },
  {
   "hash": "69cc27a945e3fb09",
   "zh": "「昔我曾為尤洛之徒，後他決意退隱。」"
  },
  {
   "hash": "0db5a0fc395b10db",
   "zh": "「如今此店歸我，所售之弓皆由我親製！」"
  },
  {
   "hash": "8ad8d0a32be2e5c2",
   "zh": "\\\"「然店名仍為@尤洛之弓，以敬師父。」"
  },
  {
   "hash": "454084ea8ea5eb5c",
   "zh": "尤洛謙遜地紅了臉。"
  },
  {
   "hash": "8b0d9772045c66f6",
   "zh": "魔像"
  },
  {
   "hash": "626e249802789eb5",
   "zh": "「聽士兵說，@魔像族乃強悍敵手。」"
  },
  {
   "hash": "1553feb1a9dc2614",
   "zh": "「有些魔像迅如疾風，攻擊宛若雷霆閃電！」"
  },
  {
   "hash": "b21fdc027de3e2c3",
   "zh": "「魔像族另有一種怪異可怖之@武器。」"
  },
  {
   "hash": "3d730cf619e19878",
   "zh": "武器"
  },
  {
   "hash": "e91246ce23379bea",
   "zh": "「名曰飛去來器，乃極為奇特之遠程兵器。」"
  },
  {
   "hash": "994db0b84c57159f",
   "zh": "「擲出能擊中目標，又自行飛回擲者之手！」"
  },
  {
   "hash": "3d948781ba0e03c9",
   "zh": "「為禦此等魔法，士兵們選用堅固的不列顛尼亞之弓！」"
  },
  {
   "hash": "fd09d1c57e62dbf8",
   "zh": "尤洛"
  },
  {
   "hash": "4fabf7de6560b817",
   "zh": "她笑了笑。「在尤洛朋友面前，我不便多言他事。」"
  },
  {
   "hash": "5b479fe20cd33848",
   "zh": "「免得讓他臉紅！」"
  },
  {
   "hash": "bd098088d0a6ca97",
   "zh": "「不，我實不願在師父背後議論他。」"
  },
  {
   "hash": "eb956cf0bd3433ac",
   "zh": "箭,弩矢"
  },
  {
   "hash": "c795c35c7d8516ee",
   "zh": "「是，平日皆有存貨。」"
  },
  {
   "hash": "4b421252bc4cb4ab",
   "zh": "「然近來因@魔像族戰事而短缺。」"
  },
  {
   "hash": "93f6e25e2e1724f2",
   "zh": "「往北去找製箭匠林恩吧。」"
  },
  {
   "hash": "490a0eadb716da52",
   "zh": "林恩"
  },
  {
   "hash": "8d9c5528d285733d",
   "zh": "「林恩乃好箭匠，常為我供應@箭與@弩矢。」"
  },
  {
   "hash": "7bc14c0ff403c8ef",
   "zh": "「不過如今皆售予士兵，已無存貨。」"
  },
  {
   "hash": "5b33bbef512af60a",
   "zh": "三連"
  },
  {
   "hash": "e2a6bc231592c6ff",
   "zh": "「我只剩一具三連弩可賣，恐怕。」"
  },
  {
   "hash": "f33a6973dc0aee22",
   "zh": "「半年後再來，可能還有一具。」"
  },
  {
   "hash": "008a2f19137d94c3",
   "zh": "別"
  },
  {
   "hash": "fb9a6170acad1dfa",
   "zh": "「諸位，珍重。」"
  },
  {
   "hash": "d770291af15bcd43",
   "zh": "「汝亦珍重！」"
  },
  {
   "hash": "88c63c982f7f1945",
   "zh": "「尤洛，本月分潤我不久將再尋汝交付！」"
  },
  {
   "hash": "57f6e4ebe2f3306a",
   "zh": "「請再說？」"
  },
  {
   "hash": "5e5c44896130b651",
   "zh": "「啊，汝果是行家。」"
  },
  {
   "hash": "6471e1ad3110236e",
   "zh": "「三連弩乃一奇物。」"
  },
  {
   "hash": "a983204c5dd715fb",
   "zh": "「此附魔之器一發三矢！」"
  },
  {
   "hash": "9c123f67410d8b07",
   "zh": "「平時我絕不出售。」"
  },
  {
   "hash": "25ac7ec5b10878ce",
   "zh": "「然汝之任重大，我願讓汝——僅讓汝——購之。」"
  },
  {
   "hash": "d57cfcaad1cadc31",
   "zh": "「然須收四百金幣，恐怕。」"
  },
  {
   "hash": "04f396cfee0de060",
   "zh": "「汝可願購此兵器？」 "
  },
  {
   "hash": "08ed5807b58a118e",
   "zh": "是"
  },
  {
   "hash": "a5e9d1e636be598a",
   "zh": "「汝攜不動此物！」"
  },
  {
   "hash": "21d7c0b141ae86a7",
   "zh": "「汝財不足購之！」"
  },
  {
   "hash": "2f63eae9b56a934f",
   "zh": "「此物將留於此，待汝有需之時。」"
  },
  {
   "hash": "22a8c8e2b8bf6bd1",
   "zh": "「抱歉，諸位皆無我所需之物。」"
  },
  {
   "hash": "d61144d8628164d8",
   "zh": "「啊，$Y有趣物……」"
  },
  {
   "hash": "42c1fbc2b3fd0c7f",
   "zh": "#1) $Y"
  },
  {
   "hash": "7bf2e7fe4fc43e63",
   "zh": "「諸位何人？」 "
  },
  {
   "hash": "4db5477c4189df47",
   "zh": "#0) "
  },
  {
   "hash": "62aaff84f5558c2c",
   "zh": "「何物？」 "
  },
  {
   "hash": "0151a6fe6165af39",
   "zh": "「$Y，七金幣換此$0，可乎？」 "
  },
  {
   "hash": "08ed5807b58a118e",
   "zh": "是"
  },
  {
   "hash": "1ec1b2840556664e",
   "zh": "「那麼，改日再說吧。」"
  },
  {
   "hash": "57187897e5919d33",
   "zh": "「那麼，可有他物？」"
  },
  {
   "hash": "23b088837d4b0ea0",
   "zh": "「成交！」$N付$Y七金幣，取走$0。"
  },
  {
   "hash": "d714edfefe55a466",
   "zh": "「改主意了，是嗎？」"
  },
  {
   "hash": "311dc8d8111ea702",
   "zh": "#2) $Y"
  },
  {
   "hash": "7bf2e7fe4fc43e63",
   "zh": "「諸位何人？」 "
  },
  {
   "hash": "4c8e66177eef3e4b",
   "zh": "#0) $0"
  },
  {
   "hash": "62aaff84f5558c2c",
   "zh": "「何物？」 "
  },
  {
   "hash": "3978435bc2b6d4bf",
   "zh": "「此$1售#1金幣。」"
  },
  {
   "hash": "09e61d3bae68d9cc",
   "zh": "「$Y可有興趣？」 "
  },
  {
   "hash": "08ed5807b58a118e",
   "zh": "是"
  },
  {
   "hash": "17b442a747cda944",
   "zh": "「然$Y，此將令汝負重過甚！」"
  },
  {
   "hash": "3d5e71454a4edb9e",
   "zh": "「絕妙！」"
  },
  {
   "hash": "b3984455c20f3402",
   "zh": "收下$Y之金後，$N交付$1。"
  },
  {
   "hash": "b308280d0a2bd0e3",
   "zh": "「然$Y，汝金不足！」"
  },
  {
   "hash": "7a5927a16a5f7b53",
   "zh": "「$Y，汝金不足。」"
  },
  {
   "hash": "6c57f9127b7b4393",
   "zh": "她向尤洛眨眼。「然此次我可信汝賒帳！」"
  },
  {
   "hash": "77238703e78e81a0",
   "zh": "「$Y，抱歉，即便對汝，我亦不能再賒。」"
  },
  {
   "hash": "75db6adffcac4233",
   "zh": "「@魔像族戰事使我貨品大為熱銷！」"
  },
  {
   "hash": "16565119b102f66b",
   "zh": "弓"
  },
  {
   "hash": "ea41af61f3bbbd91",
   "zh": "十字弓"
  },
  {
   "hash": "eae1d7cd31b04356",
   "zh": "投石"
  },
  {
   "hash": "6df76bfd66904a50",
   "zh": "魔法弓"
  }
 ],
