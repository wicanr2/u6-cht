 "translations": [
  {
   "hash": "9931f30cd850ecc0",
   "zh": "農夫納許",
   "note": "NPC name"
  },
  {
   "hash": "5864614e1b2142e7",
   "zh": "面容憔悴、神色疲憊之有翼魔像。",
   "note": "DESC"
  },
  {
   "hash": "27ac1de971326e23",
   "zh": "魔像嘶喊：「An-bal-sil-fer！Des-lem, klep lem！」",
   "note": "魔像語保留"
  },
  {
   "hash": "28cd0990beb8261d",
   "zh": "魔像嘶喊：「偽先知！工人們，攻擊！」",
   "note": "旁白嵌入"
  },
  {
   "hash": "e5ec39200835ba49",
   "zh": "「$T好，高貴之$P。再度蒞臨，深感榮幸！」"
  },
  {
   "hash": "8ed928a9e7f3a534",
   "zh": "「真令吾大感震驚！」"
  },
  {
   "hash": "17d2bcd1824ddf28",
   "zh": "「對偽先知之高貴，吾深懷敬佩。」"
  },
  {
   "hash": "057c0ed01b47916c",
   "zh": "「以汝之犧牲榮耀吾族！」"
  },
  {
   "hash": "08f320a89dd07ce1",
   "zh": "「敢問汝之名諱，以便適切地稱呼汝？」"
  },
  {
   "hash": "f0eccb885482b55f",
   "zh": "「$0蒞臨，深感榮幸。」"
  },
  {
   "hash": "d09a6a0ca3e33449",
   "zh": "「吾名納許·烏斯-阿爾布-瓦斯-蘭，即農夫@Leader統帥納許。」"
  },
  {
   "hash": "319ae44dbf950861",
   "zh": "「@lead領導@wingless無翼者，即看守這些田地的工匠魔像。」"
  },
  {
   "hash": "620fe7b5064c5577",
   "zh": "「然吾之@harvests收成一向不佳。」"
  },
  {
   "hash": "55ede02098742fee",
   "zh": "「試圖給予@wingless無翼者自由，",
   "note": "前半"
  },
  {
   "hash": "cd7293622905351e",
   "zh": "然仍被迫在其工作中加以指引。」",
   "note": "後半"
  },
  {
   "hash": "de8ead16130c72e1",
   "zh": "「吾對無翼者之仁厚，遠超吾族大多數人。」"
  },
  {
   "hash": "c2f5ad61ad34ef36",
   "zh": "「吾認為無翼者不應僅因智力不如吾等便遭奴役。」"
  },
  {
   "hash": "61065cb69ff66de7",
   "zh": "「有時因時勢艱難，不得不親自下田耕作。」"
  },
  {
   "hash": "105aa5dae20b4a02",
   "zh": "「真希望吾的田地能像西邊鄰居@Krill農夫克里爾那樣豐收。」"
  },
  {
   "hash": "39d3e5411ac366e9",
   "zh": "「吾為農夫克里爾對工人如此嚴苛而感到羞恥。」"
  },
  {
   "hash": "60025a7e64f86614",
   "zh": "「對他漠視工人的想法與感受，吾深感震驚。」"
  },
  {
   "hash": "4ada3277ec482a0f",
   "zh": "「此番交談令吾深感榮幸，高貴之$P。」"
  },
  {
   "hash": "24ab14ce7ff797db",
   "zh": "「坦承難以理解汝之口音。請問$Z是何意？」"
  }
 ],
 "glossary_additions": {
  "people": {
   "Farmer Nash": "農夫納許",
   "Farmer Krill": "農夫克里爾"
  },
  "places": {}
 },
 "translator_notes": "農夫納許為仁厚的魔像農場主，對無翼工匠較為同情，與鄰居克里爾形成對比。魔像 To+動詞 語法一律文言化。"
}
