{
 "_meta": {},
 "translations": [
  {
   "hash": "ac3ff419ee121a18",
   "zh": "謙遜祭壇",
   "note": "NPC name — 神殿祭壇"
  },
  {
   "hash": "2b2fbc8a2fc3fc28",
   "zh": "謙遜之祭壇。",
   "note": "DESC"
  },
  {
   "hash": "4dea77d1e904b054",
   "zh": "當你跪在祭壇前，一個神秘的聲音在你腦中迴響。",
   "note": "旁白"
  },
  {
   "hash": "c47dab3776c2cdf3",
   "zh": "「汝對謙遜仍有許多須學習之處。」",
   "note": "低階評語"
  },
  {
   "hash": "e19d5bfc006b176a",
   "zh": "「汝之行為展現了令人欽佩的謙遜。」",
   "note": "中階評語"
  },
  {
   "hash": "52b84eff61efe845",
   "zh": "「汝之行為可為眾人表率。」",
   "note": "高階評語"
  },
  {
   "hash": "bf3b28dcc608d94c",
   "zh": "你希望在此祭壇冥想嗎？",
   "note": "旁白提示，尾隨空格保留"
  },
  {
   "hash": "50e77701c0136675",
   "zh": "#2。$Y",
   "note": "控制符保留"
  },
  {
   "hash": "4f97e949580d4b79",
   "zh": "「誰來冥想？」",
   "note": "尾隨空格保留"
  },
  {
   "hash": "20697d72b5a3db29",
   "zh": "「覆誦謙遜真言。」"
  },
  {
   "hash": "ffe5b426e8468f7f",
   "zh": "「$Z…… $Z……」",
   "note": "真言提示第一次"
  },
  {
   "hash": "ffe5b426e8468f7f",
   "zh": "「$Z…… $Z……」",
   "note": "真言提示第二次"
  },
  {
   "hash": "ffe5b426e8468f7f",
   "zh": "「$Z…… $Z……」",
   "note": "真言提示第三次"
  },
  {
   "hash": "7bb136b0a81f241e",
   "zh": "「這土地上最謙卑的市民，",
   "note": "聖言第一段（未閉合）"
  },
  {
   "hash": "d5c75e89fd48789b",
   "zh": "當披上正義大義的鎧甲，",
   "note": "聖言第二段"
  },
  {
   "hash": "f52eee1410c02ad4",
   "zh": "比所有謬誤之眾更為強大。」",
   "note": "聖言第三段（閉合）"
  },
  {
   "hash": "9d3c825b4abf0064",
   "zh": "你未能獲得啟示。",
   "note": "旁白"
  },
  {
   "hash": "05865a534ee33600",
   "zh": "$Y提升了一個等級！",
   "note": "升級旁白（謙遜無特定能力提升，故用！而非……）"
  },
  {
   "hash": "cb93cedb92f1135f",
   "zh": "「此刻此地，汝已無更多可學。」"
  },
  {
   "hash": "36b180a0ddf1311a",
   "zh": "「待汝的旅程更進一步，再行回返。」"
  }
 ],
 "glossary_additions": {
  "people": {},
  "places": {}
 },
 "translator_notes": "謙遜神殿，真言 lum（不翻譯）。謙遜是唯一不賦予原則衍生屬性的德行——需單獨修行，無法與其他德行組合。聖言三段合一引自 William Jennings Bryan，謙卑之人因正義而強大的主題。升級符號用「！」而非「……」，呼應本神殿的特殊性。"
}
