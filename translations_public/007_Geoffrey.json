{
 "_meta": {},
 "translations": [
  {
   "hash": "c8ae56143d79285e",
   "zh": "傑佛瑞",
   "note": "NPC name"
  },
  {
   "hash": "c6ae48b131408ef8",
   "zh": "高大堂堂之武將。",
   "note": "DESC"
  },
  {
   "hash": "9924e35465c1da87",
   "zh": "「汝最好先去面見不列顛王陛下，餘事容後再議。」"
  },
  {
   "hash": "b28c9b3c4285b897",
   "zh": "「見汝甚悅，$P。或汝能成就他人未竟之績。」",
   "note": "避『許』『功』5C trail"
  },
  {
   "hash": "f55e34812d82cf48",
   "zh": "「吾已遣十名兵卒，欲自魔像族手中奪回慈悲聖壇。」"
  },
  {
   "hash": "e43b3cc4beb23c8c",
   "zh": "「惜哉，敗羽而歸。」"
  },
  {
   "hash": "17cf51b3beac0e14",
   "zh": "「生還者目下正在海灣鎮休養。」"
  },
  {
   "hash": "50048defa0175dc3",
   "zh": "「汝宜先與彼等一談。」"
  },
  {
   "hash": "e814b7704199944a",
   "zh": "「彼等所知，或可助汝一臂之力。」",
   "note": "避『許』5C trail"
  },
  {
   "hash": "0a2e6964f1cfd3f5",
   "zh": "「吾不諱言，深恐大禍將至。」"
  },
  {
   "hash": "dde5491c26f26dbb",
   "zh": "「魔像族敵勢凶猛，蔓延又快……」"
  },
  {
   "hash": "d23734001cc2f10b",
   "zh": "「恐怕王國末日已近矣。」"
  },
  {
   "hash": "a0da8540c4b593f0",
   "zh": "「祝汝武運昌隆，吾之祈禱與汝同行。」"
  },
  {
   "hash": "b47b5cc430ce232f",
   "zh": "「莫再耗時空談……」"
  },
  {
   "hash": "ff522558b3f00206",
   "zh": "「天曉得，當此言之際，魔像族正在何處為非作歹？」*",
   "note": "尾 * 控制符保留"
  },
  {
   "hash": "421893b92d79443c",
   "zh": "「願汝已至海灣鎮，與葛爾坦一晤。」"
  }
 ],
 "glossary_additions": {
  "people": {
   "Gertan": "葛爾坦"
