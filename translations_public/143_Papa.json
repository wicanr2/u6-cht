 "_meta": {},
 "translations": [
  {
   "hash": "b5087d57bea38f59",
   "zh": "一頭巨大的雄性獨眼巨人。",
   "note": "DESC"
  },
  {
   "hash": "4ce7561498793e78",
   "zh": "「哦，哦。你回來了！」"
  },
  {
   "hash": "c095bc3ec297cf41",
   "zh": "「你帶來好魚。」"
  },
  {
   "hash": "49a6e7a452f6451b",
   "zh": "「帶更多？」"
  },
  {
   "hash": "84c61bde49c72f06",
   "zh": "「沒有魚？」獨眼巨人看起來很難過。"
  },
  {
   "hash": "7fa989c5136c3729",
   "zh": "「哦！你帶魚了？」"
  },
  {
   "hash": "5b8b3a8d7e43b96a",
   "zh": "「去弄@fish（魚）！」"
  },
  {
   "hash": "c7a7794539a15819",
   "zh": "「你是誰？」"
  },
  {
   "hash": "dec61a65a8edecb6",
   "zh": "「我獨眼巨人。」"
  },
  {
   "hash": "ad51cba94652f888",
   "zh": "「@Tiny（小不）點叫我『爸爸』。」"
  },
  {
   "hash": "c383edb4737cd114",
   "zh": "「在岸邊找到他。」"
  },
  {
   "hash": "50b20d5a63cbbe22",
   "zh": "「一眼的小不點很久以前死了。」",
   "note": "獨眼巨人自己的孩子"
  },
  {
   "hash": "5e23cd86a5284944",
   "zh": "「女的想要小孩，所以留下小不點。」"
  },
  {
   "hash": "29e21987112f3d84",
   "zh": "「不像一眼小不點那樣強壯。」"
  },
  {
   "hash": "11c611cd104a3a7e",
   "zh": "「住這！吃東西，打獵！」"
  },
  {
   "hash": "c86f83285afc3c23",
   "zh": "「地下室不能去。@Locked（鎖著）。」"
  },
  {
   "hash": "fc4d67f20e6007b0",
   "zh": "「有鑰匙。要鑰匙？」"
  },
  {
   "hash": "d0c926928c77900b",
   "zh": "「沒有鑰匙。」"
  },
  {
   "hash": "cbcd78f9bb4c0782",
   "zh": "「我的。在@cellar（地）下室。拿不到！」"
  },
  {
   "hash": "eb202cb4c0e4cacc",
   "zh": "「魚好吃。」"
  },
  {
   "hash": "a9c51955eead2332",
   "zh": "「喜歡吃很多魚！」"
  },
  {
   "hash": "52877b6e7a01c184",
   "zh": "「再來，帶",
   "note": "下接more fish"
  },
  {
   "hash": "472b39930d474fe0",
   "zh": "更多"
  },
  {
   "hash": "573b5fd86307230c",
   "zh": "魚！」"
  },
  {
   "hash": "b6422d8c3fb4fa73",
   "zh": "「$Z是什麼意思？」"
  },
  {
   "hash": "2b16896806fc6524",
   "zh": "「要魚！」"
  },
  {
   "hash": "509271bd35706d74",
   "zh": "「用竿子，釣魚。」"
  },
  {
   "hash": "858cf6072956bf4d",
   "zh": "「要鑰匙，帶魚！」"
  },
  {
   "hash": "b86fd59196c0c722",
   "zh": "「為什麼問了不想要？」"
  },
  {
   "hash": "f8b0418e2251a16d",
   "zh": "「魚在哪？沒聞到魚味。」"
  },
  {
   "hash": "fb4c3178b58e3b09",
   "zh": "「好魚！好朋友！」"
  },
  {
   "hash": "8f32371b1305fe00",
   "zh": "「好魚！來，鑰匙。」"
  },
  {
   "hash": "11779831909811b6",
   "zh": "獨眼巨人遞給你一把巨大的生鏽鑰匙。"
  }
 ],
 "glossary_additions": {
  "people": {
   "Papa": "爸爸"
  },
  "places": {}
 },
 "translator_notes": "爸爸是雄性獨眼巨人，說話極簡短，省略代詞和謂語，呈現智力簡單的特徵。「tiny one」（小不點）指人類孩子Myles。用魚換鑰匙是重要互動。"
}
