{
 "_meta": {},
 "translations": [
  {
   "hash": "93005ba1cfcdeba4",
   "zh": "兵器師",
   "note": "NPC name — glossary 已有"
  },
  {
   "hash": "28a0fc41cac63520",
   "zh": "年輕且神色緊張之魔像。",
   "note": "DESC"
  },
  {
   "hash": "1a63758ba604a631",
   "zh": "「偽先知！」魔像嘶喊。「護衛！護衛！」",
   "note": "旁白嵌入"
  },
  {
   "hash": "7a10cd0b74226061",
   "zh": "「An-bal-sil-fer！」魔像嘶喊。「Agra-lem！Agra-Lem！」",
   "note": "魔像語保留"
  },
  {
   "hash": "bae0404cc0c3dc53",
   "zh": "魔像忽然意識到自己手持武器，隨即發起攻擊！",
   "note": "旁白"
  },
  {
   "hash": "99282211b38463a6",
   "zh": "「問如何可助尊者？」"
  },
  {
   "hash": "45c1dad0d2064ee6",
   "zh": "「偽先知！」"
  },
  {
   "hash": "23f0f44cf81154e6",
   "zh": "「感謝汝即將到來的犧牲。」"
  },
  {
   "hash": "cfa1ad0519fb99da",
   "zh": "「對汝之高貴與勇氣，深表敬意。」"
  },
  {
   "hash": "dc07f8c8637cbf24",
   "zh": "「吾不明白那是何意。」"
  },
  {
   "hash": "ec9e85d7c5fc6050",
   "zh": "「製作這些物品，供@all眾人使用。」"
  },
  {
   "hash": "77de0a27deed3b4e",
   "zh": "「將這些物品贈予任何有需要的魔像。」"
  },
  {
   "hash": "ae8365feb5b3fc94",
   "zh": "「亦邀汝瀏覽吾的@wares物品。」"
  },
  {
   "hash": "ce4ffc9536465585",
   "zh": "「問汝是否對其中有感興趣者？」"
  },
  {
   "hash": "c7ed6b5759abfd7b",
   "zh": "「目前僅有少數物品可供取用。」"
  },
  {
   "hash": "b06877effd4d59fd",
   "zh": "「吾之技藝遠不如先師@master。」"
  },
  {
   "hash": "2cbbf64f49356e0f",
   "zh": "「真希望手邊有更多飛去來器，好再送汝一枚。」"
  },
  {
   "hash": "41bdb24ddfa6d35c",
   "zh": "「可惜吾的醒神塵存量極少。」",
   "note": "zu ylem dust = 魔像藥粉，令人昏迷的粉末"
  },
  {
   "hash": "01a088534fc8aec7",
   "zh": "「吾認為他是吾族之恥！」",
   "note": "兵器師評論工匠"
  },
  {
   "hash": "8852ee9a21d0ddc1",
   "zh": "「尤其，吾認為他是吾亡師之@dishonor恥辱！」"
  },
  {
   "hash": "18619d30c0955bda",
   "zh": "「他的自憐使吾等所有人的失去與哀傷都變得廉價。」"
  },
  {
   "hash": "93f73d9be0dd4b5b",
   "zh": "「吾失去了@master先師，他如父一般。」"
  },
  {
   "hash": "f27087a594714fa6",
   "zh": "「然吾仍保持克制，保持勤勉。」"
  },
  {
   "hash": "1ca7510a515bdfd2",
   "zh": "「最重要的是，保持對生命的熱情。」",
   "note": "三原則：克制、勤勉、熱情"
  },
  {
   "hash": "826cb6841a81bd8a",
   "zh": "「吾認為工匠棄守吾族原則，是對吾等所有人的侮辱。」"
  },
  {
   "hash": "409019a5a683c353",
   "zh": "「吾認為工匠需要到@catacombs地下聖所走一趟。」"
  },
  {
   "hash": "b147ce246b089af9",
   "zh": "「是的，吾自身亦曾在久遠以前前往拜訪。」"
  },
  {
   "hash": "576f2d27eea6f0de",
   "zh": "「在那裡，有供奉吾族三大原則的聖壇：克制、熱情與勤勉。」"
  },
  {
   "hash": "d9ed747dffedd8ef",
   "zh": "「向這些聖壇祈禱冥想，可獲得新的領悟。」"
  },
  {
   "hash": "e12972ef450424c5",
   "zh": "「吾已不記得地下聖所在何處了。」"
  },
  {
   "hash": "692441a8ea295a08",
   "zh": "「須由@Singularity獨身者神殿指引前往。」"
  },
  {
   "hash": "dd3de4d00c77ab61",
   "zh": "「在北方山中可尋得。」"
  },
  {
   "hash": "7b747cc6e882083e",
   "zh": "「然若汝想前往，建議設法@fly飛翔！」"
  },
  {
   "hash": "edec891476c2cae0",
   "zh": "「神殿無法徒步到達；唯有飛越山峰方可抵達。」"
  },
  {
   "hash": "dc1ea3b78e9ea00e",
   "zh": "「此乃強效但危險之藥劑！」"
  },
  {
   "hash": "c2fa39f2fe6ae320",
   "zh": "「服之可使魔像武士化身為無法阻擋的戰士！」"
  },
  {
   "hash": "85526a37ac44e320",
   "zh": "「然戰鬥結束後，必然致死。」"
  },
  {
   "hash": "abc58450c042c63a",
   "zh": "「由住在西南方的@charmer馴蛇者所製。」"
  },
  {
   "hash": "8ce3bf2e52bf19f4",
   "zh": "「是的，若汝有興趣，建議前往拜訪。」"
  },
  {
   "hash": "f66cd853b757ca7c",
   "zh": "「召蛇號角實為壯觀之物！」"
  },
  {
   "hash": "64f2c80b59c63707",
   "zh": "「醒神塵由如今已無處可尋之植物製成。」"
  },
  {
   "hash": "14d3d01654a54df8",
   "zh": "「然吾知曉@disasters大災變帶來了遠更嚴重的影響。」"
  },
  {
   "hash": "fab7783acd3fd9f7",
   "zh": "「吾對此物興趣甚淡。」"
  },
  {
   "hash": "0b4d8b2e7f69ccaf",
   "zh": "「願汝之長久努力與力量引領至成功！」",
   "note": "道別語，兵器師版魔像祝辭"
  },
  {
   "hash": "b2013d061f019425",
   "zh": "「吾不過是個普通@weaponsmith兵器師，偽先知。」"
  },
  {
   "hash": "aefaefa79bdcae73",
   "zh": "「吾無名字，此乃吾身份地位之應然。」"
  },
  {
   "hash": "e170f18956f45639",
   "zh": "「是的，汝應知曉大災變吧？」"
  },
  {
   "hash": "0f5af4050901a7e0",
   "zh": "「守則之書消失後的那場地震中，吾僅以一息之差倖存。」"
  },
  {
   "hash": "a84a5b55a90d442f",
   "zh": "「如今吾乃兵器師首席，雖然不久前吾還只是一介@apprentice學徒。」"
  },
  {
   "hash": "44453da65b41ac63",
   "zh": "「對先師在@disasters大災變中喪命，吾深感悲痛。」"
  },
  {
   "hash": "1f1ea5f5ebccc06a",
   "zh": "「然仍於逆境中奮進。」"
  },
  {
   "hash": "6f1f47450a1c8570",
   "zh": "「斷不會像那個無用的@goodscrafter工匠一樣，失去對生命的所有熱情！」"
  },
  {
   "hash": "be3c9feadeee7c74",
   "zh": "「真希望能出去冒險……」"
  },
  {
   "hash": "9a98fc970ecbef8d",
   "zh": "「然吾獻身於吾之重要@work職責。」"
  },
  {
   "hash": "8904168617d7fe7f",
   "zh": "「吾只是個普通兵器師，對$Z一無所知。」"
  },
  {
   "hash": "9ad72508727f38b0",
   "zh": "「請汝到吾的鋪子來！」"
  },
  {
   "hash": "2afe4415fdc1650c",
   "zh": "「啊，見汝欣賞這些飛去來器，乃吾@master先師之作。」"
  },
  {
   "hash": "4e9088b08b54faa5",
   "zh": "「可惜吾自身無法製作飛去來器。」"
  },
  {
   "hash": "fcd2a60f414455a3",
   "zh": "「庫存所剩不多",
   "note": "前半（接後）"
  },
  {
   "hash": "07da0e07b4a02ac9",
   "zh": "。」"
  },
  {
   "hash": "93d75b6f8a83cd78",
   "zh": "，然願贈汝一枚。」"
  },
  {
   "hash": "f7b40ea80b56c17f",
   "zh": "你接受這份禮物嗎？",
   "note": "旁白提示"
  },
  {
   "hash": "4f40e77ddf4988a2",
   "zh": "你接過飛去來器時，夏米諾開口。",
   "note": "旁白"
  },
  {
   "hash": "a1f7e66616c70d60",
   "zh": "「確是件極有趣的武器，$G。」"
  },
  {
   "hash": "2f3f848434332be6",
   "zh": "「也許試煉結束後，吾可研究其用法。」"
  },
  {
   "hash": "917eedbd6888e98a",
   "zh": "魔像說：「問汝是否對其他物品感興趣？」",
   "note": "旁白嵌入"
  },
  {
   "hash": "0afab57502aedf60",
   "zh": "魔像遞給你一枚飛去來器。",
   "note": "旁白"
  },
  {
   "hash": "63efe6c0fdc02570",
   "zh": "魔像點頭。「是的，見汝已備有足夠的武器。」",
   "note": "旁白嵌入"
  },
  {
   "hash": "9ad72508727f38b0",
   "zh": "「請汝到吾的鋪子來！」"
  },
  {
   "hash": "772531002a62cdfb",
   "zh": "「是的，此乃非常有趣之武器。」"
  },
  {
   "hash": "96359dfebf431ef7",
   "zh": "「一小袋此粉末便能令大型獵物昏厥！」"
  },
  {
   "hash": "dac302feb1cb166f",
   "zh": "「獵人最常使用，可避免損傷獵物肉質。」"
  },
  {
   "hash": "a2728b36db378dbd",
   "zh": "「可惜，此粉末須以@plants如今已無處可尋之植物製成。」"
  },
  {
   "hash": "7535966c43b6390f",
   "zh": "「來，贈汝一份。」"
  },
  {
   "hash": "f7b40ea80b56c17f",
   "zh": "你接受這份禮物嗎？",
   "note": "旁白提示"
  },
  {
   "hash": "aff2dc49853b272c",
   "zh": "他遞給你一個小袋。「望汝得其所用。」",
   "note": "旁白嵌入"
  },
  {
   "hash": "4aa8c07260deaa0c",
   "zh": "魔像點頭。「理解汝之顧慮。」",
   "note": "旁白嵌入"
  },
  {
   "hash": "a056c1b160a47cd0",
   "zh": "「知曉醒神塵對未受訓練者之危險。」"
  }
 ],
 "glossary_additions": {
  "people": {},
  "places": {}
 },
 "translator_notes": "兵器師為年輕魔像，在大災變失去師父後自立為首席兵器師，對工匠的自憐深感不屑。遵守魔像三原則（克制、熱情、勤勉）。zu ylem dust 譯為「醒神塵」（實為昏迷粉末，但用字帶魔像語異文化感）。飛去來器、號角等道具詳細介紹保留。"
}
