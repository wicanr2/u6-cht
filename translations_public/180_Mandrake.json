{
 "_meta": {},
 "translations": [
  {
   "hash": "c9244f8d36be93f4",
   "zh": "曼德雷克",
   "note": "NPC name，曼德雷克根（毒茄蔘），吟遊詩人"
  },
  {
   "hash": "43eb616196686b81",
   "zh": "帽子上插著孔雀羽毛、風度翩翩的男子。",
   "note": "DESC"
  },
  {
   "hash": "78b0f9744c26ee96",
   "zh": "「歡迎，歡迎！每次見到新面孔都是一大樂事。」"
  },
  {
   "hash": "340a3fa14ab6c2b5",
   "zh": "「在下曼德雷克。敢問閣下如何稱呼？」"
  },
  {
   "hash": "e5f6a77ab1a45f75",
   "zh": "「幸會，$G，幸會。希望日後常有緣相見。」他向你狡黠地眨了眨眼。",
   "note": "旁白嵌入"
  },
  {
   "hash": "5398643774f07135",
   "zh": "「幸會，老兄！」"
  },
  {
   "hash": "ed23a720bba9dc64",
   "zh": "「你看起來像是懂得欣賞好@story故事的人。」"
  },
  {
   "hash": "f2eb724500f5c0d5",
   "zh": "「$P！好久不見了。是什麼風把你吹到這一帶來了？」"
  },
  {
   "hash": "1f60957571943dd5",
   "zh": "「先別管那個了。且讓在下唱首@song歌給你聽！」"
  },
  {
   "hash": "ca7fe0d3b09665cd",
   "zh": "「曼德雷克，朋友，曼德雷克。如同同名的@root根，但更高、更俊、更@louder響亮。」"
  },
  {
   "hash": "ad62529ec3d5dba6",
   "zh": "「那玩意兒長在沼澤，我這個人倒多半出沒在@taverns酒館。」"
  },
  {
   "hash": "6264eb6c1d040c44",
   "zh": "「久仰久仰。」"
  },
  {
   "hash": "a4ff7162fc313770",
   "zh": "「每家都去。」"
  },
  {
   "hash": "32f34b30efeeb8e7",
   "zh": "「墮落@Virgin聖女和劍與@Keg酒桶這兩家，粗獷吵鬧。」"
  },
  {
   "hash": "096b1edea201b6ff",
   "zh": "「藍@Bottle瓶子賣的是弗雷澤的@Folly蠢作——不列顛尼亞全境最好的麥酒。」"
  },
  {
   "hash": "91f31f3bce754037",
   "zh": "「不過貓的@Lair巢穴還是我的最愛。」"
  },
  {
   "hash": "77d91508a4cbbcb8",
   "zh": "「你應該嘗嘗！對你大有好處。」"
  },
  {
   "hash": "2722d7a3243999d4",
   "zh": "「就在海盜@Den巢穴——膽小鬼不宜前往。」"
  },
  {
   "hash": "244240cf4ccf5d5b",
   "zh": "「若是不知道在哪兒，我是不打算說的那種人。」"
  },
  {
   "hash": "84c89c4338c4e681",
   "zh": "「在@Jhelom那邊。那裡的人向來愛打架。」"
  },
  {
   "hash": "8021b1a1d1e7169b",
   "zh": "「那裡武士多。」"
  },
  {
   "hash": "aa769cd0e1647061",
   "zh": "「他們幾乎每晚都打架，但沒有惡意，純屬好玩。」"
  },
  {
   "hash": "a361aa9c676b5849",
   "zh": "「在@Moonglow月輝城。」"
  },
  {
   "hash": "ea31794e9a8ee5d4",
   "zh": "「@Derydlus常在那兒喝酒——那人喝酒的量比我見過的任何人都多。」"
  },
  {
   "hash": "9b2665bd57da0f5a",
   "zh": "「他不知多少次把我喝趴下了。」"
  },
  {
   "hash": "8fd6c7fd587fad99",
   "zh": "「那城太誠實，沒多少樂趣，但住著一些好人。」"
  },
  {
   "hash": "4d7bb93b022a6e41",
   "zh": "「你應該找@Penumbra半影算個命。」"
  },
  {
   "hash": "5963b7042c898b49",
   "zh": "「見到他代我問好。」"
  },
  {
   "hash": "4f5c20594ea7ba64",
   "zh": "「聽說她有奇異的@powers能力。」"
  },
  {
   "hash": "f92ede952e7a22b6",
   "zh": "「是的，@prophecy預言之天賦。」"
  },
  {
   "hash": "dbd97ef6833935e4",
   "zh": "「如是聽聞。」"
  },
  {
   "hash": "670612c3f9d51667",
   "zh": "「好地方！貓博士只要我唱歌就請我免費喝酒。」"
  },
  {
   "hash": "e81c1a987836a09f",
   "zh": "「他也愛各種遊戲。跟他提到我的名字，他準會好好招待你。」"
  },
  {
   "hash": "09c228592998da1d",
   "zh": "「在下走遍各地，把重要的@news消息傳遍王國——還有@tales故事和@songs歌謠。」"
  },
  {
   "hash": "d72554332222166c",
   "zh": "「若是你時間充裕，在下可以三樣都送上。」"
  },
  {
   "hash": "c9a8fc0b93672f67",
   "zh": "「在下最近的旅程以一種極為可怖的方式被打斷了。」"
  },
  {
   "hash": "e476fddcdeeeaf65",
   "zh": "「我被@gargoyles魔像抓走，帶到世界另一面，關了起來。」"
  },
  {
   "hash": "6fea50af6064537c",
   "zh": "「但幸運的是，其中一個幫我逃了出來。」"
  },
  {
   "hash": "0b42346c287d6c35",
   "zh": "「他只會說一點點我們的話，但我相信他說他的名字是「貝蘭」。」"
  },
  {
   "hash": "21e08d70d430a0fd",
   "zh": "「在下旅途中多次見識過魔像的手段。」"
  },
  {
   "hash": "577307257a41cc6b",
   "zh": "「我相信他們已佔領了八@virtues德的所有神殿。」"
  },
  {
   "hash": "f63e1ed9ed32b698",
   "zh": "「就是那些：誠實、慈悲、勇敢、正義、犧牲、榮譽、靈性和謙遜。」"
  },
  {
   "hash": "42eac618cae5398e",
   "zh": "「選了這麼一套@stuffy刻板的原則作基礎，就會這樣。」"
  },
  {
   "hash": "2a95da465c17b1f1",
   "zh": "「真實、愛與勇氣……哈！」"
  },
  {
   "hash": "1361a7ff860226cb",
   "zh": "「若由我來定，我會選酒、女人和歌謠。」"
  },
  {
   "hash": "76e6675f9d10709b",
   "zh": "「想想那些原則會@lead引出什麼德行！」"
  },
  {
   "hash": "39de77b4858aecd8",
   "zh": "「在下仔細想過了……」"
  },
  {
   "hash": "8707fc169e1f154c",
   "zh": "「酒、女人和歌謠這三大原則，將衍生出八種德行：",
   "note": "前半，與下一段合"
  },
  {
   "hash": "10c7b88543151cd0",
   "zh": "醉意、感官、和諧、情慾、慵懶、歡舞、縱情與歡樂。」",
   "note": "後半"
  },
  {
   "hash": "bd07338fe31406e0",
   "zh": "「這才是個宜居好世界的基礎！」"
  },
  {
   "hash": "1a6d7199cf27b1c7",
   "zh": "「這就要走了，$G？在下正享受著你的陪伴呢。」他深深一鞠躬，吻了吻你的手。",
   "note": "旁白嵌入"
  },
  {
   "hash": "bb7316d00b14d6c8",
   "zh": "「好啦，$P，很高興你來找我聊天。下次再找機會敘敘舊。」"
  },
  {
   "hash": "19a80cd9d44d9bad",
   "zh": "「下次見面，在下很樂意再為你唱一首。」"
  },
  {
   "hash": "240c00c0900c0438",
   "zh": "「或許改天再告訴你。」"
  },
  {
   "hash": "36399245aa11bca8",
   "zh": "「哎，何必管這麼無聊的事？換個@song歌怎麼樣？」"
  },
  {
   "hash": "8ceb56f2abfc0510",
   "zh": "「肚子飽、酒囊也飽，在下才唱得好。」"
  },
  {
   "hash": "f8be1cdf3055a960",
   "zh": "「你願意捐個一兩個銅板嗎？」",
   "note": "尾隨空格保留"
  },
  {
   "hash": "e81cbfbbba61bbd5",
   "zh": "「悉聽尊便。」"
  },
  {
   "hash": "646978bda1b30720",
   "zh": "你給他多少？",
   "note": "旁白提示"
  },
  {
   "hash": "4434441e8fd826d8",
   "zh": "你沒有那麼多錢。",
   "note": "旁白"
  },
  {
   "hash": "645d30bc704a602d",
   "zh": "「多謝好意。」"
  },
  {
   "hash": "a3e1419eed983114",
   "zh": "「好，開始了！」"
  },
  {
   "hash": "f43c35e4db9a076c",
   "zh": "「巨龍渾身鱗片，",
   "note": "歌謠第一節第一行"
  },
  {
   "hash": "028a0b12998bbdca",
   "zh": "噴嚏一打便吐火。",
   "note": "第一節第二行"
  },
  {
   "hash": "00a35f3698527371",
   "zh": "與多少勇騎士廝殺，",
   "note": "第一節第三行"
  },
  {
   "hash": "b4f11edbeff84fb5",
   "zh": "任意縱橫天下。」",
   "note": "第一節第四行"
  },
  {
   "hash": "f48b7d8c94d5bf4c",
   "zh": "「豪豬先生一身刺，",
   "note": "歌謠第二節第一行"
  },
  {
   "hash": "9bb553cc6dd16d34",
   "zh": "令他與夫人苦惱不已。",
   "note": "第二節第二行"
  },
  {
   "hash": "3b640b189f1b478f",
   "zh": "他心中最渴盼之事，",
   "note": "第二節第三行"
  },
  {
   "hash": "82a3684899872fc5",
   "zh": "不過是她的一個甜吻。」",
   "note": "第二節第四行"
  },
  {
   "hash": "f1fc4cf695a96a67",
   "zh": "「吉普賽女孩與蝴蝶，",
   "note": "歌謠第三節第一行"
  },
  {
   "hash": "f0a544b42716659b",
   "zh": "在林中嬉戲玩耍，",
   "note": "第三節第二行"
  },
  {
   "hash": "691b38d4320900dd",
   "zh": "我見到她們，不禁驚嘆：「哎呀！",
   "note": "第三節第三行"
  },
  {
   "hash": "95efed9a3dbf075e",
   "zh": "真是個晴好天氣！」」",
   "note": "第三節第四行，雙引號：外層歌謠，內層感嘆"
  },
  {
   "hash": "b1ec682c77781159",
   "zh": "「或許在下的故事值幾個銅板？」",
   "note": "尾隨空格保留"
  },
  {
   "hash": "e81cbfbbba61bbd5",
   "zh": "「悉聽尊便。」"
  },
  {
   "hash": "646978bda1b30720",
   "zh": "你給他多少？",
   "note": "旁白提示"
  },
  {
   "hash": "4434441e8fd826d8",
   "zh": "你沒有那麼多錢。",
   "note": "旁白"
  },
  {
   "hash": "937133696f59d73c",
   "zh": "「你真是太慷慨了。」"
  },
  {
   "hash": "0bb6b28963a7f28c",
   "zh": "曼德雷克說了許久的故事，聽著聽著你竟渾然忘了時間。",
   "note": "旁白"
  },
  {
   "hash": "662557d6ff84540b",
   "zh": "他說起駛落世界邊緣的船，說起地震、瘋狂術士和激烈戰鬥。",
   "note": "旁白"
  },
  {
   "hash": "084b2ad70e073cb3",
   "zh": "他講述能凝固時間的咒術、尋得飛行之道的人，以及靈火的奇異秘密。",
   "note": "旁白"
  },
  {
   "hash": "be8ab99462108e52",
   "zh": "他說王道上有兩支吉普賽隊伍往來，常被人互相搞混。",
   "note": "旁白"
  },
  {
   "hash": "0a14d7d5cd200609",
   "zh": "他說起曾令人聞風喪膽的海盜船帝國號，以及旱地中可以找到的巨大螞蟻。",
   "note": "旁白"
  },
  {
   "hash": "38da144a1e40fd20",
   "zh": "你腦中充滿了奇異的幻象。",
   "note": "旁白"
  },
  {
   "hash": "3ab0464dd33b6f11",
   "zh": "但最終，",
   "note": "旁白前半（隊伍版，與下一段合）"
  },
  {
   "hash": "e660185534604320",
   "zh": "他注意到杜普雷已開始打盹，便決定為故事畫下句點。",
   "note": "旁白後半（隊伍版）"
  },
  {
   "hash": "24e4edc03fa913a3",
   "zh": "故事就此落幕。",
   "note": "旁白（單人版，接在 But finally 之後）"
  }
 ],
 "glossary_additions": {
  "people": {
   "Mandrake": "曼德雷克",
   "Derydlus": "戴瑞德拉斯"
  },
  "places": {
   "Cat's Lair": "貓的巢穴"
  }
 },
 "translator_notes": "曼德雷克為風流才子型吟遊詩人，語氣輕佻自傲，以「在下」自稱增添文人氣息。三首歌謠以散文詩體翻譯，保留幽默感：龍打噴嚏吐火、豪豬刺妨礙接吻、吉普賽女孩賞天氣。「另類八德」（酒女歌）為核心笑料，翻譯保留原文滑稽哲學感。Beh Lem 協助逃脫情節與 183_Captain John 互相呼應。"
}
