 "_meta": {},
 "translations": [
  {
   "hash": "008da02b42052c76",
   "zh": "手持酒杯的英俊年輕男子。",
   "note": "DESC"
  },
  {
   "hash": "5f1628fcab19c137",
   "zh": "「你好，」他說，伸出一雙纖細的手。"
  },
  {
   "hash": "3e5974c1fe06a33e",
   "zh": "「我以前見過你的臉，」他說，將頭歪向一側。"
  },
  {
   "hash": "785154291145a91e",
   "zh": "「你需要什麼？」"
  },
  {
   "hash": "0083a45fc4b2a27b",
   "zh": "「@法倫。」"
  },
  {
   "hash": "22474e957a024a7f",
   "zh": "「@醉鬼@法倫，有些人這樣叫我。」他向你眨眼。"
  },
  {
   "hash": "5ef6c623c4f70122",
   "zh": "「只是開玩笑。」他展顏而笑。"
  },
  {
   "hash": "a3ba88a7c72085a4",
   "zh": "「你也許注意到了我和我@姐姐之間的相似之處。」"
  },
  {
   "hash": "75a1607c19f1ec15",
   "zh": "「@史黛芬妮是個美麗的女孩。」"
  },
  {
   "hash": "11904afbec252634",
   "zh": "「你見過她嗎？那你就知道她是@盲人了。」"
  },
  {
   "hash": "2ae505dff63844df",
   "zh": "「是的，打從出生就這樣了。」"
  },
  {
   "hash": "b13a33bb911060c8",
   "zh": "「對她而言，就像生來是個@魔像族一樣。」"
  },
  {
   "hash": "3579735c5c3b3ccf",
   "zh": "「她不知道別種生活。她的命運就是盡力應對自己的處境。」"
  },
  {
   "hash": "e65eeafa6ff3bce2",
   "zh": "「在這一點上她和你我沒有分別。」他停頓片刻，整理思緒。"
  },
  {
   "hash": "eae6c5e81a1296c8",
   "zh": "「我敢打賭，連魔像族也面臨這樣的困境。」"
  },
  {
   "hash": "5e02f462ef3e4c34",
   "zh": "「但我們更多是以他們與我們的不同來了解他們，而非共同之處。」",
   "note": "對魔像族的深刻見解"
  },
  {
   "hash": "1c37abeaf4668bbb",
   "zh": "「我賣多種@葡萄酒，都是在這裡釀造的。」他嘖嘖稱讚。"
  },
  {
   "hash": "5daeb43b951af442",
   "zh": "「$T愉快。」他啜了一口酒杯。"
  },
  {
   "hash": "f35d79034141e13a",
   "zh": "他搔搔頭，環顧四周。"
  },
  {
   "hash": "7bf2e7fe4fc43e63",
   "zh": "「你們哪位？」"
  },
  {
   "hash": "62aaff84f5558c2c",
   "zh": "「要哪一種？」"
  },
  {
   "hash": "968df022a00f2f62",
   "zh": "$N對$Y微笑。「$0需要#1枚金幣。有意嗎？」"
  },
  {
   "hash": "5ede383c9586bf82",
   "zh": "$N瞥向$Y，「你帶的東西已經很多了。」"
  },
  {
   "hash": "7e5362332d76261f",
   "zh": "「太好了！」接過$Y的金幣後，$N遞上葡萄酒。"
  },
  {
   "hash": "1b90e9cc73af60c6",
   "zh": "$N望向$Y。「你的金幣不夠。」"
  },
  {
   "hash": "c751fefcd3414d66",
   "zh": "「好好享用你的$1。」"
  },
  {
   "hash": "59ed73859feef486",
   "zh": "「可惜，這是非常好的葡萄酒。」"
  }
 ],
 "glossary_additions": {
  "people": {
   "Faren": "法倫"
  },
  "places": {}
 },
 "translator_notes": "法倫是酒商，史黛芬妮的哥哥。他對魔像族有深刻的人道主義見解，以妹妹的盲眼為例說明理解「他者」的重要性。葡萄酒名為系統字串，略。"
}
