{
 "_meta": {},
 "translations": [
  {
   "hash": "6e4bce8571ea1fd2",
   "zh": "貝蘭",
   "note": "NPC name — Gargish, 'just one'，音譯為貝蘭"
  },
  {
   "hash": "6d6e2acf61ecdd72",
   "zh": "皮膚白皙之矮小魔像。",
   "note": "DESC"
  },
  {
   "hash": "1a4521bf8fcad47e",
   "zh": "「願問強大之$P，我能如何效勞？」貝蘭問道。",
   "note": "魔像語法：以「To+動詞」開頭，譯為文言"
  },
  {
   "hash": "bbc1b9ed5dd48573",
   "zh": "魔像熱情地與你打招呼，你卻完全聽不懂！",
   "note": "旁白"
  },
  {
   "hash": "1a9c733dd23f8f8d",
   "zh": "見你一臉困惑，他切換成人類語言。這對他顯然費勁。",
   "note": "旁白"
  },
  {
   "hash": "edd7eed8b19b7be1",
   "zh": "「哈囉。我一點點人類@speak說話。」",
   "note": "破碎的人類語，保留原味"
  },
  {
   "hash": "cee24aee65f8e41e",
   "zh": "$Y說：「$P，我們離開這裡吧。」"
  },
  {
   "hash": "2cc79958614ad41d",
   "zh": "「這生靈對我們毫無用處。同意嗎？」"
  },
  {
   "hash": "12bc5cb204cef299",
   "zh": "困惑的魔像揮手告別。",
   "note": "旁白"
  },
  {
   "hash": "99f66600f2f33b84",
   "zh": "「悉聽尊便，$G。」"
  },
  {
   "hash": "1da414ac482fe601",
   "zh": "「約翰船長朋友。他來這。我等這。」",
   "note": "貝蘭破碎人類語"
  },
  {
   "hash": "dfa8afed08e955b7",
   "zh": "「沒名字。我貝蘭。」",
   "note": "破碎語法"
  },
  {
   "hash": "484968b81e466d88",
   "zh": "「我等這。@Captain約翰船長會來。」"
  },
  {
   "hash": "81b7ecc03796b11e",
   "zh": "「@Captain約翰船長教我人類說話，」魔像吞吞吐吐地說。"
  },
  {
   "hash": "12bc5cb204cef299",
   "zh": "困惑的魔像揮手告別。",
   "note": "旁白（重複）"
  },
  {
   "hash": "def23d588010a18a",
   "zh": "魔像聳聳肩。",
   "note": "旁白"
  },
  {
   "hash": "1ed0fa34a794914e",
   "zh": "「見人類而作禮。認汝乃偽@Prophet先知！」",
   "note": "魔像文言語法"
  },
  {
   "hash": "69bb6258eefcb476",
   "zh": "「$T好，吾友",
   "note": "前半"
  },
  {
   "hash": "d4280bed5411665e",
   "zh": "。已見過@Valkadesh否？」",
   "note": "後半"
  },
  {
   "hash": "b927a8e8657351cf",
   "zh": "「識得約翰船長！助他與@Valkedesh共事，」這小傢伙自豪地說。"
  },
  {
   "hash": "17ef3c385ff0cf82",
   "zh": "「未證己之@worthy配得，不受真名。」",
   "note": "魔像名制度"
  },
  {
   "hash": "1a80c23afdc7cf5f",
   "zh": "「吾被稱作貝蘭，意為『僅此一人』。尚未獲賜@true真名。」"
  },
  {
   "hash": "144b1c3a7c461f7a",
   "zh": "「尚不配得真名。然終將得之，如吾父@Valkadesh一般！」"
  },
  {
   "hash": "6a102003137ba566",
   "zh": "「在此效力於高貴之$P。」"
  },
  {
   "hash": "d6454ccc8a6c2075",
   "zh": "「在此等候@John約翰船長。」"
  },
  {
   "hash": "e1479d8034689310",
   "zh": "「吾父瓦卡德許，甚為敬仰。」"
  },
  {
   "hash": "cb3413bb6f32da17",
   "zh": "「願他日成一學者，如吾父一般！」"
  },
  {
   "hash": "09069bdb81024067",
   "zh": "「問何處指引不明？」"
  },
  {
   "hash": "6cf41ea68f90030c",
   "zh": "「吾所知甚少。然@Valkadesh定知曉！」"
  },
  {
   "hash": "202f4bc3341fefc2",
   "zh": "「乃吾族指引之@principles原則之一。」"
  },
  {
   "hash": "9b9e9e1997663147",
   "zh": "「竟不知此，令吾驚訝！」"
  },
  {
   "hash": "1979e5b2e675afde",
   "zh": "「吾族有三大指引原則——@control克制、@diligence勤勉、@passion熱情。」"
  },
  {
   "hash": "a7099721e2fe4108",
   "zh": "「此乃吾族全部信仰之根基。」"
  },
  {
   "hash": "6a0bed0df34b8e4c",
   "zh": "「人人皆懼之——除吾與吾父@Valkadesh之外！」"
  },
  {
   "hash": "080f4dbf0d93e283",
   "zh": "「願與汝同行！」"
  },
  {
   "hash": "273f8b6cab4bbb19",
   "zh": "「兩族未達和平，決不離去！」"
  },
  {
   "hash": "1102b7e0179a6cf2",
   "zh": "「願",
   "note": "道別語前半"
  },
  {
   "hash": "dcc2eddd2d21926c",
   "zh": "以恆毅與精準引領吾等走向勝利！」",
   "note": "道別語後半"
  },
  {
   "hash": "058d38bf21fe8808",
   "zh": "你離開期間，$9決定前往地面，向不列顛王稟報進度。",
   "note": "旁白"
  },
  {
   "hash": "f601284ea8c11801",
   "zh": "「岩漿危險！須遠離！」"
  },
  {
   "hash": "cba1c4ee5a2d08bd",
   "zh": "「自海帝羅斯出發，順時針繞山而行，可至吾父之@house居所。」"
  },
  {
   "hash": "f051c1bcd6c79727",
   "zh": "「穿過@Hall智識之殿以東的山口，可尋得吾父瓦卡德許之居所。」"
  },
  {
   "hash": "503c137fcf96ffaa",
   "zh": "「智識之殿在城市南方。」"
  },
  {
   "hash": "42bc3311d3ef1260",
   "zh": "「勿入智識之殿！先去見@Valkadesh！」"
  },
  {
   "hash": "6c830a212307e9bb",
   "zh": "「好！他非常想與汝一談。」"
  },
  {
   "hash": "c51e9603f0c46d63",
   "zh": "「願見瓦卡德許否？」"
  },
  {
   "hash": "d6c0f8d9a154b2aa",
   "zh": "「與汝同行，@guide引路！」"
  },
  {
   "hash": "83f290ca85f5f1da",
   "zh": "「哦。」小魔像似乎有些失落。",
   "note": "旁白"
  },
  {
   "hash": "bb97920107f64270",
   "zh": "「需要前往瓦卡德許居所的@directions指引嗎？」"
  },
  {
   "hash": "736215c7965c717f",
   "zh": "「那吾便不解汝之意了。」"
  },
  {
   "hash": "dadae0cbfe2363f5",
   "zh": "「自海帝羅斯入口向西，沿@mountains山脈而行。」"
  },
  {
   "hash": "20190fe8e43bab6d",
   "zh": "「至@Hall智識之殿處北轉。」"
  },
  {
   "hash": "1c7201394358731d",
   "zh": "「沿山東行，直至窄口山道。」"
  },
  {
   "hash": "f8a8416bc4febe12",
   "zh": "「穿越山道，即可尋得瓦卡德許之@house居所！」"
  },
  {
   "hash": "f874eb9487862e9b",
   "zh": "「以六分儀測量，位於南緯40度、東經65度。」"
  },
  {
   "hash": "adb6ac61e704eb56",
   "zh": "「但須小心！避開@lava岩漿坑與@Hall智識之殿！」"
  },
  {
   "hash": "429a6e08c95650ba",
   "zh": "「明白此@directions指引嗎？」"
  },
  {
   "hash": "e8ae2f8cd5b3fabb",
   "zh": "「好！」"
  },
  {
   "hash": "93f60cd1c6be8799",
   "zh": "「問何處不明？」"
  },
  {
   "hash": "ebae5e3748dd439c",
   "zh": "小魔像迫不及待地加入你的隊伍。",
   "note": "旁白"
  },
  {
   "hash": "f2487e4e08e90fcc",
   "zh": "「甚願加入，然汝之隊伍已無多餘位置。」"
  },
  {
   "hash": "544af9c8d9a5ab9f",
   "zh": "$9說：「$G，吾將返回地面，向大家稟報我們的進度。」"
  },
  {
   "hash": "a9bf48bc472746c1",
   "zh": "「眼下無法與汝同行。也許稍後再問。」"
  },
  {
   "hash": "ebae5e3748dd439c",
   "zh": "小魔像迫不及待地加入你的隊伍。",
   "note": "旁白（重複）"
  },
  {
   "hash": "c7a50a5afaae7a0c",
   "zh": "「對此毫不知曉。」"
  },
  {
   "hash": "89dc08f254b3aa0f",
   "zh": "「吾年幼。此事當問年長者。」"
  },
  {
   "hash": "0c220d88a916f2e0",
   "zh": "「誠心盼能助汝於此事。」"
  },
  {
   "hash": "c7adea52b3c86abe",
   "zh": "「不解汝所言$Z之意。」"
  },
  {
   "hash": "42cc27e8acea0f0d",
   "zh": "「吾閱歷尚淺，無從作答。」"
  }
 ],
 "glossary_additions": {
  "people": {
   "Beh Lem": "貝蘭",
   "Valkadesh": "瓦卡德許"
  },
  "places": {
   "Hythloth": "海帝羅斯"
  }
 },
 "translator_notes": "貝蘭為年輕魔像，習得破碎人類語（早期對話）及魔像典雅語法（後期）。前段人類語保留破碎口語感；後段魔像語用文言「To+動詞」對應為文言句式。道別語「願以恆毅與精準引領吾等走向勝利」保留魔像三原則意象。"
}
