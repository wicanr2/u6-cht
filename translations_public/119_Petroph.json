{
 "_meta": {},
 "translations": [
  {
   "hash": "be698367f38f24d1",
   "zh": "身形魁梧之男子，目光嚴峻。",
   "note": "DESC"
  },
  {
   "hash": "a6ff6d803580e0c1",
   "zh": "「回來做甚麼？我以為汝不喜歡我的@客棧。」",
   "note": "Petroph 說話文法粗疏，譯文略帶洋味"
  },
  {
   "hash": "468d15eb046e9e28",
   "zh": "「又來囉。」"
  },
  {
   "hash": "2f9e887401acebfe",
   "zh": "「你好啊。」"
  },
  {
   "hash": "10d612830071a3cb",
   "zh": "「@彼得羅夫。」"
  },
  {
   "hash": "9b970ada9c193bf8",
   "zh": "「對，彼得羅夫。」",
   "note": "Da = 俄語是，保留語感"
  },
  {
   "hash": "49a073d5b4505a29",
   "zh": "「我在這裡經營@客棧，叫做『王者贖金』。」",
   "note": "King's Ransom 為客棧名，意譯保留"
  },
  {
   "hash": "10b24342705185e6",
   "zh": "「對，再見，算是解脫了！」"
  },
  {
   "hash": "aa8faeb99e254a43",
   "zh": "「祝你愉快。」"
  },
  {
   "hash": "af14cc0831041ef6",
   "zh": "「你說太快了。說什麼？」"
  },
  {
   "hash": "bbf82a3cc4dc99e2",
   "zh": "「住宿附餐，#0枚金幣，可以嗎？」"
  },
  {
   "hash": "92b8f635ebc54813",
   "zh": "「住房要預先付款。抱歉，這是規定。」"
  },
  {
   "hash": "1d3035718718ebe0",
   "zh": "你睡在舒適的床上……",
   "note": "敘述文"
  },
  {
   "hash": "26d8ebccc4991909",
   "zh": "你醒來精神充沛，吃了一頓豐盛的早餐。"
  },
  {
   "hash": "51685ce75f0057ba",
   "zh": "「早安。」"
  },
  {
   "hash": "eb87b130918c90f1",
   "zh": "「什麼，難道你不喜歡我的客棧？」"
  },
  {
   "hash": "313d634a9bbbf35c",
   "zh": "「那好，也許我也不喜歡你！」"
  }
 ],
 "glossary_additions": {
  "people": {
   "Petroph": "彼得羅夫"
  },
  "places": {
   "King's Ransom": "王者贖金客棧"
  }
 },
 "translator_notes": "Petroph 帶東歐口音（Da = 是），說話簡短生硬。King's Ransom 為客棧名，直譯。"
}
