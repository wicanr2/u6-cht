 "_meta": {},
 "translations": [
  {
   "hash": "4219e7a46d5c1461",
   "zh": "英勇祭壇",
   "note": "NPC name — 神殿祭壇"
  },
  {
   "hash": "78ec80d1be05fb73",
   "zh": "英勇之祭壇。",
   "note": "DESC"
  },
  {
   "hash": "4dea77d1e904b054",
   "zh": "當你跪在祭壇前，一個神秘的聲音在你腦中迴響。",
   "note": "旁白"
  },
  {
   "hash": "065b2267916cf488",
   "zh": "「汝對英勇仍有許多須學習之處。」",
   "note": "低階評語"
  },
  {
   "hash": "30db67178566a29f",
   "zh": "「汝之行為展現了令人欽佩的英勇。」",
   "note": "中階評語"
  },
  {
   "hash": "52b84eff61efe845",
   "zh": "「汝之行為可為眾人表率。」",
   "note": "高階評語"
  },
  {
   "hash": "bf3b28dcc608d94c",
   "zh": "你希望在此祭壇冥想嗎？",
   "note": "旁白提示，尾隨空格保留"
  },
  {
   "hash": "50e77701c0136675",
   "zh": "#2。$Y",
   "note": "控制符保留"
  },
  {
   "hash": "4f97e949580d4b79",
   "zh": "「誰來冥想？」",
   "note": "尾隨空格保留"
  },
  {
   "hash": "deab673525366c06",
   "zh": "「覆誦英勇真言。」"
  },
  {
   "hash": "ffe5b426e8468f7f",
   "zh": "「$Z…… $Z……」",
   "note": "真言提示第一次"
  },
  {
   "hash": "ffe5b426e8468f7f",
   "zh": "「$Z…… $Z……」",
   "note": "真言提示第二次"
  },
  {
   "hash": "ffe5b426e8468f7f",
   "zh": "「$Z…… $Z……」",
   "note": "真言提示第三次"
  },
  {
   "hash": "399402d6eaacfaaf",
   "zh": "「以柔手撫弄蕁麻，它以刺痛回報你的代價。」",
   "note": "聖言（Aaron Hill 詩作典故）"
  },
  {
   "hash": "a5633524d6a2117c",
   "zh": "「以剛毅之手緊握，它便柔如絲綢。」",
   "note": "聖言（同上）"
  },
  {
   "hash": "9d3c825b4abf0064",
   "zh": "你未能獲得啟示。",
   "note": "旁白"
  },
  {
   "hash": "64268b11d0648045",
   "zh": "$Y提升了一個等級……",
   "note": "升級旁白"
  },
  {
   "hash": "0c701c5c793f8816",
   "zh": "以及力量！",
   "note": "能力提升（英勇→力量）"
  },
  {
   "hash": "cb93cedb92f1135f",
   "zh": "「此刻此地，汝已無更多可學。」"
  },
  {
   "hash": "36b180a0ddf1311a",
   "zh": "「待汝的旅程更進一步，再行回返。」"
  }
 ],
 "glossary_additions": {
  "people": {},
  "places": {}
 },
 "translator_notes": "英勇神殿，真言 ra（不翻譯）。冥想獲得力量提升。聖言引自 Aaron Hill 的蕁麻詩，以剛克柔的比喻。"
}
