{
 "_meta": {},
 "translations": [
  {
   "hash": "7878e6b5462b456f",
   "zh": "琳達",
   "note": "NPC name，女農夫，賣穀物"
  },
  {
   "hash": "82351850f78372b6",
   "zh": "一位看起來結實幹練的女農夫。",
   "note": "DESC"
  },
  {
   "hash": "188987a38ddce9f7",
   "zh": "「歡迎，朋友。」"
  },
  {
   "hash": "6e2ce8c3526bd422",
   "zh": "「我叫琳達。」"
  },
  {
   "hash": "e936db138207f57b",
   "zh": "「我種@crops農作物。若想買些@grain穀物，說個@word口令就行。」"
  },
  {
   "hash": "417079f691c1ab74",
   "zh": "「@Bread麵包、蛋糕、派、糕點……它們的@roots根源都在這裡。」"
  },
  {
   "hash": "715b0335a15aa8d6",
   "zh": "「@Woman女人不能只靠@meat肉食活命。」",
   "note": "聖經典故改寫"
  },
  {
   "hash": "5ccf4c48f4de3253",
   "zh": "「牛和@sheep羊比@wheat小麥難養多了。」"
  },
  {
   "hash": "fba0213d606d02db",
   "zh": "「它們有它們的用途。但不在我的農場。」"
  },
  {
   "hash": "36ad4422705aeb88",
   "zh": "「我天生就是要耕地的。不然就只能去當@gravedigger掘墓人了……」"
  },
  {
   "hash": "140c5aa6c1d89cf1",
   "zh": "「那不是我喜歡的活。」"
  },
  {
   "hash": "4e5c69fcb3005a51",
   "zh": "「是的，男人也要吃飯，我想是這樣。」"
  },
  {
   "hash": "dca4ee824ffc24f3",
   "zh": "「口令是「@grain穀物」啦，笨！」"
  },
  {
   "hash": "cb1ab3b8687f40c9",
   "zh": "「願陽光照耀你，雨水滋養你。」",
   "note": "農夫式的告別祝福"
  },
  {
   "hash": "6178d186005a9e17",
   "zh": "「我不知道。我想是的。」"
  },
  {
   "hash": "50e77701c0136675",
   "zh": "#2。$Y",
   "note": "控制符保留"
  },
  {
   "hash": "7bf2e7fe4fc43e63",
   "zh": "「你們哪一位？」",
   "note": "尾隨空格保留"
  },
  {
   "hash": "9de6b5af97ab8f6d",
   "zh": "「一袋穀物要2金幣。有興趣嗎？」",
   "note": "尾隨空格保留"
  },
  {
   "hash": "b3e06e01d84ec8f7",
   "zh": "「你看起來裝得挺滿的了。」",
   "note": "背包滿了"
  },
  {
   "hash": "f8e09482dae4a1f6",
   "zh": "「給你。」"
  },
  {
   "hash": "2c360c6a7ef2b1fe",
   "zh": "「最好再查查你的錢袋。」"
  },
  {
   "hash": "e608466a8ab44245",
   "zh": "「好。」"
  }
 ],
 "glossary_additions": {
  "people": {
   "Linda": "琳達"
  },
  "places": {}
 },
 "translator_notes": "琳達是直率的女農夫，賣穀物（2金幣一袋），對畜牧不感興趣。「Woman does not live on meat alone」仿聖經「人不能單靠麵包」。告別祝詞保留農耕意象。"
}
