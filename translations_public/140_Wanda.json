 "_meta": {},
 "translations": [
  {
   "hash": "ef59636231c865ee",
   "zh": "身材豐盈的吉普賽女子。",
   "note": "DESC"
  },
  {
   "hash": "bd6a84d14d14c536",
   "zh": "「你好，姑娘。近況如何？」",
   "note": "對女性玩家的開場"
  },
  {
   "hash": "eb508803fe3e3f22",
   "zh": "「哦，你好，帥哥！在找點……放鬆嗎？」",
   "note": "對男性玩家的開場"
  },
  {
   "hash": "12eda05005d4c78a",
   "zh": "「這裡就是了！」"
  },
  {
   "hash": "7bddbb13f9e4f90f",
   "zh": "「哈！你肯定是怕你媽知道了怎麼想。」"
  },
  {
   "hash": "f2a9539af0d0bca1",
   "zh": "「他們叫我『@壞汪達』，$0。」"
  },
  {
   "hash": "1470648c1ad6e437",
   "zh": "「若我們能找個@僻靜的地方，我很樂意讓你知道我的綽號是怎麼來的……」"
  },
  {
   "hash": "0a6c9fa1c6bc5e98",
   "zh": "「嗯，聽起來我已勾起你的興趣……」"
  },
  {
   "hash": "8d76d9339811f45b",
   "zh": "「哦，",
   "note": "下接稱謂"
  },
  {
   "hash": "500454a54e38bc6b",
   "zh": "夫人",
   "note": "引擎依性別注入"
  },
  {
   "hash": "20d448f44d7660e8",
   "zh": "先生",
   "note": "引擎依性別注入"
  },
  {
   "hash": "0f33ea37ffc7e041",
   "zh": "，您這是在暗示什麼嗎？」"
  },
  {
   "hash": "1ac05b5b62a40104",
   "zh": "她忍不住咯咯笑起來。"
  },
  {
   "hash": "a6bb90670af8f171",
   "zh": "「我們沒有……哦，等等，好像是有那麼回事！」",
   "note": "關於地圖"
  },
  {
   "hash": "0b5897a77046be50",
   "zh": "「@阿圖羅斯，呃，上次我們去悲憫@修道院時他找到了一張地圖。」"
  },
  {
   "hash": "abf7b5eb46910af6",
   "zh": "「他可以為你算@命，$0。去問他就是了！」"
  },
  {
   "hash": "e55d712d21f8d6c8",
   "zh": "「對，就是。」"
  },
  {
   "hash": "654b72b3f6ebd0f1",
   "zh": "「我不太喜歡他們。個個都太自命清高。」",
   "note": "關於Empath Abbey僧侶"
  },
  {
   "hash": "5c0c5af8a4bdf6d5",
   "zh": "「@安德烈亞斯有塊銀板，你可以去問他。」"
  },
  {
   "hash": "3a7e81c8f441e0bf",
   "zh": "「但我有更@甜蜜的東西出售……」"
  },
  {
   "hash": "46aecec769627d96",
   "zh": "「他能讓你玩得很開心，甜心！」"
  },
  {
   "hash": "ff6bf900d8db9099",
   "zh": "「他跟我做同一行——但我覺得我更合你的口味！」"
  },
  {
   "hash": "3cb544d4944975b6",
   "zh": "「這工作很累人，你知道的。」"
  },
  {
   "hash": "5e042fbc2a66e519",
   "zh": "「跟你做生意真是享受……希望你快快再來！」",
   "note": "pleasure/business雙關"
  },
  {
   "hash": "01150ebc519d82a2",
   "zh": "「保重……若你遇到又高又壯又英俊的人，把他們送到我這來！」"
  },
  {
   "hash": "0ba672216ed77c4a",
   "zh": "「若你哪天決定想從冒險中喘口氣，再來找我。」"
  },
  {
   "hash": "394c96802b98d05a",
   "zh": "「為何為那事費心，$0？」"
  },
  {
   "hash": "85d839ca6ba2c10c",
   "zh": "「你肯定能想到更愉快的事……」"
  },
  {
   "hash": "44d1175e8995bcd7",
   "zh": "「又來了，這麼快？不，晚些再來，讓我@休息一下。」"
  },
  {
   "hash": "f493a086fd548007",
   "zh": "「我不常接待女性顧客……但為何不呢？你確定這是你想要的？」",
   "note": "對女性玩家"
  },
  {
   "hash": "d3c49c2632e700cb",
   "zh": "「我篷車裡有張床……收費15枚金幣——不砍價！有意嗎，$0？」"
  },
  {
   "hash": "b8b56cd6cd8ac65c",
   "zh": "$Y說道：「我覺得我們沒有時間做這個……」"
  },
  {
   "hash": "f68427619d2e6d47",
   "zh": "腦後有個聲音問道：「你真的有時間做這個嗎？」"
  },
  {
   "hash": "c61096ea018784dd",
   "zh": "「來吧，$0。往我手心放15枚金幣，我讓你玩個痛快。好嗎？」"
  },
  {
   "hash": "4a9972d9f9ba4e4e",
   "zh": "「好吧！等你媽媽批准了再來！」"
  },
  {
   "hash": "a1a263364b848eae",
   "zh": "「嘿，我不賒帳！沒錢沒服務，明白？」",
   "note": "capish=義大利語「明白嗎」"
  },
  {
   "hash": "655a282e688953e6",
   "zh": "那吉普賽女子拉起你的手，帶你去她的篷車。"
  },
  {
   "hash": "e7fbcb1c638428ea",
   "zh": "過了一會兒，你回到同伴身邊。"
  },
  {
   "hash": "b899b2fc96886beb",
   "zh": "「整個不列顛尼亞都在危難中，你卻這樣鬼混！」",
   "note": "同伴評語"
  },
  {
   "hash": "e9554ad4d6be2332",
   "zh": "「等試煉完成，再來尋歡作樂！」"
  },
  {
   "hash": "a152446549074bc9",
   "zh": "「享樂一下沒什麼不對。時間很多……只要金幣也很多！」"
  },
  {
   "hash": "ff4272648a39bd5d",
   "zh": "你試圖無視腦後那個不斷念叨「你不該這樣浪費時間」的聲音。"
  }
 ],
 "glossary_additions": {
