{
 "_meta": {},
 "translations": [
  {
   "hash": "d0ef2b7914ae153e",
   "zh": "桃莉絲",
   "note": "SIDENT name (J prefix is opcode marker)"
  },
  {
   "hash": "81ab3b9c1f1335b2",
   "zh": "一位絕色佳人。",
   "note": "DESC"
  },
  {
   "hash": "df71b483f1ba1652",
   "zh": "彼女目不離卷，縱汝啟齒，亦不抬眼。"
  },
  {
   "hash": "7e77976c5149ecaa",
   "zh": "「嗯？汝有何貴幹"
  },
  {
   "hash": "b6bb8483ba1c6b60",
   "zh": "？」"
  },
  {
   "hash": "080d0407b4cb7364",
   "zh": "？」"
  },
  {
   "hash": "b33cb64135e7dc66",
   "zh": "「我叫桃莉絲，不過你叫我『@Hey（喂） @you（你）』也行。」",
   "note": "保留 @keyword 觸發"
  },
  {
   "hash": "f82c2b8324ae6166",
   "zh": "「人人都這樣叫我。」"
  },
  {
   "hash": "efa720f3cc49a6b5",
   "zh": "「俗不可耐。」她咕噥道。"
  },
  {
   "hash": "6008c760f151d6f4",
   "zh": "「家@father（父親）外出時，工匠客棧由我代為打理。」"
  },
  {
   "hash": "bccb6c062b702ea4",
   "zh": "「若有任何不滿，無論多瑣碎，儘管來煩我。」"
  },
  {
   "hash": "081ab0d78fbbcaaa",
   "zh": "聽她語氣，不像真心如此。"
  },
  {
   "hash": "293fbebb528f26cd",
   "zh": "「食宿每人每晚五金，預先付清。」"
  },
  {
   "hash": "25267418a58a557d",
   "zh": "「有意嗎？」"
  },
  {
   "hash": "43cdb2865e3363c3",
   "zh": "「對，人人都這樣說。」"
  },
  {
   "hash": "c511df971ebc72ff",
   "zh": "「家父自@Lycaeum（學苑）召我回來，自己卻去打魔像族了。」"
  },
  {
   "hash": "54a17041436ae3aa",
   "zh": "「對，我師從偉大的@Xiao（蕭）習奧術。」"
  },
  {
   "hash": "ecada7985c06dcfa",
   "zh": "「不過汝這等人，諒也不懂此道。」"
  },
  {
   "hash": "f7d0ba1c6d552a3b",
   "zh": "「她乃全不列顛尼亞最睿智之法師。」"
  },
  {
   "hash": "548284343c914d86",
   "zh": "「唯她能傳授@power（威力）最強之咒語。」"
  },
  {
   "hash": "a956ec5f1b61917c",
   "zh": "「嗯哼，正是。」"
  },
  {
   "hash": "67f6301417e4648c",
   "zh": "「嗯——哼。」她在汝離去時咕噥。"
  },
  {
   "hash": "409abbd697ba8c04",
   "zh": "「真的喔。」"
  },
  {
   "hash": "e0c423b69beea5ea",
   "zh": "「呵，真有意思。」她打呵欠。"
  },
  {
   "hash": "e9cf10e4c9cd81b8",
   "zh": "「真可惜呢。」"
  },
  {
   "hash": "078eeab671c4f9db",
   "zh": "「無錢勿宿。五金，預先付清。」"
  },
  {
   "hash": "9c9c4a61b15b641c",
   "zh": "「無錢勿宿。」"
  },
  {
   "hash": "03c61b6e1dc33c64",
   "zh": "「汝一行人共需 #1 金，預先付清。」"
  },
  {
   "hash": "1f710f81580222e3",
   "zh": "汝一行人湊錢付房錢。"
  },
  {
   "hash": "8b75b5a3446b7e19",
   "zh": "汝將那無禮店主之事拋於腦後，安然入眠。"
  },
  {
   "hash": "c98a293bf21852b4",
   "zh": "翌晨，桃莉絲悻悻然為汝供早膳，旋即回去苦讀。"
  }
 ],
 "glossary_additions": {
  "people": {
   "Doris": "桃莉絲"
  },
  "places": {
   "Tinker's Inn": "工匠客棧",
   "Lycaeum": "學院"
  }
 },
 "translator_notes": "Doris = 米諾克工匠客棧老闆 Patrick 之女。態度傲慢，看不起客人，學徒於 Xiao。語氣設定：刻意輕蔑、敷衍。"
}
