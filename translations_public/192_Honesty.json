 "translations": [
  {
   "hash": "6daf4443316516b1",
   "zh": "誠實祭壇",
   "note": "NPC name — 神殿祭壇"
  },
  {
   "hash": "0c4b5070ce0ad34b",
   "zh": "誠實之祭壇。",
   "note": "DESC"
  },
  {
   "hash": "4dea77d1e904b054",
   "zh": "當你跪在祭壇前，一個神秘的聲音在你腦中迴響。",
   "note": "旁白"
  },
  {
   "hash": "15291ea2923841e8",
   "zh": "「汝對誠實仍有許多須學習之處。」",
   "note": "低階評語"
  },
  {
   "hash": "f700c1ddc000b39f",
   "zh": "「汝之行為展現了令人欽佩的誠實。」",
   "note": "中階評語"
  },
  {
   "hash": "52b84eff61efe845",
   "zh": "「汝之行為可為眾人表率。」",
   "note": "高階評語"
  },
  {
   "hash": "bf3b28dcc608d94c",
   "zh": "你希望在此祭壇冥想嗎？",
   "note": "旁白提示，尾隨空格保留"
  },
  {
   "hash": "50e77701c0136675",
   "zh": "#2。$Y",
   "note": "控制符保留"
  },
  {
   "hash": "4f97e949580d4b79",
   "zh": "「誰來冥想？」",
   "note": "尾隨空格保留"
  },
  {
   "hash": "c14069d6da1c7e76",
   "zh": "「覆誦誠實真言。」"
  },
  {
   "hash": "ffe5b426e8468f7f",
   "zh": "「$Z…… $Z……」",
   "note": "真言提示第一次"
  },
  {
   "hash": "ffe5b426e8468f7f",
   "zh": "「$Z…… $Z……」",
   "note": "真言提示第二次"
  },
  {
   "hash": "ffe5b426e8468f7f",
   "zh": "「$Z…… $Z……」",
   "note": "真言提示第三次"
  },
  {
   "hash": "a08c22034f89fd10",
   "zh": "「凡是真實之事……」",
   "note": "聖言，仿聖經腓立比書4:8"
  },
  {
   "hash": "0b20c35f0eb92c13",
   "zh": "「凡是誠實之事……」",
   "note": "聖言"
  },
  {
   "hash": "0415f4d69a120c96",
   "zh": "「凡有德行、凡可稱頌者，皆當存念於心。」",
   "note": "聖言"
  },
  {
   "hash": "9d3c825b4abf0064",
   "zh": "你未能獲得啟示。",
   "note": "旁白"
  },
  {
   "hash": "64268b11d0648045",
   "zh": "$Y提升了一個等級……",
   "note": "升級旁白"
  },
  {
   "hash": "bfbd02c2001fdf00",
   "zh": "以及智力！",
   "note": "能力提升（誠實→智力）"
  },
  {
   "hash": "cb93cedb92f1135f",
   "zh": "「此刻此地，汝已無更多可學。」"
  },
  {
   "hash": "36b180a0ddf1311a",
   "zh": "「待汝的旅程更進一步，再行回返。」"
  }
 ],
