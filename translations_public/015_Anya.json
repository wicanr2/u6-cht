{
 "_meta": {},
 "translations": [
  {
   "hash": "14b7b38acc2b3d24",
   "zh": "安雅",
   "note": "人名 Anya"
  },
  {
   "hash": "9df3fe42053bb019",
   "zh": "豐腴婦人，看來勤勉而知足。",
   "note": "外貌描述"
  },
  {
   "hash": "ac566da3514f072f",
   "zh": "「對不住，$G，今日我只有一個時辰閒暇。」",
   "note": "忙碌中"
  },
  {
   "hash": "9ff2bb0497cbbeac",
   "zh": "「來日再與汝細談。」",
   "note": "改日再談"
  },
  {
   "hash": "4dd55f776f095009",
   "zh": "「$T好，$G，藍野豬酒館歡迎汝。汝是為@business（生意）還是@pleasure（消遣）？」",
   "note": "酒館招呼"
  },
  {
   "hash": "66d38dd03cfcc1e8",
   "zh": "「還有別的事我能效勞嗎？」",
   "note": "後續服務"
  },
  {
   "hash": "c4bcadba8e631b86",
   "zh": "名字",
   "note": "@name keyword"
  },
  {
   "hash": "406cbc3815f64b6b",
   "zh": "我是安雅。",
   "note": "自我介紹；len=12 省略「」"
  },
  {
   "hash": "5937637278a5075c",
   "zh": "吉普",
   "note": "@gypsies keyword 簡寫"
  },
  {
   "hash": "6da8d23008c643c8",
   "zh": "「他們偶爾經過不列顛城。我想他們是走@Way（王道）而來。」",
   "note": "吉普賽人"
  },
  {
   "hash": "f55b55f90b8b1ad5",
   "zh": "王道,御",
   "note": "king/way 雙 keyword；『王道』『御』分觸發"
  },
  {
   "hash": "b9180da614f1ef6e",
   "zh": "「王道乃不列顛城最古老之路。」",
   "note": "古道"
  },
  {
   "hash": "15b1ab3e86311a5d",
   "zh": "職業,工",
   "note": "job/work 雙 keyword；『職業』『工』分觸發"
  },
  {
   "hash": "a2e9c67a6625affe",
   "zh": "「我經營此酒館以養@family（家計）。時辰雖長，所幸夫君力所能及亦多有相助。」",
   "note": "酒館生計"
  },
  {
   "hash": "aeb4e3f3d40cc4d2",
   "zh": "「所掙能供小女讀書，故而一切皆值得。」",
   "note": "供女讀書"
  },
  {
   "hash": "378adf656b9499fa",
   "zh": "家計,養",
   "note": "family/support keyword"
  },
  {
   "hash": "5d13e841c8c60a01",
   "zh": "「夫君@Matt（馬特），與小女@Ariana（艾里）安娜。」",
   "note": "家人"
  },
  {
   "hash": "afaa7a11e1047f3f",
   "zh": "夫君,馬特",
   "note": "husband/matt keyword"
  },
  {
   "hash": "4b0572786f3f9fd5",
   "zh": "「他幼時遭逢變故，自此聾啞，然我愛他不減分毫。」",
   "note": "丈夫聾啞"
  },
  {
   "hash": "05b15e498e4508e2",
   "zh": "「我只@wish（盼他）能聽小女彈奏一回，哪怕只此一次。」",
   "note": "願望聽彈奏"
  },
  {
   "hash": "5dc637abf3c3c05d",
   "zh": "「然此事終難成。他常住於永恆之靜默中。」",
   "note": "永恆靜默"
  },
  {
   "hash": "46ceaca8f2b25c63",
   "zh": "變故,聾,啞,盼,靜",
   "note": "5 個 keyword 合併"
  },
  {
   "hash": "5a3f83fb6102906d",
   "zh": "她面色忽明。「汝有幾分習法者之相。」",
   "note": "察覺玩家為法師"
  },
  {
   "hash": "871b4e1b8b14b253",
   "zh": "「或汝能尋得某種法術，使夫君復聽？」",
   "note": "求法術復聽；避 5C trail 改『或』"
  },
  {
   "hash": "1242d8a2227ba35f",
   "zh": "「我知此求甚重，然汝可願一試？」",
   "note": "請求一試"
  },
  {
   "hash": "2382d9f0366bbb8b",
   "zh": "女兒,艾里",
   "note": "daughter/ariana keyword"
  },
  {
   "hash": "5c853f96154cc746",
   "zh": "「艾里安娜是我生命之光。她方學會走路，便已顯露音律之天賦。」",
   "note": "女兒天賦"
  },
  {
   "hash": "768f9e3c54cfebf4",
   "zh": "「她如今在學堂跟隨@bards（吟遊）詩人習藝。」",
   "note": "拜師吟遊詩人"
  },
  {
   "hash": "d63c85eb6cc65ca3",
   "zh": "音律,詩人,學堂",
   "note": "music/bard/cons keyword"
  },
  {
   "hash": "a55a07c872bd38ae",
   "zh": "「願諸位老師受我祝福，他們教導甚善。她長大後絕不會再做酒館女侍。」",
   "note": "祝福老師"
  },
  {
   "hash": "68b7a0d7f78d3a33",
   "zh": "「或有朝一日她能成為不列顛王之宮廷樂師……」",
   "note": "宮廷樂師夢；避 5C 改『或』"
  },
  {
   "hash": "1f645ea2cea20481",
   "zh": "真言",
   "note": "@mantra keyword"
  },
  {
   "hash": "fb77fb5e8a4a7ed0",
   "zh": "「此事汝應問小女。我想吟遊詩人們已將真言授與她。」",
   "note": "真言問女兒"
  },
  {
   "hash": "f346ee7db33539a5",
   "zh": "符文,慈悲,准,借",
   "note": "rune/compass/perm/borrow"
  },
  {
   "hash": "56765286f46e22c0",
   "zh": "「我已准汝借用那符文！」",
   "note": "已給准"
  },
  {
   "hash": "75b07bc1e550454f",
   "zh": "「汝務必小心，莫失此石，亦莫令其受損。艾里安娜會永不能原諒自己的。」",
   "note": "保管符石"
  },
  {
   "hash": "a5f6670db7200fef",
   "zh": "消遣",
   "note": "@pleasure keyword"
  },
  {
   "hash": "a5a4adfa2c3dce0d",
   "zh": "「再次與汝交談甚悅。自@gypsies（吉普）賽人離去後，此地便冷清了好些。」",
   "note": "近況清淡；避 5C"
  },
  {
   "hash": "9dcfb7b9ba229368",
   "zh": "「甚好！或汝可留下與我閒談片刻，待我回去做工。」",
   "note": "邀玩家閒談；避 5C"
  },
  {
   "hash": "b50c5190e8330a79",
   "zh": "糕點",
   "note": "@cake keyword"
  },
  {
   "hash": "42f400a2e307e562",
   "zh": "蜜酒",
   "note": "@mead keyword"
  },
  {
   "hash": "e6f094190519cebf",
   "zh": "麥 ",
   "note": "@ale keyword；len=3 用『麥』+空白（前綴可比對『麥酒』）"
  },
  {
   "hash": "a6200df65560e354",
   "zh": "葡酒",
   "note": "@wine keyword"
  },
  {
   "hash": "6d91161fd1ce40e3",
   "zh": "乾糧",
   "note": "@ration keyword"
  },
  {
   "hash": "008a2f19137d94c3",
   "zh": "別 ",
   "note": "@bye keyword；單字『別』+空白（沿用既有譯法）"
  },
  {
   "hash": "8b3b485f464881f7",
   "zh": "「隨時歡迎再來。」",
   "note": "再會"
  },
  {
   "hash": "88eb2cb0e3be2e6e",
   "zh": "「也罷，我該回去做工了。盤碟要洗，飯食要煮，酒水要送……」",
   "note": "回去做工；『餐』改『飯』避 5C"
  },
  {
   "hash": "0b0fcbf72a56238d",
   "zh": "「謝汝來此一坐，以言談點亮我這一日。願汝再來。」",
   "note": "感謝來訪"
  },
  {
   "hash": "27f51c1dcad425b1",
   "zh": "是,買,賣,生意",
   "note": "yes/buy/sell/business"
  },
  {
   "hash": "49ca857e58020878",
   "zh": "「汝想要@ale（麥酒）、@mead（蜜酒）、@wine（葡酒）、@rations（乾糧），還是來一份@cake（糕點）？」",
   "note": "酒館選單"
  },
  {
   "hash": "1fa9890fbf035491",
   "zh": "「此事我幫不上汝。」",
   "note": "無法協助"
  },
  {
   "hash": "90d343e354fb7ab7",
   "zh": "「啊，那是我此生最自豪之刻——他們將慈悲符文授與我親愛的小艾里安娜。」",
   "note": "自豪時刻"
  },
  {
   "hash": "3ffbd16440ebe4cd",
   "zh": "「他們說她是學堂從未有過的最具天賦的學生。」",
   "note": "最有天賦"
  },
  {
   "hash": "57037bcbba8dc3f7",
   "zh": "「我相信她會將符文展示給汝看，若汝願一觀。」",
   "note": "願示符文"
  },
  {
   "hash": "21e13b46130a3be4",
   "zh": "「汝想向小女借用慈悲符文？」她沉思片刻。",
   "note": "借符文沉思"
  },
  {
   "hash": "03a9edc3b0bff5ca",
   "zh": "「也罷——汝面相誠實。我准汝借之。」",
   "note": "准許借用"
  },
  {
   "hash": "08ed5807b58a118e",
   "zh": "yn",
   "note": "y/n 提示，保留英文（既有慣例）"
  },
  {
   "hash": "4753d6bd9297662f",
   "zh": "「噢，多謝汝，$G！」",
   "note": "感謝"
  },
  {
   "hash": "9abea9991997454b",
   "zh": "她滿懷希望之色轉為憂傷，垂首盯地，掩其窘迫。",
   "note": "失望神情"
  },
  {
   "hash": "14c839636a3b38c7",
   "zh": "「打擾汝了，」她說，「汝必定還有更要緊之事要忙。」",
   "note": "歉意"
  },
  {
   "hash": "50e77701c0136675",
   "zh": "#2. $Y",
   "note": "編號 $Y 變數，保留"
  },
  {
   "hash": "7bf2e7fe4fc43e63",
   "zh": "「你們哪一位？」",
   "note": "問哪位"
  },
  {
   "hash": "2ac2ca536a161c63",
   "zh": "「共需#1枚金幣，$Y。汝要嗎？」",
   "note": "計價"
  },
  {
   "hash": "08ed5807b58a118e",
   "zh": "yn",
   "note": "y/n 提示"
  },
  {
   "hash": "2e5ff2378366e7ab",
   "zh": "「抱歉，你的金幣不足。」",
   "note": "錢不夠"
  },
  {
   "hash": "6c98fa7d7578a208",
   "zh": "「你身上裝不下了。」",
   "note": "背包滿"
  },
  {
   "hash": "eb7c5bb97c1233d9",
   "zh": "「成交！」收下$Y的金幣後，$N將貨物遞出。",
   "note": "交易完成"
  },
  {
   "hash": "c751fefcd3414d66",
   "zh": "「請享用$1。」",
   "note": "請享用"
  },
  {
   "hash": "50e77701c0136675",
   "zh": "#2. $Y",
   "note": "編號"
  },
  {
   "hash": "7bf2e7fe4fc43e63",
   "zh": "「你們哪一位？」",
   "note": "問哪位"
  },
  {
   "hash": "57d4fe34ef2eb818",
   "zh": "$N問$Y：「糕點要8枚金幣。可以嗎？」",
   "note": "糕點計價"
  },
  {
   "hash": "08ed5807b58a118e",
