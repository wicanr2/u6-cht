  },
  {
   "hash": "2e5ff2378366e7ab",
   "zh": "「抱歉，你的金幣不足。」",
   "note": "錢不夠"
  },
  {
   "hash": "6c98fa7d7578a208",
   "zh": "「你身上裝不下了。」",
   "note": "背包滿"
  },
  {
   "hash": "8281cd7f80e61a89",
   "zh": "$N將糕點交給$Y。",
   "note": "遞糕點"
  },
  {
   "hash": "e6d006961024d4e3",
   "zh": "「願汝享用得宜！」",
   "note": "祝享用"
  },
  {
   "hash": "50e77701c0136675",
   "zh": "#2. $Y",
   "note": "編號"
  },
  {
   "hash": "7bf2e7fe4fc43e63",
   "zh": "「你們哪一位？」",
   "note": "問哪位"
  },
  {
   "hash": "54a78bfd55d16922",
   "zh": "「每份乾糧4枚金幣。$Y，你要幾份？」",
   "note": "乾糧計價"
  },
  {
   "hash": "fb67f137fd16da1b",
   "zh": "「你的背包已無容身之處。」",
   "note": "背包滿"
  },
  {
   "hash": "2e5ff2378366e7ab",
   "zh": "「抱歉，你的金幣不足。」",
   "note": "錢不夠"
  },
  {
   "hash": "be6f490468460ac4",
   "zh": "$N將乾糧交給$Y。",
   "note": "遞乾糧"
  },
  {
   "hash": "2eac9c9c5fc2440d",
   "zh": "她遞給$Y#9份羊肉乾糧\\s。",
   "note": "羊肉乾糧"
  },
  {
   "hash": "e968c0e5ea00bb87",
   "zh": "「就只能拿這些了。」",
   "note": "拿不下了"
  },
  {
   "hash": "e2268050dcd1697e",
   "zh": "「你只買得起這些。」",
   "note": "買得起這些"
  },
  {
