 "_meta": {},
 "translations": [
  {
   "hash": "80a01ae86c385072",
   "zh": "一位身材高大、肌肉壯碩、咧嘴而笑的男子。",
   "note": "DESC; same as Peer"
  },
  {
   "hash": "16c812c23ebb7789",
   "zh": "他瞇眼打量汝。「吾等見過面，對嗎？」"
  },
  {
   "hash": "ce79f7679a89f2b1",
   "zh": "「哈囉，」他說著，蹣跚地走向汝，伸出一隻大手。"
  },
  {
   "hash": "87dbc0b38424b2af",
   "zh": "「吾能為汝效勞什麼？」"
  },
  {
   "hash": "5c1d72fc45aa4261",
   "zh": "「崔伯。」"
  },
  {
   "hash": "09d20e2cdb2f2834",
   "zh": "「汝買走了吾最後一艘船！」"
  },
  {
   "hash": "813ec6cd1bc79d10",
   "zh": "「吾售賣",
   "note": "partial"
  },
  {
   "hash": "59a844e2601c9422",
   "zh": "@ships（大船）"
  },
  {
   "hash": "07da0e07b4a02ac9",
   "zh": "。」"
  },
  {
   "hash": "3c0a015edb522c38",
   "zh": "與"
  },
  {
   "hash": "bb389ed1c62df17d",
   "zh": "@skiffs（小艇）。」"
  },
  {
   "hash": "74fe973ae3f6a5f2",
   "zh": "「抱歉，吾最後一艘大船已賣給汝了。」"
  },
  {
   "hash": "2e90dc38b3226871",
   "zh": "「抱歉，吾最後一艘小艇已賣給汝了。」"
  },
  {
   "hash": "5426a97fb77bd4e2",
   "zh": "「吾以前賣大船和小艇。」"
  },
  {
   "hash": "3eae0ac041d96148",
   "zh": "「但汝把它們全買走了！」"
  },
  {
   "hash": "813ec6cd1bc79d10",
   "zh": "「吾售賣",
   "note": "partial"
  },
  {
   "hash": "59a844e2601c9422",
   "zh": "@ships（大船）"
  },
  {
   "hash": "07da0e07b4a02ac9",
   "zh": "。」"
  },
  {
   "hash": "3c0a015edb522c38",
   "zh": "與"
  },
  {
   "hash": "bb389ed1c62df17d",
   "zh": "@skiffs（小艇）。」"
  },
  {
   "hash": "af07368672588d2d",
   "zh": "「再見，朋友。」他蹣跚地走回去繼續工作。",
   "note": "bye"
  },
  {
   "hash": "300e898b506ac547",
   "zh": "「這倒是個謎。」"
  },
  {
   "hash": "7bf2e7fe4fc43e63",
   "zh": "「汝等哪一位？」"
  },
  {
   "hash": "d9fd39184a1347d4",
   "zh": "$N 轉向 $Y。「船契需 #4 枚金幣。汝有意嗎？」"
  },
  {
   "hash": "226ff75df1e77800",
   "zh": "「汝看起來行李很滿，$Y。」"
  },
  {
   "hash": "09d94fa66a98a319",
   "zh": "「甚好！」收下金幣後，$N 將船契交給 $Y。"
  },
  {
   "hash": "5a108f0bdbd387a7",
   "zh": "「駕好她，順風而行。」"
  },
  {
   "hash": "663d72312f313f70",
   "zh": "「汝絕對找不到比這更好的船了。」"
  },
  {
   "hash": "82bae5e7d87aae9c",
   "zh": "「汝的金幣不足。」"
  },
  {
   "hash": "efcc1c40dcd23ea3",
   "zh": "「汝等隊伍的金幣不足。」"
  },
  {
   "hash": "f2b79d91768fe953",
   "zh": "汝的隊伍湊錢購買這艘船。",
   "note": "action"
  }
 ],
 "glossary_additions": {
  "people": {
   "Trebor": "崔伯"
  },
