 "translations": [
  {
   "hash": "47b35e81b6f32621",
   "zh": "索登"
  },
  {
   "hash": "052ed96df0a0cdec",
   "zh": "一名腋下夾著帳冊，神情專注的男子。"
  },
  {
   "hash": "3059249400c2e1e8",
   "zh": "「要記帳冊，要籌節慶，老臣忙得很……但仍可為$G撥冗片刻。」"
  },
  {
   "hash": "c4bcadba8e631b86",
   "zh": "名字"
  },
  {
   "hash": "b49c88769590d5ac",
   "zh": "「老臣索登·馮·巴齊柳斯，乃@British（不列顛王）之宰相。」"
  },
  {
   "hash": "c8fb99745932f3a5",
   "zh": "「想當年，老臣有個綽號叫『@Werecat（酒窖之貓人）』……」"
  },
  {
   "hash": "4c935f957b685aee",
   "zh": "貓人,貓,酒,窖,當年"
  },
  {
   "hash": "efaac455828f7c0d",
   "zh": "「故事多得是，可惜如今已無暇細說了。」"
  },
  {
   "hash": "7d560e159b945c3b",
   "zh": "lord,brit"
  },
  {
   "hash": "0d782c909af04696",
   "zh": "「實乃一代賢君。能為陛下打理國政，老臣甚以為樂。」"
  },
  {
   "hash": "45627c193a5b605c",
   "zh": "業"
  },
  {
   "hash": "dca5566087acf32e",
   "zh": "「治國繁瑣諸事、文牘案牘，皆落在老臣肩上。」"
  },
  {
   "hash": "328dc39d5cc50ab6",
   "zh": "「總得有人來做，然老臣仍懷念當年無拘無束的冒險歲月。」"
  },
  {
   "hash": "95a53dc35da5f83a",
   "zh": "符文,真言,慈悲"
  },
  {
   "hash": "124abbaa88f14d27",
   "zh": "「慈悲之符文與真言，由@Conservatory（音樂院）的吟遊詩人們所保管。」"
  },
  {
   "hash": "af3cd76164d46f5d",
   "zh": "「老臣因詩人們秉性慈悲，故將符文託予之。」"
  },
  {
   "hash": "534a5e318b7f0476",
   "zh": "「至於其餘符文，自@Codex（知識寶典）則之書尋回後，便不再聚於一處。」"
  },
  {
   "hash": "9e66c8b90b7cf9c0",
   "zh": "「自彼時起，諸符文便散佈於全境，各自送往臨近其聖壇之城。」"
  },
  {
   "hash": "1d109c1ea89e7e74",
   "zh": "「汝若向各城首領詢問，應能得知更多詳情。」"
  },
  {
   "hash": "579784b97c04b669",
   "zh": "「諸城為月華城、傑隆、尤伊、米諾克、崔西克、斯卡拉布雷、新馬精西亞。」"
  },
  {
   "hash": "0bb51791194b4414",
   "zh": "守則"
  },
  {
   "hash": "62241e83db5ffedb",
   "zh": "「此乃此境最珍貴之寶。」"
  },
  {
   "hash": "0bca0591195d8188",
   "zh": "音樂"
  },
  {
   "hash": "e9004deadf69a1c1",
   "zh": "「乃陛下所創立。」"
  },
  {
   "hash": "008a2f19137d94c3",
   "zh": "bye"
  },
  {
   "hash": "1cb760938c8a641a",
   "zh": "索登單膝跪地，輕吻汝之手。"
  },
  {
   "hash": "4bf22ccfe8cce0c9",
   "zh": "索登深深一鞠躬。"
  },
  {
   "hash": "14ff9598f33169db",
   "zh": "「願老臣有所助益，$G。」"
  },
  {
   "hash": "1fa9890fbf035491",
   "zh": "「此事老臣無能為力。」"
  }
 ],
