  },
  {
   "offset": 340,
   "len": 6,
   "en": "#2. $Y",
   "zh": "#2。$Y",
   "note": "控制符保留"
  },
  {
   "offset": 380,
   "len": 21,
   "en": "\"Who will meditate?\" ",
   "zh": "「誰來冥想？」",
   "note": "尾隨空格保留"
  },
  {
   "offset": 438,
   "len": 30,
   "en": "\"Speak the Mantra of Honesty.\"",
   "zh": "「覆誦誠實真言。」",
   "note": ""
  },
  {
   "offset": 471,
