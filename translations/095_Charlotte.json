  {
   "offset": 61,
   "len": 18,
   "en": "\"Hello again, $G.\"",
   "zh": "「又見面了，$G。」",
   "note": "再次見面問候"
  },
  {
   "offset": 80,
   "len": 14,
   "en": "\"Good $T, $G.\"",
   "zh": "「$T安，$G。」",
   "note": "時段問候"
  },
  {
   "offset": 103,
   "len": 36,
   "en": "\"I am called Charlotte @Weaver, $G.\"",
   "zh": "「吾名夏綠蒂·@Weaver（織女），$G。」",
   "note": "@Weaver keyword"
  },
  {
   "offset": 155,
   "len": 32,
   "en": "\"I am but a humble @weaver, $G.\"",
