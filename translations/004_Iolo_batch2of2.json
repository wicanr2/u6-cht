    {"offset": 4622, "len": 52, "en": "Iolo gathers up everyone's gold and hands it to you.", "zh": "尤洛將眾人之金幣匯齊，交予閣下。", "zh_bytes": 32, "note": "敘述句"},
    {"offset": 4675, "len": 39, "en": "\"None of us are carrying any gold, $G.\"", "zh": "「咱們無人攜帶金幣，$G。」", "zh_bytes": 26, "note": "保留 $G"},
    {"offset": 4724, "len": 53, "en": "Iolo collects some gold together and hands it to you.", "zh": "尤洛湊了些金幣，交予閣下。", "zh_bytes": 26, "note": "敘述句"},
    {"offset": 4780, "len": 44, "en": "\"Here, this is all you can carry right now.\"", "zh": "「來，此乃閣下當前所能攜帶之數。」", "zh_bytes": 34, "note": ""},
    {"offset": 4825, "len": 42, "en": "\"You're carrying enough already, I think.\"", "zh": "「在下看閣下已攜帶足矣。」", "zh_bytes": 26, "note": ""},
    {"offset": 4974, "len": 26, "en": "\"But we have no gold, $G!\"", "zh": "「然吾等並無金幣，$G！」", "zh_bytes": 24, "note": "保留 $G"},
    {"offset": 5013, "len": 47, "en": "\"We don't have enough gold to bother with, $G.\"", "zh": "「咱們的金幣不足道哉，$G。」", "zh_bytes": 28, "note": "保留 $G"},
    {"offset": 5206, "len": 60, "en": "Iolo gathers everyone's gold together and divides it evenly.", "zh": "尤洛將眾人之金幣匯齊，再均分予諸人。", "zh_bytes": 36, "note": "敘述句"},
    {"offset": 5389, "len": 67, "en": "Iolo splits up the gold between everyone who has room to carry any.", "zh": "尤洛將金幣分予尚能攜帶之眾人。", "zh_bytes": 30, "note": "敘述句"}
