   "len": 6,
   "en": "#2. $Y",
   "zh": "#2. $Y",
   "zh_bytes": 6,
   "note": "選單格式"
  },
  {
   "offset": 1679,
   "len": 16,
   "en": "\"Which of you?\" ",
   "zh": "「汝等哪位？」",
   "zh_bytes": 14,
   "note": ""
  },
  {
   "offset": 1748,
   "len": 24,
   "en": "\"@Cloth or @thread, $Y?\"",
   "zh": "「@Cloth（布）或@thread（線），$Y？」",
   "zh_bytes": 18,
   "note": "@Cloth → @布；@thread → @線"
  },
