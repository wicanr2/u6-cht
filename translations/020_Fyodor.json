  {
   "offset": 2734,
   "len": 30,
   "en": "\"Sorry, you haven't any wool.\"",
   "zh": "「抱歉，汝無羊毛可賣。」",
   "zh_bytes": 24,
   "note": ""
  },
  {
   "offset": 2771,
   "len": 24,
