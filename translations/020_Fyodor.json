   "zh_bytes": 2,
   "note": "@thread keyword"
  },
  {
   "offset": 1840,
   "len": 49,
   "en": "\"It'll cost you #1 gold for the $0. Interested?\" ",
   "zh": "「$0需#1金。$Y有意？」",
   "zh_bytes": 22,
   "note": "保留 $0/#1/$Y"
